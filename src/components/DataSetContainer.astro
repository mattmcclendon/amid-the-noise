---
interface DataSetItem {
  label: string;
  detail: string;
}

interface DataSetEntry {
  eyebrow: string;
  title: string;
  description: string;
  items: DataSetItem[];
}

interface Props {
  entries: DataSetEntry[];
  ariaLabel: string;
}

const { entries, ariaLabel } = Astro.props;
---

<ol class="data-set" aria-label={ariaLabel}>
  {entries.map((entry) => (
    <li class="data-set__entry">
      <div class="data-set__context">
        <p>{entry.eyebrow}</p>
        <h4>{entry.title}</h4>
        <p>{entry.description}</p>
      </div>

      <ul class="data-set__items">
        {entry.items.map((item) => (
          <li>
            <strong>{item.label}</strong>
            <span>{item.detail}</span>
          </li>
        ))}
      </ul>
    </li>
  ))}
</ol>

<style>
  .data-set {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .data-set__entry {
    display: grid;
    grid-template-columns: minmax(11rem, 35fr) minmax(0, 65fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    min-width: 0;
    padding: 1.4rem 1.35rem 1.5rem;
  }

  .data-set__entry + .data-set__entry {
    border-top: 1px solid rgba(31, 31, 31, .12);
  }

  .data-set__context {
    min-width: 0;
  }

  .data-set__context > p:first-child {
    margin: 0 0 .3rem;
    font-family: var(--font-ui);
    font-size: .66rem;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(31, 31, 31, .62);
  }

  .data-set__context h4 {
    margin: 0 0 .35rem;
    font-family: var(--font-reading);
    font-size: 1.02rem;
    line-height: 1.2;
    color: var(--title);
  }

  .data-set__context > p:last-child {
    margin: 0;
    font-family: var(--font-ui);
    font-size: .75rem;
    line-height: 1.45;
    color: rgba(31, 31, 31, .68);
  }

  .data-set__items {
    display: grid;
    grid-template-columns: 1fr;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .data-set__items li {
    padding: .72rem 0 .78rem;
  }

  .data-set__items li:first-child {
    padding-top: 0;
  }

  .data-set__items li + li {
    border-top: 1px solid rgba(31, 31, 31, .12);
  }

  .data-set__items strong,
  .data-set__items span {
    display: block;
  }

  .data-set__items strong {
    font-family: var(--font-reading);
    font-size: .87rem;
    line-height: 1.3;
    color: var(--title);
  }

  .data-set__items span {
    margin-top: .1rem;
    font-family: var(--font-ui);
    font-size: .71rem;
    line-height: 1.4;
    color: rgba(31, 31, 31, .63);
  }

  @media (max-width: 760px) {
    .data-set__entry {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .data-set__context {
      max-width: 34rem;
    }
  }
</style>

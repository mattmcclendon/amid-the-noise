---
interface IntroLink {
  label: string;
  href: string;
}

interface Props {
  section?: 'writing' | 'podcast' | 'research' | 'lexicon' | 'career';
  title: string;
  intro?: string;
  introLink?: IntroLink;
  showHeader?: boolean;
}

const {
  section = 'writing',
  title,
  intro,
  introLink,
  showHeader = true,
} = Astro.props;

void showHeader;
---

<section class={`section section-page section-page--${section}`}>
  <header class="section-page__header">
    <div class="section-page__title-block">
      <h1>{title}</h1>
      {intro && (
        <p>
          {intro}
          {introLink && <> <a href={introLink.href}>{introLink.label}</a></>}
        </p>
      )}
    </div>
  </header>

  <div class="section-page__body">
    <slot />
  </div>

</section>

<style>
  .section-page {
    --section-accent: var(--accent-neutral);
  }

  .section-page--writing {
    --section-accent: var(--accent-writing);
  }

  .section-page--podcast {
    --section-accent: var(--accent-podcast);
  }

  .section-page--research {
    --section-accent: var(--accent-research);
  }

  .section-page--lexicon {
    --section-accent: var(--accent-lexicon);
  }

  .section-page--career {
    --section-accent: var(--accent-career);
  }

  .section-page__header {
    position: relative;
    margin-bottom: 2rem;
  }

  .section-page__title-block {
    min-width: 0;
    max-width: 42rem;
  }

  .section-page__header h1 {
    margin: 0 0 1.2rem;
  }

  .section-page__header p {
    max-width: 42rem;
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(31, 31, 31, 0.9);
  }

  .section-page__header p a {
    color: var(--section-accent);
  }

  .section-page__header p a:hover {
    color: var(--section-accent);
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 1px;
  }


  .section-page__body {
    display: grid;
    gap: 1.75rem;
  }
</style>

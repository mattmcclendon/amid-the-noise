---
interface SectionNavItem {
  label: string;
  href: string;
}

interface Props {
  section?: 'writing' | 'research' | 'lexicon' | 'career';
  title: string;
  intro?: string;
  showHeader?: boolean;
  sectionNav?: SectionNavItem[];
}

const {
  section = 'writing',
  title,
  intro,
  showHeader = true,
  sectionNav = [],
} = Astro.props;

void showHeader;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<section class={`section section-page section-page--${section}`}>
  <header class="section-page__header">
    <div class="section-page__title-block">
      <h1>{title}</h1>
      {intro && <p>{intro}</p>}
    </div>
    {sectionNav.length > 0 && (
      <nav class="section-page__nav" aria-label={`${title} navigation`}>
        {sectionNav.map((item) => {
          const itemPath = item.href.replace(/\/$/, '') || '/';
          const isActive = currentPath === itemPath;

          return (
            <a href={item.href} aria-current={isActive ? 'page' : undefined}>
              {item.label}
            </a>
          );
        })}
      </nav>
    )}
  </header>

  <div class="section-page__body">
    <slot />
  </div>

</section>

<style>
  .section-page {
    --section-accent: var(--accent-neutral);
  }

  .section-page--writing {
    --section-accent: var(--accent-writing);
  }

  .section-page--research {
    --section-accent: var(--accent-research);
  }

  .section-page--lexicon {
    --section-accent: var(--accent-lexicon);
  }

  .section-page--career {
    --section-accent: var(--accent-career);
  }

  .section-page__header {
    position: relative;
    margin-bottom: 2rem;
  }

  .section-page__title-block {
    min-width: 0;
    max-width: 42rem;
  }

  .section-page__header h1 {
    margin: 0 0 1.2rem;
  }

  .section-page__header p {
    max-width: 42rem;
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(31, 31, 31, 0.82);
  }

  .section-page__nav {
    position: absolute;
    top: 0.15rem;
    right: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.45rem 0.75rem;
    max-width: 28rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.82rem;
    line-height: 1.4;
    letter-spacing: 0.01em;
  }

  .section-page__nav a {
    color: rgba(31, 31, 31, 0.5);
    text-decoration: none;
  }

  .section-page__nav a + a::before {
    content: '/';
    margin-right: 0.75rem;
    color: rgba(31, 31, 31, 0.28);
  }

  .section-page__nav a[aria-current='page'] {
    color: rgba(31, 31, 31, 0.76);
    font-weight: 600;
  }

  .section-page__nav a:hover {
    color: rgba(31, 31, 31, 0.9);
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 1px;
  }


  .section-page__body {
    display: grid;
    gap: 1.75rem;
  }

  @media (max-width: 820px) {
    .section-page__header {
      position: relative;
    }

    .section-page__nav {
      position: static;
      margin-top: 1.15rem;
      max-width: none;
      justify-content: flex-start;
      text-align: left;
    }
  }
</style>
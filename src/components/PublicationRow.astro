---
interface Props {
  title: string;
  href: string;
  date?: string;
  datetime?: string;
  description?: string;
  tags?: string[];
  accent?: string;
  showAccentBar?: boolean;
  tagsAsLinks?: boolean;
}

const {
  title,
  href,
  date,
  datetime,
  description,
  tags = [],
  accent = 'var(--section-accent)',
  showAccentBar = true,
  tagsAsLinks = false,
} = Astro.props;

const slugifyTag = (tag: string) =>
  tag
    .toLowerCase()
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
---

<article class:list={['publication-row', { 'has-accent': showAccentBar }]} style={`--row-accent:${accent}`}>
  <h3><a href={href}>{title}</a></h3>
  {date && <time datetime={datetime}>{date}</time>}
  {description && <p>{description}</p>}

  {tags.length > 0 && (
    <ul class="publication-tags" aria-label="Tags">
      {tags.map((tag) => (
        <li>
          {tagsAsLinks ? <a href={`/writing/tag/${slugifyTag(tag)}`}>{tag}</a> : tag}
        </li>
      ))}
    </ul>
  )}
</article>

<style>
  .publication-row + .publication-row {
    border-top: 1px solid rgba(31,31,31,.14);
  }

  .publication-row {
    position: relative;
    display: grid;
    padding: 1.65rem 0 1.75rem 1rem;
  }

  .publication-row.has-accent::before {
    content: '';
    position: absolute;
    top: 1.45rem;
    left: 0;
    width: 3px;
    height: 56px;
    background: var(--row-accent);
  }

  .publication-row h3 {
    margin: 0 0 .35rem;
    font-size: clamp(1.02rem,1.45vw,1.18rem);
    line-height: 1.18;
    letter-spacing: -.014em;
    font-weight: 700;
  }

  .publication-row h3 a {
    color: inherit;
    text-decoration: none;
  }

  .publication-row time {
    display:block;
    margin:0 0 .65rem;
    font-size:.88rem;
    color: var(--secondary);
  }

  .publication-row p {
    margin:0 0 .78rem;
    font-family: var(--font-ui);
    font-size:.92rem;
    line-height:1.5;
    color: var(--secondary);
  }

  .publication-tags {
    display:flex;
    flex-wrap:wrap;
    gap:.4rem;
    margin:0;
    padding:0;
    list-style:none;
  }

  .publication-tags li {
    border:1px solid rgba(31,31,31,.14);
    padding:.16rem .45rem;
    font-family: var(--font-ui);
    font-size:.78rem;
    letter-spacing:.05em;
    text-transform:uppercase;
    color: var(--secondary);
    background:rgba(248,247,244,.4);
  }

  .publication-tags a {
    color: inherit;
    text-decoration: none;
  }

  .publication-tags a:hover,
  .publication-tags a:focus-visible {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  .publication-row h3 a:hover,
  .publication-row h3 a:focus-visible {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 1px;
  }
</style>

---
import ContentRow from './ContentRow.astro';

interface Concept {
  title: string;
  description: string;
  href?: string;
}

interface RelatedWork {
  title: string;
  href: string;
  meta: string;
  description: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  featured: Concept[];
  related: RelatedWork[];
  additionalTitle: string;
  additional: Concept[];
}

const { eyebrow, title, intro, featured, related, additionalTitle, additional } = Astro.props;

const slugify = (term: string) =>
  term
    .toLowerCase()
    .replace(/→/g, '')
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');

const sectionId = slugify(title);

const accentForRelatedWork = (meta: string) => {
  const contentType = meta.toLowerCase();

  if (contentType.includes('paper')) return 'var(--accent-papers)';
  if (contentType.includes('field study')) return 'var(--accent-field-studies)';
  return 'var(--accent-writing)';
};
---

<section class="lexicon-section" aria-labelledby={`${sectionId}-title`}>
  <header class="lexicon-group-header">
    {eyebrow && <p class="lexicon-eyebrow">{eyebrow}</p>}
    <h2 id={`${sectionId}-title`}>{title}</h2>
    {intro && <p class="lexicon-intro">{intro}</p>}
  </header>

  <div class="concept-list">
    {featured.map((entry) => (
      <article class="concept-card" id={slugify(entry.title)}>
        <h3>{entry.href ? <a href={entry.href}>{entry.title} →</a> : entry.title}</h3>
        <p class="concept-definition">{entry.description}</p>
      </article>
    ))}
  </div>

  <section class="related-work" aria-labelledby={`${sectionId}-related-title`}>
    <h3 id={`${sectionId}-related-title`}>Where this thinking appears</h3>
    <div class="content-list">
      {related.map((item) => (
        <ContentRow
          href={item.href}
          title={item.title}
          meta={item.meta}
          metaLabel="Content type"
          description={item.description}
          tags={[]}
          accent={accentForRelatedWork(item.meta)}
        />
      ))}
    </div>
  </section>

  <section class="additional-concepts" aria-labelledby={`${sectionId}-additional-title`}>
    <h3 id={`${sectionId}-additional-title`}>{additionalTitle}</h3>
    <div class="concept-grid">
      {additional.map((entry) => (
        <article class="concept-card concept-card--compact" id={slugify(entry.title)}>
          <h4>{entry.href ? <a href={entry.href}>{entry.title} →</a> : entry.title}</h4>
          <p class="concept-definition">{entry.description}</p>
        </article>
      ))}
    </div>
  </section>
</section>

<style>
  .lexicon-section {
    margin-top: 4rem;
  }

  .lexicon-section:first-child {
    margin-top: 3rem;
  }

  .lexicon-group-header {
    margin-bottom: 1.5rem;
  }

  .lexicon-eyebrow,
  .lexicon-section h2,
  .related-work > h3,
  .additional-concepts > h3 {
    font-family: var(--font-ui);
    text-transform: uppercase;
  }

  .lexicon-eyebrow {
    margin: 0 0 0.4rem;
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.14em;
    color: var(--secondary);
  }

  .lexicon-section h2,
  .related-work > h3,
  .additional-concepts > h3 {
    margin: 0 0 1.25rem;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.14em;
    color: var(--secondary);
  }

  .lexicon-intro {
    max-width: 68ch;
    margin: 0.65rem 0 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--secondary);
  }

  .concept-list,
  .content-list {
    display: grid;
    gap: 0;
  }

  .concept-card {
    padding: 1.35rem 0 1.45rem;
    border-top: 1px solid var(--line);
  }

  .concept-card:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .concept-card h3,
  .concept-card h4 {
    margin: 0 0 0.5rem;
    font-family: var(--font-ui);
    font-size: clamp(0.96rem, 1.25vw, 1.06rem);
    font-weight: 500;
    line-height: 1.22;
  }

  .concept-card a {
    color: inherit;
    text-decoration: none;
  }

  .concept-card a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  .concept-definition {
    max-width: 72ch;
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.65;
    color: rgba(31, 31, 31, 0.88);
  }

  .related-work,
  .additional-concepts {
    margin-top: 3rem;
  }

  .concept-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0 2.5rem;
  }

  .concept-card--compact:nth-child(-n + 2) {
    padding-top: 0;
    border-top: 0;
  }

  @media (max-width: 760px) {
    .concept-grid {
      grid-template-columns: 1fr;
    }

    .concept-card--compact:nth-child(2) {
      padding-top: 1.35rem;
      border-top: 1px solid var(--line);
    }
  }
</style>



---
interface Props {
  title: string;
  href: string;
  description?: string;
}

const {
  title,
  href,
  description,
} = Astro.props;
---

<article class="destination-row">
  <a href={href}>
    <div>
      <h3>{title}</h3>
      {description && <p>{description}</p>}
    </div>
  </a>
</article>

<style>
  .destination-row + .destination-row {
    border-top: 1px solid rgba(31, 31, 31, 0.14);
  }

  .destination-row a {
    display: block;
    padding: 1.65rem 0;
    color: inherit;
    text-decoration: none;
  }

  .destination-row h3 {
    margin: 0 0 0.35rem;
    font-size: clamp(1.08rem, 1.7vw, 1.28rem);
    line-height: 1.18;
    letter-spacing: -0.014em;
    font-weight: 700;
  }

  .destination-row p {
    margin: 0;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.92rem;
    line-height: 1.5;
    color: rgba(31, 31, 31, 0.82);
  }

  .destination-row a:hover h3 {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 1px;
  }
</style>
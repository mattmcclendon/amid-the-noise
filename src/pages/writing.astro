---
import Layout from '../layouts/Layout.astro';

const postModules = import.meta.glob('./writing/*.md', { eager: true });
const posts = Object.values(postModules);

const datedPosts = posts.filter((post) => {
  const pubDate = post.frontmatter?.pubDate;
  return pubDate && !Number.isNaN(new Date(pubDate).getTime());
});

datedPosts.sort((a, b) => {
  return new Date(b.frontmatter.pubDate) - new Date(a.frontmatter.pubDate);
});

const formatPostDate = (pubDate, options = {}) => {
  const date = new Date(pubDate);

  const now = new Date();
  const currentYear = now.getFullYear();
  const postYear = date.getFullYear();

  const includeYear = options.alwaysShowYear === true ? true : postYear !== currentYear;

  return date.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    ...(includeYear ? { year: 'numeric' } : {}),
  });
};

const getPostSlug = (post) => post.url?.split('/').filter(Boolean).pop();
const postsBySlug = new Map(datedPosts.map((post) => [getPostSlug(post), post]));

const startHereSlugs = [
  'where-does-truth-live',
  'the-only-metric',
  'the-deck-was-always-mine',
  'compression-character-and-the-worlds-we-build',
  'before-we-called-it-social',
  'one-degree-of-drift',
  'the-lineage-of-signal',
];

const foundationalSlugs = [
  'when-ai-is-wrong-a-simple-operating-model-for-real-world-systems',
  'designed-to-fail-excused-by-scarcity',
  'toward-a-human-centered-intelligence-infrastructure',
  'the-reciprocity-principle-of-emerging-intelligence',
];

const startHerePosts = startHereSlugs
  .map((slug) => postsBySlug.get(slug))
  .filter(Boolean);

const foundationalPosts = foundationalSlugs
  .map((slug) => postsBySlug.get(slug))
  .filter(Boolean);

const featuredSlugs = new Set([
  ...foundationalSlugs,
  ...startHereSlugs,
]);

const recentPosts = datedPosts
  .filter((post) => !featuredSlugs.has(getPostSlug(post)))
  .slice(0, 6);

const getThemePosts = (theme) => {
  const pool = datedPosts.filter((post) => {
    const postTags = post.frontmatter.tags ?? [];
    return !featuredSlugs.has(getPostSlug(post)) && theme.tags.some((tag) => postTags.includes(tag));
  });

  const sortByDate = (arr) => arr.sort((a, b) => new Date(b.frontmatter.pubDate) - new Date(a.frontmatter.pubDate));

  const tierOne = sortByDate(pool.filter((post) => post.frontmatter?.tier === 'tier-1'));
  const tierTwo = sortByDate(pool.filter((post) => post.frontmatter?.tier === 'tier-2'));
  const tierThree = sortByDate(pool.filter((post) => post.frontmatter?.tier === 'tier-3'));

  return [...tierOne, ...tierTwo, ...tierThree].slice(0, 6);
};

const themeGroups = [
  {
    title: 'Signal, Trust, and Perception',
    description: 'Essays on truth, interpretation, attention, and the ways signal degrades under pressure.',
    tags: ['Signal', 'Perception', 'Truth', 'Narrative', 'Language', 'Cognitive Bias'],
  },
  {
    title: 'Civic Systems and Dignity',
    description: 'Writing on public infrastructure, institutional behavior, policy inertia, and systems that either preserve or erode agency.',
    tags: ['Civic Systems', 'Governance', 'Policy', 'Power', 'Dignity', 'Infrastructure'],
  },
  {
    title: 'AI and Decision Systems',
    description: 'Work on AI governance, decision design, risk, human judgment, and systems that must remain accountable under uncertainty.',
    tags: ['AI Governance', 'Decision Design', 'Systems Thinking', 'Governance', 'Metrics', 'Workflows'],
  },
  {
    title: 'Sovereign Reflection',
    description: 'Personal essays on recovery, memory, agency, clarity, and the discipline of becoming legible to oneself.',
    tags: ['Recovery', 'Agency', 'Voice', 'Reflection', 'Clarity', 'Presence'],
  },
  {
    title: 'Place, Memory, and Continuity',
    description: 'Reflections on cities, inherited landscapes, travel, family memory, and the places that keep speaking after we leave.',
    tags: ['Place', 'Memory', 'Travel', 'History', 'Continuity', 'Lineage'],
  },
  {
    title: 'Builders, Startups, and Product Judgment',
    description: 'Writing on product judgment, founder behavior, early-stage systems, and the practice of building with consequence.',
    tags: ['Startups', 'Product', 'Execution', 'Growth', 'Fundraising', 'Users'],
  },
];

---

<Layout title="Writing | Amid the Noise">
  <section class="section writing-hero" data-pagefind-ignore>
    <h1>Writing</h1>
    <p class="intro-lead">
      Amid the Noise is a working archive of essays, reflections, and papers on signal, systems, trust, agency, and the structures that shape how people think, decide, and act. Start with the foundational pieces, follow a pathway, or move into the full archive when you want the complete record.
    </p>

    <div class="decision-grid" aria-label="Writing paths">
      <a class="decision-card" href="#foundational">
        <span>Foundational Papers</span>
        <p>Begin with the pieces that define the core argument.</p>
      </a>
      <a class="decision-card" href="#themes">
        <span>Reader Pathways</span>
        <p>Follow the main routes through the body of work.</p>
      </a>
      <a class="decision-card" href="/writing/archive">
        <span>Full Archive</span>
        <p>View the complete chronological record.</p>
      </a>
    </div>
  </section>
  <section class="section" id="foundational" data-pagefind-ignore>
    <div class="section-heading">
      <h2>Foundational Papers</h2>
      <p>The pieces that define the central operating model behind the archive: how systems behave, how signal degrades, and how trust survives contact with reality.</p>
    </div>

    <div class="foundation-grid">
      {foundationalPosts.map((post) => (
        <article class="supporting-post">
          <span>Foundational Paper</span>

          <h3>
            <a href={post.url}>{post.frontmatter.title}</a>
          </h3>

          <p class="entry-meta">
            {formatPostDate(post.frontmatter.pubDate)}
          </p>

          <p>{post.frontmatter.description}</p>
        </article>
      ))}
    </div>
  </section>
  <section class="section" id="start-here" data-pagefind-ignore>
    <div class="section-heading">
      <h2>Start Here</h2>
      <p>Seven reader-friendly entry points into the archive, chosen to introduce the voice, range, and recurring questions behind the work.</p>
    </div>

    <div class="featured-list">
      {startHerePosts.map((post) => (
        <article class="entry featured-entry">
          <h3>
            <a href={post.url}>{post.frontmatter.title}</a>
          </h3>

          <p class="entry-meta">
            {formatPostDate(post.frontmatter.pubDate)}
          </p>

          <p>{post.frontmatter.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="themes" data-pagefind-ignore>
    <div class="section-heading">
      <h2>Reader Pathways</h2>
      <p>Six ways into the archive, organized by reader intent rather than chronology.</p>
    </div>

    <div class="theme-grid">
      {themeGroups.map((theme) => {
        const themePosts = getThemePosts(theme);
        return (
          <article class="theme-card">
            <h3>{theme.title}</h3>
            <p>{theme.description}</p>

            {themePosts.length > 0 && (
              <ul>
                {themePosts.map((post) => (
                  <li><a href={post.url}>{post.frontmatter.title}</a></li>
                ))}
              </ul>
            )}
          </article>
        );
      })}
    </div>
  </section>

  <section class="section" data-pagefind-ignore>
    <div class="section-heading">
      <h2>Recent Writing</h2>
      <p>The latest additions to the collection. <a href="/writing/archive">View the full archive</a>.</p>
    </div>

    {recentPosts.map((post) => (
      <article class="entry">
        <h3>
          <a href={post.url}>{post.frontmatter.title}</a>
        </h3>

        <p class="entry-meta">
          {formatPostDate(post.frontmatter.pubDate)}
        </p>

        <p>{post.frontmatter.description}</p>
      </article>
    ))}
  </section>
</Layout>

<style>

  .eyebrow {
    margin: 0 0 12px;
    font-size: 0.78rem;
    line-height: 1.35;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  .intro-lead {
    max-width: 42rem;
    font-size: 0.98rem;
    line-height: 1.58;
    color: var(--text);
  }

  .decision-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 34px;
    max-width: 56rem;
  }

  .decision-card {
    display: block;
    border: 1px solid var(--line);
    padding: 18px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .decision-card:hover,
  .decision-card:focus-visible {
    border-color: var(--text);
    transform: translateY(-2px);
  }

  .decision-card span {
    display: block;
    font-size: 0.78rem;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
    margin-bottom: 12px;
    font-weight: 600;
    white-space: nowrap;
  }

  .decision-card p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--text);
  }

  .section-heading {
    margin-bottom: 44px;
  }

  .section-heading h2 {
    margin: 0 0 22px;
    font-size: 0.92rem;
    line-height: 1.3;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  .section-heading p {
    margin: 0 0 20px;
    max-width: 38rem;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--text);
  }

  .foundation-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    max-width: 56rem;
  }

  .supporting-post {
    border: 1px solid var(--line);
    padding: 20px;
  }

  .supporting-post span {
    display: block;
    margin: 0 0 12px;
    font-size: 0.72rem;
    line-height: 1.2;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  .supporting-post h3 {
    font-size: 1.1rem;
    line-height: 1.35;
    font-weight: 600;
    margin: 0 0 4px;
  }

  .supporting-post h3 a {
    color: var(--title);
    text-decoration: none;
  }

  .supporting-post h3 a:hover,
  .supporting-post h3 a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  .supporting-post p:last-child {
    margin-bottom: 0;
  }

  .featured-list .entry:first-child,
  .entry:first-of-type {
    border-top: 0;
  }

  .featured-entry h3 {
    font-size: 1.15rem;
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .theme-card {
    border: 1px solid var(--line);
    padding: 20px;
  }

  .theme-card h3 {
    font-size: 1rem;
    line-height: 1.35;
    margin: 0 0 8px;
  }

  .theme-card p {
    margin: 0 0 16px;
    color: var(--text);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .theme-card ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .theme-card li {
    border-top: 1px solid var(--line);
    padding: 12px 0;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .theme-card li:last-child {
    padding-bottom: 0;
  }

  .theme-card a {
    color: var(--title);
    text-decoration: none;
    font-weight: 600;
  }

  .theme-card a:hover,
  .theme-card a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  .entry h3 {
    font-size: 1.15rem;
    line-height: 1.35;
    font-weight: 600;
    margin: 0 0 4px;
  }

  @media (max-width: 760px) {
    .decision-grid,
    .foundation-grid,
    .theme-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
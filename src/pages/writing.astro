---
import Layout from '../layouts/Layout.astro';

const postModules = import.meta.glob('./writing/*.md', { eager: true });
const posts = Object.values(postModules);

posts.sort((a, b) => {
  return new Date(b.frontmatter.pubDate) - new Date(a.frontmatter.pubDate);
});

const getPostSlug = (post) => post.url?.split('/').filter(Boolean).pop();
const postsBySlug = new Map(posts.map((post) => [getPostSlug(post), post]));

const startHereSlugs = [
  'when-ai-is-wrong-a-simple-operating-model-for-real-world-systems',
  'designed-to-fail-excused-by-scarcity',
  'the-deck-was-always-mine',
  'compression-character-and-the-worlds-we-build',
  'standing-on-the-edge',
  'ai-is-a-stack',
  'before-we-called-it-social',
];

const themeGroups = [
  {
    title: 'Signal, Systems, and Trust',
    description: 'Essays on civic systems, institutional design, and the structures that shape public life.',
    tags: ['Civic Systems', 'Trust', 'Signal', 'Systems Thinking'],
  },
  {
    title: 'AI and Decision Systems',
    description: 'Writing on AI, judgment, risk, interface design, and human responsibility under pressure.',
    tags: ['AI', 'AI Safety', 'Decision Systems', 'Human-in-the-Loop'],
  },
  {
    title: 'Builders and Startups',
    description: 'Work on product judgment, founder behavior, early-stage systems, and the practice of building well.',
    tags: ['Startup Series', 'Startups', 'Product Strategy', 'Innovation'],
  },
  {
    title: 'Sovereign Reflection',
    description: 'Personal essays on recovery, memory, agency, and the hard work of becoming clear.',
    tags: ['Recovery', 'Agency', 'Voice', 'Reflection'],
  },
];

const startHerePosts = startHereSlugs
  .map((slug) => postsBySlug.get(slug))
  .filter(Boolean);

const recentPosts = posts
  .filter((post) => !startHereSlugs.includes(getPostSlug(post)))
  .slice(0, 6);

const getThemePosts = (theme) => posts
  .filter((post) => {
    const postTags = post.frontmatter.tags ?? [];
    return theme.tags.some((tag) => postTags.includes(tag));
  })
  .slice(0, 4);
---

<Layout title="Writing | Amid the Noise">
  <section class="section writing-hero" data-pagefind-ignore>
    <h1>Writing</h1>
    <p class="intro-lead">
      Essays, reflections, and working notes on signal, systems, trust, and agency. Start with the curated pieces, follow a theme, or move into the full archive when you want the complete record.
    </p>

    <div class="decision-grid" aria-label="Writing paths">
      <a class="decision-card" href="#start-here">
        <span>Start Here</span>
        <p>Begin with the pieces that best introduce the work.</p>
      </a>
      <a class="decision-card" href="#themes">
        <span>Explore by Theme</span>
        <p>Follow the major lanes across the collection.</p>
      </a>
      <a class="decision-card" href="/writing/archive">
        <span>Browse Everything</span>
        <p>View the full chronological archive.</p>
      </a>
    </div>
  </section>

  <section class="section" id="start-here" data-pagefind-ignore>
    <div class="section-heading">
      <h2>Start Here</h2>
      <p>Seven pieces that orient the larger body of work.</p>
      <p></p>
    </div>

    <div class="featured-list">
      {startHerePosts.map((post) => (
        <article class="entry featured-entry">
          <h3>
            <a href={post.url}>{post.frontmatter.title}</a>
          </h3>

          <p class="entry-meta">
            {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
            })}
          </p>

          <p>{post.frontmatter.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="themes" data-pagefind-ignore>
    <div class="section-heading">
      <h2>Explore by Theme</h2>
      <p>Four ways into the archive, organized by reader intent rather than chronology.</p>
    </div>

    <div class="theme-grid">
      {themeGroups.map((theme) => {
        const themePosts = getThemePosts(theme);
        return (
          <article class="theme-card">
            <h3>{theme.title}</h3>
            <p>{theme.description}</p>

            {themePosts.length > 0 && (
              <ul>
                {themePosts.map((post) => (
                  <li><a href={post.url}>{post.frontmatter.title}</a></li>
                ))}
              </ul>
            )}
          </article>
        );
      })}
    </div>
  </section>

  <section class="section" data-pagefind-ignore>
    <div class="section-heading">
      <h2>Recent Writing</h2>
      <p>The latest additions to the collection. <a href="/writing/archive">View the full archive</a>.</p>
    </div>

    {recentPosts.map((post) => (
      <article class="entry">
        <h3>
          <a href={post.url}>{post.frontmatter.title}</a>
        </h3>

        <p class="entry-meta">
          {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
          })}
        </p>

        <p>{post.frontmatter.description}</p>
      </article>
    ))}
  </section>
</Layout>

<style>

  .eyebrow {
    margin: 0 0 12px;
    font-size: 0.78rem;
    line-height: 1.35;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  .intro-lead {
    max-width: 42rem;
    font-size: 0.98rem;
    line-height: 1.58;
    color: var(--text);
  }

  .decision-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 34px;
    max-width: 56rem;
  }

  .decision-card {
    display: block;
    border: 1px solid var(--line);
    padding: 18px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .decision-card:hover,
  .decision-card:focus-visible {
    border-color: var(--text);
    transform: translateY(-2px);
  }

  .decision-card span {
    display: block;
    font-size: 0.78rem;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
    margin-bottom: 12px;
    font-weight: 600;
    white-space: nowrap;
  }

  .decision-card p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--text);
  }

  .section-heading {
    margin-bottom: 24px;
  }

  .section-heading h2 {
    margin: 0 0 22px;
    font-size: 0.92rem;
    line-height: 1.3;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  .section-heading p {
    margin: 0;
    max-width: 38rem;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--text);
  }


  .featured-list .entry:first-child,
  .entry:first-of-type {
    border-top: 0;
  }

  .featured-entry h3 {
    font-size: 1.15rem;
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .theme-card {
    border: 1px solid var(--line);
    padding: 20px;
  }

  .theme-card h3 {
    font-size: 1rem;
    line-height: 1.35;
    margin: 0 0 8px;
  }

  .theme-card p {
    margin: 0 0 16px;
    color: var(--text);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .theme-card ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .theme-card li {
    border-top: 1px solid var(--line);
    padding: 12px 0;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .theme-card li:last-child {
    padding-bottom: 0;
  }

  .theme-card a {
    color: var(--title);
    text-decoration: none;
    font-weight: 600;
  }

  .theme-card a:hover,
  .theme-card a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  .entry h3 {
    font-size: 1.15rem;
    line-height: 1.35;
    font-weight: 600;
    margin: 0 0 4px;
  }

  @media (max-width: 760px) {
    .decision-grid,
    .theme-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
---
import Layout from '../layouts/Layout.astro';

const postModules = import.meta.glob('./writing/*.md', { eager: true });
const posts = Object.values(postModules);

const tagCounts = posts.reduce((acc, post) => {
  for (const tag of post.frontmatter.tags ?? []) {
    acc.set(tag, (acc.get(tag) ?? 0) + 1);
  }
  return acc;
}, new Map());

const allTags = [...tagCounts.entries()]
  .filter(([, count]) => count >= 2)
  .sort((a, b) => {
    if (b[1] !== a[1]) return b[1] - a[1];
    return a[0].localeCompare(b[0]);
  })
  .slice(0, 14)
  .map(([tag]) => tag);

posts.sort((a, b) => {
  return new Date(b.frontmatter.pubDate) - new Date(a.frontmatter.pubDate);
});
---

<Layout title="Writing | Amid the Noise">
<section class="section">
    <h1>Writing</h1>
    <p>
      A complete collection of essays and reflections on systems, signal, and the structures that shape how people think, decide, and act.
    </p>

    {allTags.length > 0 && (
      <div class="filters" aria-label="Filter posts by tag">
        <div class="filters-header">
          <span class="filters-label">Filter by:</span>
          <button
            class="filters-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="filter-options"
            data-current-filter="All"
          >
            <span class="filters-toggle-value">All</span>
            <span class="filters-toggle-caret">▾</span>
          </button>
        </div>

        <div class="filters-panel" id="filter-options" hidden>
          <button class="filter-chip is-active" type="button" data-filter="all">All</button>
          {allTags.map((tag) => (
            <button class="filter-chip" type="button" data-filter={tag}>{tag}</button>
          ))}
        </div>
      </div>
    )}
  </section>

  <section class="section">
    {posts.map((post) => (
      <article class="entry" data-tags={(post.frontmatter.tags ?? []).join('|')}>
        <h3>
          <a href={post.url}>{post.frontmatter.title}</a>
        </h3>

        <p class="entry-meta">
          {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
          })}
        </p>

        <p>{post.frontmatter.description}</p>

        {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
          <div class="entry-tags">
            {post.frontmatter.tags.map((tag) => (
              <button class="entry-tag" type="button" data-filter-trigger={tag}>{tag}</button>
            ))}
          </div>
        )}
      </article>
    ))}
  </section>

<script>
  const chips = Array.from(document.querySelectorAll('.filter-chip'));
  const entries = Array.from(document.querySelectorAll('.entry'));
  const tagTriggers = Array.from(document.querySelectorAll('[data-filter-trigger]'));
  const filterToggle = document.querySelector('.filters-toggle');
  const filterPanel = document.querySelector('.filters-panel');
  const filterToggleValue = document.querySelector('.filters-toggle-value');

  const setPanelOpen = (isOpen) => {
    if (!filterToggle || !filterPanel) return;
    filterToggle.setAttribute('aria-expanded', String(isOpen));
    filterPanel.hidden = !isOpen;
    filterToggle.classList.toggle('is-open', isOpen);
  };

  const applyFilter = (filter) => {
    entries.forEach((entry) => {
      const tags = (entry.getAttribute('data-tags') || '').split('|').filter(Boolean);
      const matches = filter === 'all' || tags.includes(filter);
      entry.style.display = matches ? '' : 'none';
    });

    chips.forEach((chip) => {
      chip.classList.toggle('is-active', chip.dataset.filter === filter);
    });

    if (filterToggleValue) {
      filterToggleValue.textContent = filter === 'all' ? 'All' : filter;
    }
  };

  if (filterToggle) {
    filterToggle.addEventListener('click', () => {
      const isOpen = filterToggle.getAttribute('aria-expanded') === 'true';
      setPanelOpen(!isOpen);
    });
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      applyFilter(chip.dataset.filter || 'all');
      setPanelOpen(false);
    });
  });

  tagTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const tag = trigger.getAttribute('data-filter-trigger') || 'all';
      applyFilter(tag);
      setPanelOpen(false);
      const filterRow = document.querySelector('.filters');
      if (filterRow) {
        filterRow.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });
  });

  document.addEventListener('click', (event) => {
    if (!filterToggle || !filterPanel) return;
    const target = event.target;
    if (!(target instanceof Node)) return;
    if (!filterToggle.contains(target) && !filterPanel.contains(target)) {
      setPanelOpen(false);
    }
  });
</script>
</Layout>

<style>

  .filters {
    margin-top: 26px; /* more breathing room from intro */
    margin-bottom: 6px; /* tighter to the hairline below */
  }

  .filters + .section {
    margin-top: 0;
  }

  .filters-header {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .filters-label {
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  .filters-toggle {
    appearance: none;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--text);
    padding: 6px 10px;
    font-size: 0.74rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: inherit;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .filters-toggle-caret {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .filters-toggle.is-open .filters-toggle-caret {
    transform: rotate(180deg);
  }

  .filters-panel {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
    padding-top: 2px;
    max-width: 44rem;
  }

  .filters-panel[hidden] {
    display: none;
  }

  .filter-chip {
    appearance: none;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--secondary);
    padding: 6px 10px;
    font-size: 0.74rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    font-family: inherit;
  }

  .filter-chip:hover,
  .filter-chip:focus-visible,
  .filter-chip.is-active {
    color: var(--text);
    border-color: var(--text);
  }

  .filters-panel .filter-chip {
    background: transparent;
  }

  .hero h1 {
    font-size: 1.6rem;
    line-height: 1.32;
    font-weight: 600;
    font-style: italic;
    max-width: 38rem;
  }

  .eyebrow {
    margin: 0 0 12px;
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--secondary);
  }

  .intro-lead {
    max-width: 40rem;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .recruiter-note {
    max-width: 40rem;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--secondary);
  }

  .intro {
    margin: 0 0 10px;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .intro em {
    font-style: italic;
  }

  .entry-tags {
    margin: 2px 0 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .entry-tag {
    display: inline-block;
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--secondary);
    border: 1px solid var(--line);
    padding: 5px 7px;
    background: transparent;
    appearance: none;
    cursor: pointer;
    font-family: inherit;
  }

  h2 {
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
    margin: 0 0 22px;
    font-weight: 500;
  }

  .entry h3 {
    font-size: 1.15rem;
    line-height: 1.35;
    font-weight: 600;
    margin: 0 0 4px;
  }
</style>
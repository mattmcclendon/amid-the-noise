---
import Layout from '../layouts/Layout.astro';
import SectionMoreLink from '../components/SectionMoreLink.astro';
import ArchiveImageModule from '../components/ArchiveImageModule.astro';

const selectedSlugs = [
  'anecdotes-to-systems',
  'the-first-year',
  'the-poll-site-is-a-decision-system',
  'xiao-long-bao',
  'the-lineage-of-signal',
];

const selectedLearning = [
  {
    kicker: 'Netscape / AOL',
    title: 'The First Comfortable Internet',
    href: '/writing/field-studies/netscape',
    description:
      'Early work across personalization, messaging convergence, and large-scale onboarding helped make the internet feel usable, familiar, and trustworthy for ordinary people.',
  },
  {
    kicker: 'Friendster',
    title: 'The Network Couldn’t Hold',
    href: '/writing/field-studies/friendster',
    description:
      'Inside the first real social network, unstable infrastructure, shifting product identity, and early social graph behavior revealed how quickly users could define a platform faster than the company itself.',
  },
  {
    kicker: 'Wells Fargo',
    title: 'Designing Human-Governed AI in a Regulated Enterprise',
    href: '/writing/field-studies/wells-fargo',
    description:
      'Inside Wells Fargo AI Enterprise Solutions, the work focused on operationalizing trust in regulated AI systems through governance frameworks, human oversight, interpretability, and scalable experimentation across 17 business units.',
  },
];

const featuredPaper = {
  title: 'The Infrastructure of Belonging',
  href: '/writing/papers/the-infrastructure-of-belonging',
  meta: 'Web Paper • June 2026',
  description:
    'A civic systems framework examining how institutions become reachable through connectors, continuity, and the reduction of distance. Drawing from elections, homelessness services, and public transit, the paper argues that belonging emerges when public systems bridge the gap between services and the people they serve.',
};

const papersNote = {
  href: '/writing/papers',
  description:
    'Browse additional papers, PDFs, and longer-form research on civic infrastructure, institutional design, decision systems, public trust, and the social consequences of technology.',
};

const postModules = import.meta.glob('./writing/*.md', { eager: true });

const selectedPosts = selectedSlugs
  .map((slug) => postModules[`./writing/${slug}.md`])
  .filter(Boolean);

const normalizeTags = (tags) => {
  if (Array.isArray(tags)) return tags;
  if (typeof tags === 'string') return [tags];
  return [];
};

const slugifyTag = (tag) =>
  tag
    .toLowerCase()
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
---

<Layout title="Amid the Noise">
  <section class="section hero">
    <p class="hero-quote">I study the systems people live inside.</p>
    <p class="intro intro-lead">Technology, institutions, cities, and organizations shape what people can see, choose, trust, and become. Their most consequential behavior is often the least visible.</p>
    <p class="intro"><em>Amid the Noise</em> is where I examine those structures through practice, research, and writing—and consider how they might become more understandable, accountable, and humane.</p>
    <p class="intro">Thank you for spending time with the work.</p>
    <img class="signature" src="/images/signature-matthew-mcclendon.svg" alt="Matthew McClendon signature" />
    <p class="signature-motto">Anecdotes are where I start. Systems are where we end up.</p>
  </section>
  <div class="home-archive-plate">
    <ArchiveImageModule
      src="/images/pages/atn-home-001.png"
      alt="Archival illustration introducing Amid the Noise."
    />
  </div>
  <section class="section learning-section">
    <h2>Selected Field Studies</h2>

    {selectedLearning.map((item) => (
      <article class="entry learning-entry">
        <h3>
          <a href={item.href}>{item.title}</a>
        </h3>

        <p class="learning-kicker">{item.kicker}</p>

        <p>{item.description}</p>
      </article>
    ))}
    <div class="learning-more">
      <p>Browse the complete field-study archive for observations from enterprise, civic, technical, and cultural systems under real operating conditions.</p>
      <SectionMoreLink href="/writing/field-studies" label="See all field studies" />
    </div>
  </section>

  <section class="section papers-section">
    <h2>Selected Papers</h2>

    <article class="entry papers-entry">
      <h3>
        <a href={featuredPaper.href}>{featuredPaper.title}</a>
      </h3>

      <p class="papers-meta">{featuredPaper.meta}</p>

      <p>{featuredPaper.description}</p>
    </article>

    <div class="papers-more">
      <p>{papersNote.description}</p>
      <SectionMoreLink href={papersNote.href} label="See all papers" />
    </div>
  </section>

  <section class="section">
    <h2>Selected Writing</h2>

    {selectedPosts.map((post) => (
      <article class="entry writing-entry">
        <h3>
          <a href={post.url}>{post.frontmatter.title}</a>
        </h3>

        <p class="entry-meta">
          {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
            timeZone: 'UTC',
          })}
        </p>

        <p>{post.frontmatter.description}</p>

        {normalizeTags(post.frontmatter.tags).length > 0 && (
          <div class="entry-tags">
            {normalizeTags(post.frontmatter.tags).map((tag) => (
              <a class="entry-tag" href={`/writing/tag/${slugifyTag(tag)}`}>{tag}</a>
            ))}
          </div>
        )}
      </article>
    ))}
  </section>

  <section class="section books-note">
    <h2>Published Writing</h2>
    <p>
      <a href="/writing/books"><em>Exit Wounds</em></a> extends the themes explored throughout <em>Amid the Noise</em> into poetry: recovery, toxic attachment, substance use, homelessness, and the cost of naming what survival required.
    </p>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    padding-bottom: 40px;
  }

  .hero-quote {
    max-width: 40rem;
    margin: 12px 0 20px;
    padding: 4px 0 12px 16px;
    border-left: 2px solid var(--line);
    font-size: 1.28rem;
    line-height: 1.5;
    font-weight: 500;
    font-style: italic;
    color: var(--title);
  }

  .eyebrow {
    margin: 0 0 12px;
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--secondary);
  }

  .intro.intro-lead {
    max-width: 41rem;
    margin: 0 0 16px;
    font-size: 1.04rem;
    line-height: 1.58;
    font-weight: 500;
    color: var(--text);
  }

  .recruiter-note {
    max-width: 42rem;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text);
    opacity: 0.9;
  }

  .intro {
    max-width: 41rem;
    margin: 0 0 14px;
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--text);
  }

  .signature {
    display: block;
    width: 200px;
    height: auto;
    margin-top: 24px;
    margin-left: 28px;
    opacity: 0.92;
  }

  .signature-motto {
  margin: 10px 0 0 48px;
  font-family: var(--font-display); /* same as logo */
  font-size: 0.91rem;
  font-style: italic;
  font-weight: 600;
  line-height: 1.4;
  color: var(--text);
  opacity: 0.85;
  }

  .intro em {
    font-style: italic;
  }

  .intro-strong {
    font-weight: 500;
    color: var(--text);
    opacity: 1;
  }

  h2 {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
    margin: 36px 0 36px;
  }

  .entry h3 {
    font-size: 1.15rem;
    line-height: 1.35;
    font-weight: 600;
    margin: 0 0 10px;
  }
  .entry-meta {
    margin: 0 0 8px;
    font-size: 0.78rem;
    line-height: 1.4;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--secondary);
  }

  .entry-tags {
    margin: 2px 0 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .entry-tag {
    display: inline-block;
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--secondary);
    border: 1px solid var(--line);
    padding: 5px 7px;
    background: transparent;
    text-decoration: none;
  }

  .entry-tag:hover,
  .entry-tag:focus-visible {
    color: var(--accent-posts);
    border-color: var(--accent-posts);
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  .learning-entry,
  .papers-entry,
  .writing-entry {
    padding-left: 14px;
  }

  .learning-entry h3,
  .papers-entry h3,
  .writing-entry h3 {
    position: relative;
  }

  .learning-entry h3::before,
  .papers-entry h3::before,
  .writing-entry h3::before {
    content: "";
    position: absolute;
    top: 0.08em;
    left: -14px;
    width: 3px;
    height: 48px;
    opacity: 1;
    pointer-events: none;
  }

  .learning-entry h3::before {
    background: var(--accent-field-studies);
  }

  .papers-entry h3::before {
    background: var(--accent-papers);
  }

  .writing-entry h3::before {
    background: var(--accent-posts);
  }

  .books-note a {
    color: var(--accent-posts);
  }

  .home-archive-plate {
    margin: 0 0 -1rem 0;
    padding-top: 30px;
    padding-bottom: -30px;
    border-top: 1px solid var(--line);
  }

  .home-archive-plate :global(.archive-image) {
    margin: 0 0 40px;
  }

  .learning-section {
    margin-top: 8px;
  }

  .papers-section {
    margin-top: 8px;
  }

  .papers-entry h3 {
    font-size: 1.08rem;
    line-height: 1.32;
    margin: 0 0 10px;
    color: var(--text);
  }

  .papers-meta {
    margin: 0 0 10px;
    font-size: 0.78rem;
    line-height: 1.4;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--secondary);
  }

  .papers-entry p {
    max-width: 46rem;
  }

  .papers-more,
  .learning-more {
    margin-top: 16px;
    padding-top: 14px;
    padding-left: 14px;
    border-top: 1px solid var(--line);
  }

  .papers-more p,
  .learning-more p {
    max-width: 46rem;
    margin: 0 0 8px;
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--text);
  }

  .papers-more p:last-child,
  .learning-more p:last-child {
    margin-bottom: 0;
  }

  .learning-kicker {
    margin: 0 0 10px;
    font-size: 0.78rem;
    line-height: 1.4;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--secondary);
  }

  .learning-entry h3 {
    font-size: 1.08rem;
    line-height: 1.32;
    margin: 0 0 10px;
    color: var(--text);
  }

  .learning-entry p {
    max-width: 46rem;
  }

  .learning-entry + .learning-entry {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--line);
  }

  .terminal-block {
    margin: 14px 0 20px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.82rem;
    line-height: 1;
    color: #3e5a82;
  }

  .terminal-block .cmd {
    letter-spacing: 0;
    font-size: 0.95rem;
  }

  @media (max-width: 900px) {
    .signature {
      width: 170px;
      margin-top: 30px;
      margin-left: 36px;
    }
    .signature-motto {
      margin-left: 36px;
    }
  }
</style>

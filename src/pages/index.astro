---
import Layout from '../layouts/Layout.astro';

const selectedSlugs = [
  'designing-under-constraint-autodesk',
  'quickbooks-works-exactly-as-designed',
  'most-software-was-never-designed-to-decide',
  'when-ai-is-wrong-a-simple-operating-model-for-real-world-systems',
  'when-design-ships-it-becomes-policy',
];

const selectedWork = [
  {
    title: 'Designing Decision Governance in Regulated AI Systems',
    href: '/work/wells-fargo',
    company: 'Wells Fargo',
    description:
      'Designed decision-governance workflows that made probabilistic model behavior reviewable, contestable, and accountable inside a high-stakes underwriting environment.',
    tags: ['AI Systems', 'Decision Support', 'Risk'],
  },
  {
    title: 'Designing Human-in-the-Loop Control for AI Automation',
    href: '/work/automation-anywhere',
    company: 'Automation Anywhere',
    description:
      'Led product and systems design for automation workflows where visibility, trust, and operational control determined whether human-in-the-loop AI could be used safely.',
    tags: ['Enterprise AI', 'Observability', 'Complex Systems'],
  },
];

const postModules = import.meta.glob('./writing/*.md', { eager: true });

const selectedPosts = selectedSlugs
  .map((slug) => postModules[`./writing/${slug}.md`])
  .filter(Boolean);
---

<Layout title="Amid the Noise">
  <section class="section hero">
    <p class="hero-quote">I design AI systems that support human judgment under pressure.</p>
      <p class="intro intro-lead">
        <em>Amid the Noise</em> is where I show the systems I’ve built and how they operate when decisions carry real consequences.
      </p>
      <p class="intro">
        I work with product, data, and policy teams to design the layer where model output becomes action, where it can be questioned, overridden, and owned by the person responsible for the outcome.
      </p>
      <p class="intro">
        These systems are used when the answer isn’t certain and the decision still has to be made.
      </p>
  </section>

  <section class="section work-section">
    <h2>Selected Work</h2>

    {selectedWork.map((item) => (
      <article class="entry work-entry">
        <h3>
          <a href={item.href}>{item.title}</a>
        </h3>

        <p class="work-company">{item.company}</p>

        <p>{item.description}</p>

        <div class="entry-tags">
          {item.tags.map((tag) => (
            <span class="entry-tag">{tag}</span>
          ))}
        </div>
      </article>
    ))}
  </section>

  <section class="section">
    <h2>Selected Writing</h2>

    {selectedPosts.map((post) => (
      <article class="entry">
        <h3>
          <a href={post.url}>{post.frontmatter.title}</a>
        </h3>

        <p class="entry-meta">
          {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
            timeZone: 'UTC',
          })}
        </p>

        <p>{post.frontmatter.description}</p>

        {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
          <div class="entry-tags">
            {post.frontmatter.tags.map((tag) => (
              <span class="entry-tag">{tag}</span>
            ))}
          </div>
        )}
      </article>
    ))}
  </section>

  <section class="section books-note">
    <h2>Published Writing</h2>
    <p>
      <a href="/books"><em>Exit Wounds</em></a> extends this body of work into poetry: recovery, toxic attachment, substance use, homelessness, and the cost of naming what survival required.
    </p>
  </section>
</Layout>

<style>

  .hero-quote {
    max-width: 42rem;
    margin: 12px 0 20px;
    padding: 4px 0 12px 16px;
    border-left: 2px solid var(--line);
    font-size: 1.28rem;
    line-height: 1.5;
    font-weight: 500;
    font-style: italic;
    color: var(--title);
  }

  .eyebrow {
    margin: 0 0 12px;
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--secondary);
  }

  .intro.intro-lead {
    max-width: 44rem;
    margin: 0 0 16px;
    font-size: 1.04rem;
    line-height: 1.58;
    font-weight: 500;
    color: var(--text);
  }

  .recruiter-note {
    max-width: 42rem;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text);
    opacity: 0.9;
  }

  .intro {
    max-width: 43rem;
    margin: 0 0 14px;
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--text);
  }

  .signature img {
    max-width: 200px;
  }

  .intro em {
    font-style: italic;
  }

  .intro-strong {
    font-weight: 500;
    color: var(--text);
    opacity: 1;
  }

  .entry-tags {
    margin: 2px 0 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .entry-tag {
    display: inline-block;
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--secondary);
    border: 1px solid var(--line);
    padding: 5px 7px;
    background: transparent;
  }

  h2 {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
    margin: 0 0 22px;
  }

  .entry h3 {
    font-size: 1.15rem;
    line-height: 1.35;
    font-weight: 600;
    margin: 0 0 10px;
  }
  .entry-meta {
    margin: 0 0 8px;
    font-size: 0.78rem;
    line-height: 1.4;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--secondary);
  }

  .work-section {
    margin-top: 8px;
  }

  .work-entry h3 {
    font-size: 1.08rem;
    line-height: 1.32;
    margin: 0 0 10px;
    color: var(--text);
  }

  .work-company {
    margin: 0 0 10px;
    font-size: 0.78rem;
    line-height: 1.4;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--secondary);
  }

  .work-entry p {
    max-width: 46rem;
  }

  .work-entry + .work-entry {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--line);
  }

  .terminal-block {
    margin: 14px 0 20px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.82rem;
    line-height: 1;
    color: #3e5a82;
  }

  .terminal-block .cmd {
    letter-spacing: 0;
    font-size: 0.95rem;
  }
</style>
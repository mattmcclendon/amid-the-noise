---
import Layout from '../layouts/Layout.astro';

const selectedSlugs = [
  'when-ai-is-wrong-a-simple-operating-model-for-real-world-systems',
  'designing-dignity',
  'the-reciprocity-principle-of-emerging-intelligence',
  'before-we-called-it-social',
  'one-degree-of-drift',
];

const selectedWork = [
  {
    title: 'AI-Assisted Mortgage Decisioning',
    href: '/work/wells-fargo',
    meta: 'Wells Fargo · AI decision support · regulated systems',
    description:
      'Designed operator-facing workflows that turned probabilistic model behavior into actionable judgment inside a high-stakes underwriting environment.',
    tags: ['AI Systems', 'Decision Support', 'Risk'],
  },
  {
    title: 'Enterprise Automation and Observability',
    href: '/work/automation-anywhere',
    meta: 'Automation Anywhere · platform design · complex enterprise workflows',
    description:
      'Led product and systems thinking across automation workflows where visibility, trust, and operational clarity mattered as much as interface polish.',
    tags: ['Enterprise AI', 'Observability', 'Complex Systems'],
  },
];

const postModules = import.meta.glob('./writing/*.md', { eager: true });

const selectedPosts = selectedSlugs
  .map((slug) => postModules[`./writing/${slug}.md`])
  .filter(Boolean);
---

<Layout title="Amid the Noise">
  <section class="section hero">
    <p class="eyebrow">Matthew McClendon</p>
    <h1>Designing AI systems where trust, risk,<br />and human judgment matter.</h1>
    <p class="intro intro-lead">
      <em>Amid the Noise</em> is where I write about products and systems that must hold up <em>under pressure</em>. The work here centers on AI, judgment, signal, oversight, and the conditions that make decisions legible.
    </p>
    <p class="intro recruiter-note">
      Relevant to Principal, Staff, and design leadership roles in AI systems, trust and safety, decision infrastructure, and other high-stakes environments.
    </p>
  </section>

  <section class="section">
    <h2>Selected Writing</h2>

    {selectedPosts.map((post) => (
      <article class="entry">
        <h3>
          <a href={post.url}>{post.frontmatter.title}</a>
        </h3>

        <p class="entry-meta">
          {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
          })}
        </p>

        <p>{post.frontmatter.description}</p>

        {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
          <div class="entry-tags">
            {post.frontmatter.tags.map((tag) => (
              <span class="entry-tag">{tag}</span>
            ))}
          </div>
        )}
      </article>
    ))}
  </section>

  <section class="section work-section">
    <h2>Selected Work</h2>

    {selectedWork.map((item) => (
      <article class="entry work-entry">
        <h3>
          <a href={item.href}>{item.title}</a>
        </h3>

        <p class="entry-meta">{item.meta}</p>

        <p>{item.description}</p>

        <div class="entry-tags">
          {item.tags.map((tag) => (
            <span class="entry-tag">{tag}</span>
          ))}
        </div>
      </article>
    ))}
  </section>
</Layout>

<style>

  .hero h1 {
    font-size: 1.68em;
    line-height: 1.22;
    font-weight: 600;
    font-style: italic;
    max-width: 38rem;
  }

  .eyebrow {
    margin: 0 0 12px;
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--secondary);
  }

  .intro-lead {
    max-width: 40rem;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .recruiter-note {
    max-width: 40rem;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--secondary);
  }

  .intro {
    margin: 0 0 10px;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .intro em {
    font-style: italic;
  }

  .entry-tags {
    margin: 2px 0 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .entry-tag {
    display: inline-block;
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--secondary);
    border: 1px solid var(--line);
    padding: 5px 7px;
    background: transparent;
  }

  h2 {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
    margin: 0 0 22px;
  }

  .entry h3 {
    font-size: 1.15rem;
    line-height: 1.35;
    font-weight: 600;
    margin: 0 0 4px;
  }
  .entry-meta {
    margin: 0 0 8px;
    font-size: 0.78rem;
    line-height: 1.4;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  .work-section {
    margin-top: 8px;
  }

  .work-entry h3 {
    font-size: 1.02rem;
    line-height: 1.35;
    margin: 0 0 2px;
    color: var(--text);
  }

  .work-entry .entry-meta {
    font-size: 0.74rem;
    margin: 0 0 10px;
  }

  .work-entry p {
    max-width: 46rem;
  }

  .work-entry + .work-entry {
    margin-top: 26px;
    padding-top: 22px;
    border-top: 1px solid var(--line);
  }
</style>
---
import Layout from '../layouts/Layout.astro';

const selectedSlugs = [
  'when-ai-is-wrong-a-simple-operating-model-for-real-world-systems',
  'quickbooks-decision-engine',
  'when-design-ships-it-becomes-policy',
  'human-compatible-is-not-sufficient',
  'before-we-called-it-social',
];

const selectedWork = [
  {
    title: 'Designing Decision Governance in Regulated AI Systems',
    href: '/work/wells-fargo',
    company: 'Wells Fargo',
    description:
      'Designed operator-facing workflows that turned probabilistic model behavior into actionable judgment inside a high-stakes underwriting environment.',
    tags: ['AI Systems', 'Decision Support', 'Risk'],
  },
  {
    title: 'Designing Human-in-the-Loop Control for AI Automation',
    href: '/work/automation-anywhere',
    company: 'Automation Anywhere',
    description:
      'Led product and systems thinking across automation workflows where visibility, trust, and operational clarity mattered as much as interface polish.',
    tags: ['Enterprise AI', 'Observability', 'Complex Systems'],
  },
];

const postModules = import.meta.glob('./writing/*.md', { eager: true });

const selectedPosts = selectedSlugs
  .map((slug) => postModules[`./writing/${slug}.md`])
  .filter(Boolean);
---

<Layout title="Amid the Noise">
  <section class="section hero">
    <p class="eyebrow">Matthew McClendon</p>
    <h1>I design AI systems that hold up under pressure.</h1>
    <p class="intro intro-lead">
      <em>Amid the Noise</em> is where I write about the systems I build and how they actually behave when it matters.
    </p>
    <p class="intro">
      I design how decisions get made around AI, turning uncertain output into something people can review, override, and act on. I work in systems where mistakes cost money, create risk, or impact people directly, and I define what happens when the model is wrong.
    </p>
  </section>

  <section class="section">
    <h2>Selected Writing</h2>

    {selectedPosts.map((post) => (
      <article class="entry">
        <h3>
          <a href={post.url}>{post.frontmatter.title}</a>
        </h3>

        <p class="entry-meta">
          {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
          })}
        </p>

        <p>{post.frontmatter.description}</p>

        {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
          <div class="entry-tags">
            {post.frontmatter.tags.map((tag) => (
              <span class="entry-tag">{tag}</span>
            ))}
          </div>
        )}
      </article>
    ))}
  </section>

  <section class="section work-section">
    <h2>Selected Work</h2>

    {selectedWork.map((item) => (
      <article class="entry work-entry">
        <h3>
          <a href={item.href}>{item.title}</a>
        </h3>

        <p class="work-company">{item.company}</p>

        <p>{item.description}</p>

        <div class="entry-tags">
          {item.tags.map((tag) => (
            <span class="entry-tag">{tag}</span>
          ))}
        </div>
      </article>
    ))}
  </section>
</Layout>

<style>

  .hero h1 {
    font-size: 1.68em;
    line-height: 1.22;
    font-weight: 600;
    font-style: italic;
    max-width: 42rem;
  }

  .eyebrow {
    margin: 0 0 12px;
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--secondary);
  }

  .intro-lead {
    max-width: 42rem;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text);
  }

  .recruiter-note {
    max-width: 42rem;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text);
    opacity: 0.9;
  }

  .intro {
    margin: 0 0 14px;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text);
  }

  .intro em {
    font-style: italic;
  }

  .intro-strong {
    font-weight: 500;
    color: var(--text);
    opacity: 1;
  }

  .entry-tags {
    margin: 2px 0 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .entry-tag {
    display: inline-block;
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--secondary);
    border: 1px solid var(--line);
    padding: 5px 7px;
    background: transparent;
  }

  h2 {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
    margin: 0 0 22px;
  }

  .entry h3 {
    font-size: 1.15rem;
    line-height: 1.35;
    font-weight: 600;
    margin: 0 0 10px;
  }
  .entry-meta {
    margin: 0 0 8px;
    font-size: 0.78rem;
    line-height: 1.4;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--secondary);
  }

  .work-section {
    margin-top: 8px;
  }

  .work-entry h3 {
    font-size: 1.08rem;
    line-height: 1.32;
    margin: 0 0 10px;
    color: var(--text);
  }

  .work-company {
    margin: 0 0 10px;
    font-size: 0.78rem;
    line-height: 1.4;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--secondary);
  }

  .work-entry p {
    max-width: 46rem;
  }

  .work-entry + .work-entry {
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid var(--line);
  }

  .terminal-block {
    margin: 14px 0 20px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.82rem;
    line-height: 1;
    color: #3e5a82;
  }

  .terminal-block .cmd {
    letter-spacing: 0;
    font-size: 0.95rem;
  }
</style>
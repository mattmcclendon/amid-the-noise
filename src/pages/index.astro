---
import Layout from '../layouts/Layout.astro';
import SectionMoreLink from '../components/SectionMoreLink.astro';

const siteSections = [
  {
    section: 'writing',
    title: 'Writing',
    href: '/writing',
    description:
      'A working archive of essays and reflections on signal, systems, and trust. It studies the structures that shape how we think and act. Start with curated collections or explore the complete archive.',
    links: [
      { label: 'Collections', href: '/writing/collections' },
      { label: 'Archive', href: '/writing/archive' },
    ],
  },
  {
    section: 'research',
    title: 'Research',
    href: '/research',
    description:
      'The space where recurring questions become formal. Papers advance arguments, field studies test them against lived systems, and the bibliography provides the intellectual bedrock. Together they are models for judgment designed for real conditions.',
    links: [
      { label: 'Papers', href: '/research/papers' },
      { label: 'Field Studies', href: '/research/field-studies' },
      { label: 'Bibliography', href: '/research/bibliography' },
    ],
  },
  {
    section: 'lexicon',
    title: 'Lexicon',
    href: '/lexicon',
    description:
      'A collection of precision instruments. Terms, concepts, and frameworks for naming patterns and making invisible structures legible. The shared vocabulary required to discuss the work with clarity.',
    links: [
      { label: 'Terms', href: '/lexicon' },
      { label: 'Concepts', href: '/lexicon' },
      { label: 'Frameworks', href: '/lexicon' },
    ],
  },
  {
    section: 'career',
    title: 'Career',
    href: '/career',
    description:
      'The provenance of the work. A record of the projects, systems, and environments that trained the judgment behind the writing. It maps where the patterns were tested, refined, and formalized.',
    links: [
      { label: 'Case Studies', href: '/career/case-studies' },
      { label: 'Timeline', href: '/career/timeline' },
      { label: 'Learning', href: '/career/learning' },
    ],
  },
];
---

<Layout title="Amid the Noise">
  <section class="section hero">
    <p class="hero-quote">I study the systems people live inside.</p>
    <p class="intro intro-lead">
      That includes technology, institutions, cities, organizations, and the invisible structures that shape belonging, trust, opportunity, and meaning.
    </p>
    <p class="intro">
      Through practice, research, and writing, I explore how complex systems become more understandable, more accountable, and ultimately more humane.
    </p>
    <p class="intro">Thank you for spending time with the work.</p>
    <img class="signature" src="/images/signature-matthew-mcclendon.svg" alt="Matthew McClendon signature" />
    <p class="signature-motto">Anecdotes are where I start. Systems are where we end up.</p>
  </section>

  <section class="section section-index" aria-labelledby="section-index-title">
    <h2 id="section-index-title">Enter the Work</h2>

    <div class="section-list" aria-label="Primary sections">
      {siteSections.map((item) => (
        <article class={`section-card section-card--${item.section}`}>
          <div class="section-card__body">
            <h3>
              <a href={item.href}>{item.title}</a>
            </h3>
            <p>{item.description}</p>

            <nav class="section-card__links" aria-label={`${item.title} destinations`}>
              {item.links.map((link) => (
                <a href={link.href}>{link.label}</a>
              ))}
            </nav>
          </div>

          <SectionMoreLink href={item.href} label={`Enter ${item.title}`} />
        </article>
      ))}
    </div>
  </section>

  <section class="section books-note">
    <h2>Published Writing</h2>
    <p>
      <a href="/books"><em>Exit Wounds</em></a> extends the themes explored throughout <em>Amid the Noise</em> into poetry: recovery, toxic attachment, substance use, homelessness, and the cost of naming what survival required.
    </p>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    padding-bottom: 40px;
  }

  .hero-quote {
    max-width: 40rem;
    margin: 12px 0 20px;
    padding: 4px 0 12px 16px;
    border-left: 2px solid var(--line);
    font-size: 1.28rem;
    line-height: 1.5;
    font-weight: 500;
    font-style: italic;
    color: var(--title);
  }

  .intro.intro-lead {
    max-width: 41rem;
    margin: 0 0 16px;
    font-size: 1.04rem;
    line-height: 1.58;
    font-weight: 500;
    color: var(--text);
  }

  .intro {
    max-width: 41rem;
    margin: 0 0 14px;
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--text);
  }

  .signature {
    display: block;
    width: 200px;
    height: auto;
    margin-top: 24px;
    margin-left: 28px;
    opacity: 0.92;
  }

  .signature-motto {
    margin: 10px 0 0 48px;
    font-family: var(--font-display);
    font-size: 0.91rem;
    font-style: italic;
    font-weight: 600;
    line-height: 1.4;
    color: var(--text);
    opacity: 0.85;
  }

  h2 {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
    margin: 36px 0 36px;
  }

  .section-index {
    margin-top: 8px;
  }

  .section-list {
    display: grid;
    gap: 0;
    max-width: 46rem;
  }

  .section-card {
    position: relative;
    padding: 0 0 28px 16px;
  }

  .section-card + .section-card {
    padding-top: 28px;
    border-top: 1px solid var(--line);
  }

  .section-card::before {
    content: '';
    position: absolute;
    top: 0.1rem;
    left: 0;
    width: 3px;
    height: 56px;
    background: var(--accent-neutral);
  }

  .section-card + .section-card::before {
    top: 28px;
  }

  .section-card--writing::before {
    background: var(--accent-writing);
  }

  .section-card--research::before {
    background: var(--accent-research);
  }

  .section-card--lexicon::before {
    background: var(--accent-lexicon);
  }

  .section-card--career::before {
    background: var(--accent-career);
  }

  .section-card h3 {
    margin: 0 0 10px;
    font-size: 1.16rem;
    line-height: 1.3;
    font-weight: 600;
    color: var(--title);
  }

  .section-card h3 a {
    color: inherit;
    text-decoration: none;
  }

  .section-card h3 a:hover {
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 1px;
  }

  .section-card p {
    max-width: 42rem;
    margin: 0 0 14px;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text);
  }

  .section-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.75rem;
    margin-top: 0.75rem;
    font-size: 0.84rem;
    line-height: 1.4;
  }

  .section-card__links a {
    color: rgba(31, 31, 31, 0.66);
    text-decoration: none;
  }

  .section-card__links a + a::before {
    content: '/';
    margin-right: 0.75rem;
    color: rgba(31, 31, 31, 0.32);
  }

  .section-card__links a:hover {
    color: rgba(31, 31, 31, 0.9);
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 1px;
  }

  .books-note p {
    max-width: 42rem;
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text);
  }

  @media (max-width: 900px) {
    .signature {
      width: 170px;
      margin-top: 30px;
      margin-left: 36px;
    }

    .signature-motto {
      margin-left: 36px;
    }
  }
</style>
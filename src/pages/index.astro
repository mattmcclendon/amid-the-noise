---
import Layout from '../layouts/Layout.astro';

const postModules = import.meta.glob('./writing/*.md', { eager: true });
const posts = Object.values(postModules);

posts.sort((a, b) => {
  return new Date(b.frontmatter.pubDate) - new Date(a.frontmatter.pubDate);
});
---

<Layout title="Writing | Amid the Noise">
  <section class="section">
    <h1>Amid the Noise</h1>
    <p class="intro">
      A body of work focused on how systems shape human experience—where data, policy, and design intersect with trust, signal, and decision-making.
    </p>
    <p class="intro">
      These pieces explore intelligence systems, civic infrastructure, and the patterns that emerge when institutions meet real-world conditions.
    </p>
  </section>

  <section class="section">
    <h2>Latest</h2>

    {posts.map((post) => (
      <article class="entry">
        <h3>
          <a href={post.url}>{post.frontmatter.title}</a>
        </h3>

        <p class="entry-meta">
          {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
          })}
        </p>

        <p>{post.frontmatter.description}</p>

        {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
          <div class="entry-tags">
            {post.frontmatter.tags.map((tag) => (
              <span class="entry-tag">{tag}</span>
            ))}
          </div>
        )}
      </article>
    ))}
  </section>
</Layout>

<style>
  .section h1 {
    margin: 0 0 12px;
    font-size: 1.6rem;
    line-height: 1.25;
    font-weight: 600;
  }

  .intro {
    max-width: 48rem;
    margin: 0 0 12px;
  }

  .entry h3 {
    margin: 0 0 8px;
    font-size: 1.28rem;
    line-height: 1.28;
    font-weight: 600;
  }

  .entry-meta {
    margin: 0 0 12px;
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--secondary);
  }

  .entry p {
    margin: 0 0 12px;
  }

  .entry-tags {
    margin: 2px 0 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .entry-tag {
    display: inline-block;
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--secondary);
    border: 1px solid var(--line);
    padding: 5px 7px;
    background: transparent;
  }
</style>
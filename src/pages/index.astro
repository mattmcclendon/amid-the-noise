---
import Layout from '../layouts/Layout.astro';

const selectedSlugs = [
  'when-ai-is-wrong-a-simple-operating-model-for-real-world-systems',
  'one-degree-of-drift',
  'before-we-called-it-social',
  'designing-dignity',
  'the-reciprocity-principle-of-emerging-intelligence',
];

const postModules = import.meta.glob('./writing/*.md', { eager: true });
const allPosts = Object.values(postModules);

const selectedPosts = selectedSlugs
  .map((slug) =>
    allPosts.find((post) => {
      const postSlug = post.url?.split('/').filter(Boolean).pop();
      return postSlug === slug;
    })
  )
  .filter(Boolean);
---

<Layout title="Amid the Noise">
  <section class="section hero">
    <p class="eyebrow">Matthew McClendon</p>
    <h1>Designing AI systems where trust, risk, and human judgment matter.</h1>
    <p class="intro intro-lead">
      <em>Amid the Noise</em> is where I write about products and systems that must hold up <em>under pressure</em>. The work here centers on AI, judgment, signal, oversight, and the conditions that make decisions legible.
    </p>
    <p class="intro recruiter-note">
      Relevant to Principal, Staff, and design leadership roles in AI systems, trust and safety, decision infrastructure, and other high-stakes environments.
    </p>
  </section>

  <section class="section">
    <h2>Selected Writing</h2>

    {selectedPosts.map((post) => (
      <article class="entry">
        <h3>
          <a href={post.url}>{post.frontmatter.title}</a>
        </h3>

        <p class="entry-meta">
          {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
          })}
        </p>

        <p>{post.frontmatter.description}</p>

        {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
          <div class="entry-tags">
            {post.frontmatter.tags.map((tag) => (
              <span class="entry-tag">{tag}</span>
            ))}
          </div>
        )}
      </article>
    ))}
  </section>
</Layout>

<style>

  .hero h1 {
    font-size: 1.6rem;
    line-height: 1.32;
    font-weight: 600;
    font-style: italic;
    max-width: 38rem;
  }

  .eyebrow {
    margin: 0 0 12px;
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--secondary);
  }

  .intro-lead {
    max-width: 40rem;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .recruiter-note {
    max-width: 40rem;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--secondary);
  }

  .intro {
    margin: 0 0 10px;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .intro em {
    font-style: italic;
  }

  .entry-tags {
    margin: 2px 0 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .entry-tag {
    display: inline-block;
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--secondary);
    border: 1px solid var(--line);
    padding: 5px 7px;
    background: transparent;
  }

  h2 {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
    margin: 0 0 14px;
  }

  .entry h3 {
    font-size: 1.15rem;
    line-height: 1.35;
    font-weight: 600;
    margin: 0 0 4px;
  }
</style>
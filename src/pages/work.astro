---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Work | Amid the Noise">
  <section class="section">
    <article>
      <h1>Work</h1>
      <p>
        Selected case studies across AI, enterprise systems, automation, and regulated environments.
        Each entry focuses on problem framing, design decisions, constraints, and operational outcomes.
        This work reflects a 30-year career building systems where clarity, trust, and decision-making matter.
      </p>
    </article>
  </section>

  <section class="section work-list">
    <h2>Recent Work</h2>

    <article class="work-entry">
      <h3>Dremio</h3>
      <p>Designing decision clarity in distributed data systems.</p>
      <p><a href="/work/dremio">Read case study →</a></p>
    </article>

    <article class="work-entry">
      <h3>Automation Anywhere</h3>
      <p>Designing decision control in AI automation systems.</p>
      <p><a href="/work/automation-anywhere">Read case study →</a></p>
    </article>

    <article class="work-entry">
      <h3>Wells Fargo</h3>
      <p>Designing decision governance in regulated AI systems.</p>
      <p><a href="/work/wells-fargo">Read case study →</a></p>
    </article>

    <article class="work-entry">
      <h3>CA Technologies</h3>
      <p>Guiding early-stage enterprise systems from concept to scale.</p>
      <p><em>Case study forthcoming</em></p>
    </article>

    <h2>Foundations</h2>

    <article class="work-entry">
      <h3>Selected Systems Work</h3>
      <p>Designing large-scale consumer and enterprise systems across web, data, and social platforms.</p>
      <p><em>Case study forthcoming</em></p>
    </article>
  </section>
</Layout>

<style>
  .work-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .work-entry {
    padding: 1.1rem 0 1.25rem;
    border-top: 1px solid var(--border-color, #e5e7eb);
  }

  .work-list h2 + .work-entry {
    margin-top: 0.25rem;
  }

  .work-entry h3 {
    margin-bottom: 0.35rem;
  }

  .work-entry p {
    margin: 0.3rem 0;
  }
</style>
---
import Layout from '../../../layouts/Layout.astro';
import PublicationRow from '../../../components/PublicationRow.astro';
import SectionPage from '../../../components/SectionPage.astro';

import { tagMetadata } from '../../../data/tagMetadata';

export const prerender = true;

const postModules = import.meta.glob('../*.md', { eager: true });

function slugifyTag(tag: string) {
  return tag
    .toLowerCase()
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

function titleCaseTag(tag: string) {
  return tag
    .split('-')
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
}

function getPosts() {
  return Object.entries(postModules)
    .map(([path, module]) => {
      const mod = module as {
        frontmatter?: {
          title?: string;
          description?: string;
          pubDate?: Date | string;
          date?: Date | string;
          tags?: string[];
          draft?: boolean;
        };
      };

      const frontmatter = mod.frontmatter ?? {};
      const slug = path.replace('../', '').replace('.md', '');

      return {
        slug,
        title: frontmatter.title ?? slug,
        description: frontmatter.description ?? '',
        pubDate: frontmatter.pubDate ?? frontmatter.date ?? null,
        tags: frontmatter.tags ?? [],
        draft: frontmatter.draft ?? false,
      };
    })
    .filter((post) => !post.draft)
    .sort((a, b) => {
      const dateA = a.pubDate ? new Date(a.pubDate).getTime() : 0;
      const dateB = b.pubDate ? new Date(b.pubDate).getTime() : 0;
      return dateB - dateA;
    });
}

export function getStaticPaths() {
  const pathPostModules = import.meta.glob('../*.md', { eager: true });

  const pathSlugifyTag = (tag: string) =>
    tag
      .toLowerCase()
      .replace(/&/g, 'and')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-|-$/g, '');

  const tagMap = new Map<string, string>();

  Object.values(pathPostModules).forEach((module) => {
    const mod = module as {
      frontmatter?: {
        tags?: string[];
        draft?: boolean;
      };
    };

    const frontmatter = mod.frontmatter ?? {};
    if (frontmatter.draft) return;

    (frontmatter.tags ?? []).forEach((tag) => {
      const tagSlug = pathSlugifyTag(tag);
      if (!tagMap.has(tagSlug)) {
        tagMap.set(tagSlug, tag);
      }
    });
  });

  return Array.from(tagMap.entries()).map(([tagSlug, label]) => ({
    params: { tag: tagSlug },
    props: { label },
  }));
}

const { tag } = Astro.params;
const { label } = Astro.props;
const posts = getPosts();

const tagSlug = tag ?? '';
const metadata = tagMetadata[tagSlug];

const tagLabel = metadata?.title ?? label ?? titleCaseTag(tagSlug);

const taggedPosts = posts.filter((post) =>
  post.tags.some((postTag) => slugifyTag(postTag) === tagSlug)
);

const pageTitle = `${tagLabel} | Writing | Amid the Noise`;
const pageDescription = `Writing tagged ${tagLabel} from Amid the Noise.`;
// const sectionIntro = `${tagLabel} is a recurring thread across Amid the Noise. This page gathers essays and reflections where the concept appears, develops, or helps frame the work.`;
const sectionIntro =
  metadata?.description ??
  `${tagLabel} gathers writing from across Amid the Noise.`;

const formatDate = (date: Date | string | null) => {
  if (!date) return '';

  return new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  }).format(new Date(date));
};
---

<Layout title={pageTitle} description={pageDescription}>
  <SectionPage section="writing" title={tagLabel} intro={sectionIntro} showHeader={false}>
    <section class="tag-section" aria-labelledby="tag-title">
      <div class="tag-meta">
        {taggedPosts.length} {taggedPosts.length === 1 ? 'post' : 'posts'}
      </div>

      <!-- Removed <h2 id="tag-title">Writing Tagged {tagLabel}</h2> -->

      <div class="writing-list" aria-label={`Writing tagged ${tagLabel}`}>
        {taggedPosts.map((post) => (
          <PublicationRow
            href={`/writing/${post.slug}`}
            title={post.title}
            date={formatDate(post.pubDate)}
            datetime={post.pubDate ? new Date(post.pubDate).toISOString() : undefined}
            description={post.description}
            tags={post.tags.slice(0, 4)}
            tagsAsLinks={true}
            accent="var(--accent-writing)"
          />
        ))}
      </div>

      <nav class="tag-nav" aria-label="Tag navigation">
        <a href="/writing">Writing</a>
        <a href="/writing/archive">Full archive →</a>
      </nav>
    </section>
  </SectionPage>
</Layout>

<style>
  .tag-section {
    margin-top: 3rem;
    margin-bottom: 2rem;
  }

  .tag-meta {
    margin: -3.0rem 0 1rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(31,31,31,.72);
  }

  /* Removed .tag-section h2 { ... } */

  .writing-list {
    display: grid;
    gap: 0;
    margin-top: 1rem;
  }

  .tag-nav {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1.25rem;
    margin-top: 2rem;
    padding-top: 0.9rem;
    border-top: 1px solid rgba(31, 31, 31, 0.12);
  }

  .tag-nav a {
    color: var(--link, #3f5f8f);
    font-family: inherit;
    font-size: 0.86rem;
    line-height: 1.4;
    text-decoration: none;
  }

  .tag-nav a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 1px;
  }

  @media (max-width: 820px) {
  }
</style>

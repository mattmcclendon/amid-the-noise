---
import Layout from '../../layouts/Layout.astro';
import SectionPage from '../../components/SectionPage.astro';
import { writingCollections } from '../../data/writingCollections';

const title = 'Writing | Amid the Noise';
const description = 'Essays, reflections, and systems writing by Matthew McClendon.';
const sectionIntro = 'A working archive of essays and reflections on signal, systems, and trust. It studies the structures that shape how we think and act. Start with curated collections or explore the complete archive.';

const postModules = import.meta.glob('./*.md', { eager: true });

const posts = Object.entries(postModules)
  .map(([path, module]) => {
    const mod = module as {
      frontmatter?: {
        title?: string;
        description?: string;
        pubDate?: Date | string;
        date?: Date | string;
        tags?: string[];
        draft?: boolean;
      };
    };

    const frontmatter = mod.frontmatter ?? {};
    const slug = path.replace('./', '').replace('.md', '');

    return {
      slug,
      title: frontmatter.title ?? slug,
      description: frontmatter.description ?? '',
      pubDate: frontmatter.pubDate ?? frontmatter.date ?? null,
      tags: frontmatter.tags ?? [],
      draft: frontmatter.draft ?? false,
    };
  })
  .sort((a, b) => {
    const dateA = a.pubDate ? new Date(a.pubDate).getTime() : 0;
    const dateB = b.pubDate ? new Date(b.pubDate).getTime() : 0;
    return dateB - dateA;
  });

const publishedPosts = posts.filter((post) => {
  if (post.draft) return false;
  if (!post.pubDate) return true;
  return new Date(post.pubDate).getTime() <= Date.now();
});

const coreWritingSlugs = [
  'the-lineage-of-signal',
  'truth-structured',
  'the-system-decides-first',
  'reclaiming-signal',
  'from-signal-to-decision',
];

const coreWritingPosts = coreWritingSlugs
  .map((slug) => publishedPosts.find((post) => post.slug === slug))
  .filter(Boolean);

const formatDate = (date: Date | string | null) => {
  if (!date) return '';

  return new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  }).format(new Date(date));
};
---

<Layout title={title} description={description}>
  <SectionPage
    section="writing"
    title="Writing"
    intro={sectionIntro}
    sectionNav={[
      { label: 'Overview', href: '/writing' },
      { label: 'Collections', href: '/writing/collections' },
      { label: 'Archive', href: '/writing/archive' },
    ]}
  >

    <section class="writing-start" id="core-writing" aria-labelledby="core-title">
      <h2 id="core-title">Core Writing</h2>
      <p>
        The pieces that define the central operating model behind the archive: how systems behave,
        how signal degrades, and how trust survives contact with reality.
      </p>

      <div class="writing-list" aria-label="Core writing">
        {coreWritingPosts.map((post) => (
          <article class="writing-row">
            <a href={`/writing/${post.slug}`}>
              <div>
                <h3>{post.title}</h3>
                <time datetime={post.pubDate ? new Date(post.pubDate).toISOString() : undefined}>
                  {formatDate(post.pubDate)}
                </time>
                {post.description && <p>{post.description}</p>}
              </div>
              {post.tags.length > 0 && (
                <ul class="writing-tags" aria-label="Tags">
                  {post.tags.slice(0, 4).map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              )}
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="collections-section" id="collections" aria-labelledby="collections-title">
      <h2 id="collections-title">Collections</h2>

      <div class="collection-grid" aria-label="Writing collections">
        {writingCollections.map((collection) => (
          <article class="collection-card">
            <a href={`/writing/collections/${collection.slug}`}>
              <h3>{collection.title}</h3>
              <p>{collection.description}</p>
              <span>read more →</span>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="recent-writing" aria-labelledby="recent-title">
      <h2 id="recent-title">Recent Writing</h2>

      <div class="writing-list" aria-label="Recent writing">
        {publishedPosts.slice(0, 5).map((post) => (
          <article class="writing-row">
            <a href={`/writing/${post.slug}`}>
              <div>
                <h3>{post.title}</h3>
                <time datetime={post.pubDate ? new Date(post.pubDate).toISOString() : undefined}>
                  {formatDate(post.pubDate)}
                </time>
                {post.description && <p>{post.description}</p>}
              </div>
              {post.tags.length > 0 && (
                <ul class="writing-tags" aria-label="Tags">
                  {post.tags.slice(0, 4).map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              )}
            </a>
          </article>
        ))}
      </div>
    </section>
  </SectionPage>
</Layout>

<style>
  .writing-entrypoints {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .writing-entrypoints .entrypoint-card {
    position: relative;
    display: block;
    min-height: 6.25rem;
    border: 1px solid rgba(31, 31, 31, 0.14);
    padding: 0.95rem 1.1rem 1.05rem;
    color: inherit;
    text-decoration: none;
    background: rgba(248, 247, 244, 0.42);
    box-sizing: border-box;
    box-shadow: none;
    transition: border-color 160ms ease, background-color 160ms ease, transform 160ms ease;
  }

  .writing-entrypoints h2 {
    margin: 0 0 0.55rem;
    font-size: 0.88rem;
    letter-spacing: 0.11em;
    line-height: 1.2;
    font-weight: 600;
    text-transform: uppercase;
  }

  .writing-entrypoints p {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.4;
    font-family: Inter, system-ui, sans-serif;
    color: rgba(31, 31, 31, 0.78);
  }

  .writing-entrypoints .entrypoint-card:hover {
    border-color: rgba(143, 65, 118, 0.42);
    background: rgba(248, 247, 244, 0.72);
    transform: translateY(-1px);
  }

  .writing-start,
  .collections-section,
  .recent-writing {
    margin-top: 3rem;
  }

  .recent-writing {
    margin-bottom: 2rem;
  }

  .writing-start p,
  .collections-section > p {
    max-width: 44rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.96rem;
    line-height: 1.6;
    color: rgba(31, 31, 31, 0.82);
  }

  .writing-start h2,
  .collections-section h2,
  .recent-writing h2 {
    margin: 0 0 1.25rem;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-transform: uppercase;
    color: rgba(31, 31, 31, 0.72);
  }

  .writing-list {
    display: grid;
    gap: 0;
    margin-top: 1rem;
  }

  .writing-row + .writing-row {
    border-top: 1px solid rgba(31, 31, 31, 0.14);
  }

  .writing-row a {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.35rem;
    padding: 1.65rem 0 1.75rem 1rem;
    color: inherit;
    text-decoration: none;
  }

  .writing-row a::before {
    content: '';
    position: absolute;
    top: 1.45rem;
    left: 0;
    width: 3px;
    height: 60px;
    background: var(--section-accent);
  }

  .writing-row time {
    display: block;
    margin: 0 0 0.65rem;
    font-size: 0.82rem;
    color: rgba(31, 31, 31, 0.62);
  }

  .writing-row h3 {
    margin: 0 0 0.35rem;
    font-size: clamp(1.02rem, 1.45vw, 1.18rem);
    line-height: 1.18;
    letter-spacing: -0.014em;
    font-weight: 700;
  }

  .writing-row p {
    margin: 0 0 0.75rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.92rem;
    line-height: 1.5;
    color: rgba(31, 31, 31, 0.82);
  }

  .writing-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .writing-tags li {
    border: 1px solid rgba(31, 31, 31, 0.14);
    padding: 0.16rem 0.45rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(31, 31, 31, 0.72);
    background: rgba(248, 247, 244, 0.4);
  }

  .writing-row a:hover h3 {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 1px;
  }

  .collection-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .collection-card {
    border: 1px solid rgba(31, 31, 31, 0.14);
    background: rgba(248, 247, 244, 0.42);
    transition: border-color 160ms ease, background-color 160ms ease, transform 160ms ease;
  }

  .collection-card a {
    display: block;
    padding: 1.05rem 1.15rem 1.1rem;
    color: inherit;
    text-decoration: none;
  }

  .collection-card h3 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.02rem, 1.35vw, 1.16rem);
    line-height: 1.18;
    letter-spacing: -0.01em;
    font-weight: 700;
  }

  .collection-card p {
    margin: 0 0 0.85rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.92rem;
    line-height: 1.5;
    color: rgba(31, 31, 31, 0.82);
  }

  .collection-card span {
    display: flex;
    justify-content: flex-end;
    font-family: inherit;
    font-size: 0.86rem;
    line-height: 1.4;
    color: var(--link, #3f5f8f);
  }

  .collection-card:hover {
    border-color: rgba(143, 65, 118, 0.42);
    background: rgba(248, 247, 244, 0.72);
    transform: translateY(-1px);
  }

  .collection-card a:hover h3,
  .collection-card a:hover span {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 1px;
  }

  @media (max-width: 820px) {
    .writing-entrypoints,
    .collection-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
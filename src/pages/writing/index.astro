---
import Layout from '../../layouts/Layout.astro';
import PublicationRow from '../../components/PublicationRow.astro';
import SectionPage from '../../components/SectionPage.astro';
import SectionMoreLink from '../../components/SectionMoreLink.astro';

interface WritingPost {
  slug: string;
  title: string;
  description: string;
  pubDate: Date | string | null;
  tags: string[];
  draft: boolean;
}

const title = 'Writing | Amid the Noise';
const description = 'Essays, reflections, and systems writing by Matthew McClendon.';
const postModules = import.meta.glob('./*.md', { eager: true });

const posts: WritingPost[] = Object.entries(postModules)
  .map(([path, module]) => {
    const mod = module as {
      frontmatter?: {
        title?: string;
        description?: string;
        pubDate?: Date | string;
        date?: Date | string;
        tags?: string[];
        draft?: boolean;
      };
    };
    const frontmatter = mod.frontmatter ?? {};
    const slug = path.replace('./', '').replace('.md', '');

    return {
      slug,
      title: frontmatter.title ?? slug,
      description: frontmatter.description ?? '',
      pubDate: frontmatter.pubDate ?? frontmatter.date ?? null,
      tags: frontmatter.tags ?? [],
      draft: frontmatter.draft ?? false,
    };
  })
  .sort((a, b) => {
    const dateA = a.pubDate ? new Date(a.pubDate).getTime() : 0;
    const dateB = b.pubDate ? new Date(b.pubDate).getTime() : 0;
    return dateB - dateA;
  });

const publishedPosts = posts.filter((post) => {
  if (post.draft) return false;
  if (!post.pubDate) return true;
  return new Date(post.pubDate).getTime() <= Date.now();
});

const coreWritingSlugs = [
  'the-lineage-of-signal',
  'truth-structured',
  'the-system-decides-first',
  'reclaiming-signal',
  'from-signal-to-decision',
];

const coreWritingPosts = coreWritingSlugs
  .map((slug) => publishedPosts.find((post) => post.slug === slug))
  .filter((post): post is WritingPost => Boolean(post));

const slugifyTag = (tag: string) =>
  tag
    .toLowerCase()
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');

const tagCounts = new Map<string, number>();
for (const post of publishedPosts) {
  for (const tag of post.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const discoveryTags = [...tagCounts.entries()]
  .filter(([, count]) => count >= 3)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 16);

const formatDate = (date: Date | string | null) => {
  if (!date) return '';
  return new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(new Date(date));
};
---

<Layout title={title} description={description}>
  <SectionPage
    section="writing"
    title="Writing"
  >
    <Fragment slot="intro">
      A working library of essays, <a href="/writing/field-studies">field studies</a>, and <a href="/writing/papers">papers</a> on signal, systems, trust, and the structures that shape how we think and act. A <a href="/writing/archive">full archive</a> is also available.
    </Fragment>

    <section class="writing-section" aria-labelledby="core-title">
      <h2 id="core-title">Start Here</h2>
      <p class="section-intro">Five pieces that establish the library’s central operating model: how systems behave, how signal degrades, and how trust survives contact with reality.</p>
      <div class="writing-list" aria-label="Start here">
        {coreWritingPosts.map((post) => (
          <PublicationRow
            href={`/writing/${post.slug}`}
            title={post.title}
            date={formatDate(post.pubDate)}
            datetime={post.pubDate ? new Date(post.pubDate).toISOString() : undefined}
            description={post.description}
            tags={post.tags.slice(0, 4)}
            tagsAsLinks={true}
            accent="var(--accent-writing)"
          />
        ))}
      </div>
    </section>

    <section class="writing-section papers-shelf" aria-labelledby="papers-title">
      <h2 id="papers-title">Papers</h2>
      <p class="section-intro">Longer-form arguments, frameworks, and downloadable research on systems, governance, human judgment, and artificial intelligence.</p>
      <SectionMoreLink href="/writing/papers" label="See all papers" />
    </section>

    <section class="writing-section field-studies-shelf" aria-labelledby="field-studies-title">
      <h2 id="field-studies-title">Field Studies</h2>
      <p class="section-intro">Direct observations from enterprise, civic, technical, and cultural systems where theory meets lived operational conditions.</p>
      <SectionMoreLink href="/writing/field-studies" label="See all field studies" />
    </section>

    <section class="writing-section" aria-labelledby="subjects-title">
      <h2 id="subjects-title">Browse by Subject</h2>
      <ul class="subject-list">
        {discoveryTags.map(([tag, count]) => (
          <li>
            <a href={`/writing/tag/${slugifyTag(tag)}`}>
              <span>{tag}</span>
              <span class="subject-count">{count}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="writing-section recent-writing" aria-labelledby="recent-title">
      <h2 id="recent-title">Recent Writing</h2>
      <div class="writing-list" aria-label="Recent writing">
        {publishedPosts.slice(0, 8).map((post) => (
          <PublicationRow
            href={`/writing/${post.slug}`}
            title={post.title}
            date={formatDate(post.pubDate)}
            datetime={post.pubDate ? new Date(post.pubDate).toISOString() : undefined}
            description={post.description}
            tags={post.tags.slice(0, 4)}
            tagsAsLinks={true}
            accent="var(--accent-writing)"
          />
        ))}
      </div>
      <p class="archive-link"><a href="/writing/archive">View the complete archive →</a></p>
    </section>
  </SectionPage>
</Layout>

<style>
  .writing-section {
    margin-top: 3rem;
  }

  .writing-section h2 {
    margin: 0 0 1.25rem;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-transform: uppercase;
    color: rgba(31, 31, 31, 0.72);
  }

  .section-intro {
    max-width: 44rem;
    margin: 0 0 1rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.96rem;
    line-height: 1.6;
    color: rgba(31, 31, 31, 0.82);
  }

  .writing-list {
    display: grid;
  }

  .subject-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--line);
    list-style: none;
  }

  .subject-list li {
    border-bottom: 1px solid var(--line);
  }

  .subject-list li:nth-child(odd) {
    padding-right: 1rem;
  }

  .subject-list li:nth-child(even) {
    padding-left: 1rem;
  }

  .subject-list a {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 0;
    color: var(--text);
    font-size: 0.9rem;
    line-height: 1.35;
    text-decoration: none;
  }

  .subject-list a:hover span:first-child,
  .subject-list a:focus-visible span:first-child {
    color: var(--accent-writing);
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  .subject-count {
    color: var(--secondary);
    font-size: 0.8rem;
  }

  .recent-writing {
    margin-bottom: 2rem;
  }

  .archive-link {
    margin: 1.5rem 0 0;
    text-align: right;
    font-size: 0.92rem;
  }

  .archive-link a {
    text-decoration: none;
  }

  .archive-link a:hover,
  .archive-link a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 1px;
  }

  @media (max-width: 620px) {
    .subject-list {
      grid-template-columns: 1fr;
    }

    .subject-list li:nth-child(n) {
      padding: 0;
    }
  }
</style>

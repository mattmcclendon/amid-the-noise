---
import Layout from '../../layouts/Layout.astro';
import SectionPage from '../../components/SectionPage.astro';

const title = 'Writing | Amid the Noise';
const description = 'Essays, reflections, and systems writing by Matthew McClendon.';
const sectionIntro = 'Writing is where observations become arguments. Each essay begins with something immediate: a place, a conversation, a design problem, a civic failure, or a moment that refuses to leave. From there, the work asks what larger structures made that moment possible.';

const postModules = import.meta.glob('./*.md', { eager: true });

const posts = Object.entries(postModules)
  .map(([path, module]) => {
    const mod = module as {
      frontmatter?: {
        title?: string;
        description?: string;
        pubDate?: Date | string;
        date?: Date | string;
        tags?: string[];
        draft?: boolean;
      };
    };

    const frontmatter = mod.frontmatter ?? {};
    const slug = path.replace('./', '').replace('.md', '');

    return {
      slug,
      title: frontmatter.title ?? slug,
      description: frontmatter.description ?? '',
      pubDate: frontmatter.pubDate ?? frontmatter.date ?? null,
      tags: frontmatter.tags ?? [],
      draft: frontmatter.draft ?? false,
    };
  })
  .filter((post) => !post.draft)
  .sort((a, b) => {
    const dateA = a.pubDate ? new Date(a.pubDate).getTime() : 0;
    const dateB = b.pubDate ? new Date(b.pubDate).getTime() : 0;
    return dateB - dateA;
  });

const formatDate = (date: Date | string | null) => {
  if (!date) return '';

  return new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  }).format(new Date(date));
};
---

<Layout title={title} description={description}>
  <SectionPage section="writing" title="Writing" intro={sectionIntro} showHeader={false}>

    <section class="recent-writing" aria-labelledby="recent-title">
      <h2 id="recent-title">Selected Writing</h2>

      <div class="writing-list" aria-label="Recent writing">
        {posts.slice(0, 10).map((post) => (
          <article class="writing-row">
            <a href={`/writing/${post.slug}`}>
              <div>
                <h3>{post.title}</h3>
                <time datetime={post.pubDate ? new Date(post.pubDate).toISOString() : undefined}>
                  {formatDate(post.pubDate)}
                </time>
                {post.description && <p>{post.description}</p>}
              </div>
              {post.tags.length > 0 && (
                <ul class="writing-tags" aria-label="Tags">
                  {post.tags.slice(0, 4).map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              )}
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="writing-destinations" aria-labelledby="destinations-title">
      <h2 id="destinations-title">Writing Archive</h2>

      <div class="destination-list" aria-label="Writing destinations">
        <article class="destination-row">
          <a href="/writing/archive">
            <div>
              <h3>Full Archive</h3>
              <p>
                Browse the complete Amid the Noise writing archive: essays, reflections,
                arguments, fragments, field observations, and ideas that sharpen over time.
              </p>
            </div>
          </a>
        </article>

        <article class="destination-row">
          <a href="/writing/books">
            <div>
              <h3>Books</h3>
              <p>
                Published and forthcoming books connected to the broader Amid the Noise body of work.
              </p>
            </div>
          </a>
        </article>
      </div>
    </section>
  </SectionPage>
</Layout>

<style>
  .recent-writing {
    margin-top: 3rem;
    margin-bottom: 2rem;
  }

  .writing-destinations {
    margin-top: 3rem;
  }

  .recent-writing h2,
  .writing-destinations h2 {
    margin: 0 0 1.25rem;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--section-accent);
  }

  .writing-list {
    display: grid;
    gap: 0;
    margin-top: 1rem;
  }

  .destination-list {
    display: grid;
    gap: 0;
    margin-top: 1rem;
  }

  .writing-destinations {
    border: 0;
    background: transparent;
    padding: 0;
  }

  .destination-row {
    border-left: 0;
    background: transparent;
  }

  .writing-row + .writing-row,
  .destination-row + .destination-row {
    border-top: 1px solid rgba(31, 31, 31, 0.14);
  }

  .writing-row a,
  .destination-row a {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.35rem;
    padding: 1.65rem 0 1.75rem 1rem;
    color: inherit;
    text-decoration: none;
  }

  .writing-row a::before {
    content: '';
    position: absolute;
    top: 1.45rem;
    left: 0;
    width: 3px;
    height: 56px;
    background: var(--section-accent);
  }

  .destination-row a::before {
    content: none;
  }

  .writing-row time {
    display: block;
    margin: 0 0 0.65rem;
    font-size: 0.82rem;
    color: rgba(31, 31, 31, 0.62);
  }

  .writing-row h3,
  .destination-row h3 {
    margin: 0 0 0.35rem;
    font-size: clamp(1.08rem, 1.7vw, 1.28rem);
    line-height: 1.18;
    letter-spacing: -0.014em;
    font-weight: 700;
  }

  .writing-row p,
  .destination-row p {
    margin: 0 0 0.75rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.92rem;
    line-height: 1.5;
    color: rgba(31, 31, 31, 0.82);
  }

  .writing-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .writing-tags li {
    border: 1px solid rgba(31, 31, 31, 0.14);
    padding: 0.16rem 0.45rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(31, 31, 31, 0.72);
    background: rgba(248, 247, 244, 0.4);
  }

  .writing-row a:hover h3,
  .destination-row a:hover h3 {
    color: var(--section-accent);
  }

  @media (max-width: 820px) {
  }
</style>
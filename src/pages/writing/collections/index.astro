---
import Layout from '../../../layouts/Layout.astro';
import SectionPage from '../../../components/SectionPage.astro';
import ContentRow from '../../../components/ContentRow.astro';
import { writingCollections } from '../../../data/writingCollections';
import ArchiveImageModule from '../../../components/ArchiveImageModule.astro';

const title = 'Collections | Writing | Amid the Noise';
const description = 'Curated reading paths through Amid the Noise.';
const pageTitle = 'Collections';
const pageIntro = 'Curated reading paths through the archive. Essays organized by argument, recurring concern, and shared pattern rather than chronology.';
---

<Layout title={title} description={description}>
  <SectionPage
    section="writing"
    title={pageTitle}
    intro={pageIntro}
    sectionNav={[
      { label: 'Overview', href: '/writing' },
      { label: 'Collections', href: '/writing/collections' },
      { label: 'Archive', href: '/writing/archive' },
    ]}
  >
    <section class="collections-list" aria-label="Writing collections">
      {writingCollections.map((collection, index) => (
        <>
          <ContentRow
            href={`/writing/collections/${collection.slug}`}
            title={collection.title}
            meta="Collection"
            description={collection.description}
            tags={[]}
          />

          {index === 3 && (
            <div class="collections-image-break">
              <ArchiveImageModule
                src="/images/pages/atn-writing-collections-001.png"
                alt="Archival illustration representing curated reading paths across Amid the Noise."
              />
            </div>
          )}
        </>
      ))}
    </section>
  </SectionPage>
</Layout>

<style>
  .collections-list {
    display: grid;
    gap: 0;
  }
  .collections-image-break {
    margin: -4rem 0 -3rem 0;
  }
</style>
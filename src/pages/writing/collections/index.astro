---
import Layout from '../../../layouts/Layout.astro';
import SectionPage from '../../../components/SectionPage.astro';
import { writingCollections } from '../../../data/writingCollections';

const title = 'Collections | Writing | Amid the Noise';
const description = 'Curated reading paths through Amid the Noise.';
const pageTitle = 'Collections';
const pageIntro = 'Curated reading paths through the archive. Essays organized by argument, recurring concern, and shared pattern rather than chronology.';
---

<Layout title={title} description={description}>
  <SectionPage
    section="writing"
    title={pageTitle}
    intro={pageIntro}
    sectionNav={[
      { label: 'Overview', href: '/writing' },
      { label: 'Collections', href: '/writing/collections' },
      { label: 'Archive', href: '/writing/archive' },
    ]}
  >
    <section class="collections-list" aria-label="Writing collections">
      {writingCollections.map((collection) => (
        <article class="collection-card">
          <a href={`/writing/collections/${collection.slug}`}>
            <h2>{collection.title}</h2>
            <p>{collection.description}</p>
            <span>read more →</span>
          </a>
        </article>
      ))}
    </section>
  </SectionPage>
</Layout>

<style>
  .collections-list {
    display: grid;
    gap: 1rem;
  }

  .collection-card {
    border: 1px solid rgba(31, 31, 31, 0.14);
    background: rgba(248, 247, 244, 0.42);
  }

  .collection-card a {
    display: block;
    padding: 1.05rem 1.15rem 1.1rem;
    color: inherit;
    text-decoration: none;
  }

  .collection-card h2 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.02rem, 1.35vw, 1.16rem);
    line-height: 1.18;
    letter-spacing: -0.01em;
    font-weight: 600;
  }

  .collection-card p {
    max-width: 44rem;
    margin: 0 0 0.85rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.92rem;
    line-height: 1.5;
    color: rgba(31, 31, 31, 0.82);
  }

  .collection-card span {
    display: flex;
    justify-content: flex-end;
    font-size: 0.88rem;
    color: var(--link, #3f5f8f);
  }

  .collection-card a:hover h2,
  .collection-card a:hover span {
    color: var(--section-accent);
  }
</style>
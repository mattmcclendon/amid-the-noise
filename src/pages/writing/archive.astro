---
import Layout from '../../layouts/Layout.astro';
import PublicationRow from '../../components/PublicationRow.astro';
import SectionPage from '../../components/SectionPage.astro';
import {
  getPublishedWritingPosts,
  getTopWritingTags,
  slugifyTag,
} from '../../utils/writing';

const postModules = import.meta.glob('./*.md', { eager: true });
const datedPosts = getPublishedWritingPosts(postModules);
const discoveryTags = getTopWritingTags(datedPosts);

const title = 'Archive | Writing | Amid the Noise';
const pageIntro = 'The complete publication record. Every essay, reflection, and note published since the project’s inception.';
---

<Layout title={title}>
  <SectionPage
    section="writing"
    title="Archive"
    intro={pageIntro}
  >
    <nav class="archive-subjects" aria-label="Browse writing by subject">
      <span>Browse by subject</span>
      <ul>
        {discoveryTags.map(([tag, count]) => (
          <li><a href={`/writing/tag/${slugifyTag(tag)}`}>{tag} <span>{count}</span></a></li>
        ))}
      </ul>
    </nav>

    <section class="archive-list" aria-label="Complete writing archive">
      {datedPosts.map((post) => {
        const timestamp = post.postTime;
        const date = new Date(timestamp);

        return (
          <PublicationRow
            href={`/writing/${post.slug}`}
            title={post.title}
            date={date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
              timeZone: 'UTC',
            })}
            datetime={date.toISOString()}
            description={post.description}
            tags={post.tags}
            tagsAsLinks={true}
            accent="var(--accent-writing)"
          />
        );
      })}
      <p class="archive-count">{datedPosts.length} posts</p>
    </section>
  </SectionPage>
</Layout>

<style>
  .archive-subjects {
    padding: 1rem 0 2rem;
    border-bottom: 1px solid var(--line);
  }

  .archive-subjects > span {
    display: block;
    margin-bottom: .78rem;
    font-size: .86rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  .archive-subjects ul {
    display: flex;
    flex-wrap: wrap;
    column-gap: 0.45rem;
    row-gap: 0.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .archive-subjects a {
    display: inline-flex;
    gap: 0.35rem;
    border: 1px solid var(--line);
    padding: 0.3rem 0.5rem;
    color: var(--secondary);
    font-size: .78rem;
    line-height: 1;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .archive-subjects a span {
    opacity: 0.7;
  }

  .archive-subjects a:hover,
  .archive-subjects a:focus-visible {
    border-color: var(--accent);
    color: var(--accent);
  }

  .archive-list {
    display: grid;
  }

  .archive-count {
    margin: 2.25rem 0 0;
    padding-top: 1.1rem;
    border-top: 1px solid var(--line);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
  }
</style>

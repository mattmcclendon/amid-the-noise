---
import Layout from '../../layouts/Layout.astro';
import PublicationRow from '../../components/PublicationRow.astro';
import SectionPage from '../../components/SectionPage.astro';

const postModules = import.meta.glob('./*.md', { eager: true });

const getPostTime = (value: Date | string | undefined) => {
  const normalizedDate = value instanceof Date
    ? value.toISOString().slice(0, 10)
    : String(value ?? '').trim();

  if (!/^\d{4}-\d{2}-\d{2}$/.test(normalizedDate)) return null;

  const [year, month, day] = normalizedDate.split('-').map(Number);
  const time = Date.UTC(year, month - 1, day);
  const date = new Date(time);

  if (
    date.getUTCFullYear() !== year ||
    date.getUTCMonth() !== month - 1 ||
    date.getUTCDate() !== day
  ) return null;

  return time;
};

const datedPosts = Object.entries(postModules)
  .map(([path, module]) => {
    const mod = module as {
      frontmatter?: {
        title?: string;
        description?: string;
        pubDate?: Date | string;
        date?: Date | string;
        tags?: string[];
        draft?: boolean;
      };
    };
    const frontmatter = mod.frontmatter ?? {};

    return {
      slug: path.replace('./', '').replace('.md', ''),
      title: frontmatter.title ?? '',
      description: frontmatter.description ?? '',
      tags: frontmatter.tags ?? [],
      draft: frontmatter.draft ?? false,
      postTime: getPostTime(frontmatter.pubDate ?? frontmatter.date),
    };
  })
  .filter((post) => !post.draft && post.postTime !== null && post.postTime <= Date.now())
  .sort((a, b) => (b.postTime ?? 0) - (a.postTime ?? 0));

const slugifyTag = (tag: string) =>
  tag
    .toLowerCase()
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');

const tagCounts = new Map<string, number>();
for (const post of datedPosts) {
  for (const tag of post.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const discoveryTags = [...tagCounts.entries()]
  .filter(([, count]) => count >= 3)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 20);

const title = 'Archive | Writing | Amid the Noise';
const pageIntro = 'The complete publication record. Every essay, reflection, and note published since the project’s inception.';
---

<Layout title={title}>
  <SectionPage
    section="writing"
    title="Archive"
    intro={pageIntro}
  >
    <nav class="archive-subjects" aria-label="Browse writing by subject">
      <span>Browse by subject</span>
      <ul>
        {discoveryTags.map(([tag, count]) => (
          <li><a href={`/writing/tag/${slugifyTag(tag)}`}>{tag} <span>{count}</span></a></li>
        ))}
      </ul>
    </nav>

    <section class="archive-list" aria-label="Complete writing archive">
      {datedPosts.map((post) => {
        const timestamp = post.postTime as number;
        const date = new Date(timestamp);

        return (
          <PublicationRow
            href={`/writing/${post.slug}`}
            title={post.title}
            date={date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
              timeZone: 'UTC',
            })}
            datetime={date.toISOString()}
            description={post.description}
            tags={post.tags}
            tagsAsLinks={true}
            accent="var(--accent-writing)"
          />
        );
      })}
      <p class="archive-count">{datedPosts.length} posts</p>
    </section>
  </SectionPage>
</Layout>

<style>
  .archive-subjects {
    padding: 1rem 0 2rem;
    border-bottom: 1px solid var(--line);
  }

  .archive-subjects > span {
    display: block;
    margin-bottom: 0.75rem;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  .archive-subjects ul {
    display: flex;
    flex-wrap: wrap;
    column-gap: 0.45rem;
    row-gap: 0.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .archive-subjects a {
    display: inline-flex;
    gap: 0.35rem;
    border: 1px solid var(--line);
    padding: 0.3rem 0.5rem;
    color: var(--secondary);
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .archive-subjects a span {
    opacity: 0.7;
  }

  .archive-subjects a:hover,
  .archive-subjects a:focus-visible {
    border-color: var(--accent-writing);
    color: var(--accent-writing);
  }

  .archive-list {
    display: grid;
  }

  .archive-count {
    margin: 2.25rem 0 0;
    padding-top: 1.1rem;
    border-top: 1px solid var(--line);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
  }
</style>

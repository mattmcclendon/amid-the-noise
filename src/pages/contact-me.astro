---
import Layout from "../layouts/Layout.astro";
import LinkedInIcon from "../components/icons/linkedin.astro";
import GitHubIcon from "../components/icons/github.astro";
import FacebookIcon from "../components/icons/facebook.astro";
import BehanceIcon from "../components/icons/behance.astro";
import XIcon from "../components/icons/x.astro";
import RSSIcon from "../components/icons/rss.astro";

const title = "Contact Me";
const description = "Contact Matthew McClendon about product design, UX strategy, civic technology, writing, speaking, and consulting inquiries.";
---

<Layout title={title} description={description}>
  <main>
    <section class="section intro-section" data-pagefind-ignore>
      <h1>Contact Me</h1>
      <p>
        For product design, UX strategy, research, civic technology, writing, speaking, or consulting inquiries, email <a href="mailto:hello@amidthenoise.com">hello@amidthenoise.com</a>.
      </p>
    </section>

    <section class="section contact-focus-section" data-pagefind-ignore>
      <div class="section-heading">
        <h2>Current Areas of Focus</h2>
      </div>
      <ul class="contact-focus-list">
        <li>Challenging roles in product design, UX strategy, and AI-native product development</li>
        <li>Research partnerships, systems thinking, and the design of decision-making workflows</li>
        <li>Active participation in civic technology, public-interest infrastructure, and governance challenges</li>
        <li>Collaborative writing, speaking engagements, interviews, and thoughtful conversations</li>
        <li>Collaborating on <a href="https://aureliareach.org" target="_blank" rel="noopener noreferrer">Aurelia Reach</a> thought experiments exploring governance, belonging, trust, education, and life beyond scarcity</li>
        <li>Contributing to <a href="https://usskepler.org" target="_blank" rel="noopener noreferrer">USS Kepler</a> through speculative fiction, archive design, worldbuilding, and narrative systems</li>
      </ul>
    </section>

    <section class="section follow-section" aria-labelledby="follow" data-pagefind-ignore>
      <div class="section-heading">
        <h2 id="follow">Follow</h2>
      </div>

      <nav class="contact-social-links" aria-label="Social links">
        <a href="https://www.linkedin.com/in/matthewmcclendon/" target="_blank" rel="noopener noreferrer">
          <LinkedInIcon />
          <span>LinkedIn (personal)</span>
        </a>
        <a href="https://www.linkedin.com/company/amidthenoise/" target="_blank" rel="noopener noreferrer">
          <LinkedInIcon />
          <span>LinkedIn (Amid the Noise)</span>
        </a>
        <a href="https://www.facebook.com/matt.mcclendon" target="_blank" rel="noopener noreferrer">
          <FacebookIcon />
          <span>Facebook (personal)</span>
        </a>
        <a href="https://www.facebook.com/amidthenoisehq" target="_blank" rel="noopener noreferrer">
          <FacebookIcon />
          <span>Facebook (Amid the Noise)</span>
        </a>
        <a href="https://github.com/matthewmcclendon" target="_blank" rel="noopener noreferrer">
          <GitHubIcon />
          <span>GitHub</span>
        </a>
        <a href="https://www.behance.net/matthewmcclendon" target="_blank" rel="noopener noreferrer">
          <BehanceIcon />
          <span>Behance</span>
        </a>
        <a href="https://x.com/amidthenoise" target="_blank" rel="noopener noreferrer">
          <XIcon />
          <span>X (Amid the Noise)</span>
        </a>
        <a href="/rss.xml">
          <RSSIcon />
          <span>RSS</span>
        </a>
      </nav>
    </section>
  </main>
</Layout>

<style>
  .intro-section {
    margin-bottom: 4.5rem;
  }

  .contact-focus-section :global(.contact-focus-list) {
    margin: 1.25rem 0 0;
    padding-left: 1.2rem;
    list-style: disc outside;
    border: 0;
    font-size: 1rem !important;
    line-height: 1.7 !important;
  }

  .contact-focus-section :global(.contact-focus-list li) {
    display: list-item;
    padding: 0.2rem 0;
    border: 0;
    font-size: 1rem !important;
    line-height: 1.7 !important;
    color: var(--secondary);
  }

  .contact-focus-section :global(.contact-focus-list li::marker) {
    font-size: 0.8rem;
    color: var(--secondary);
  }

  .contact-focus-list a {
    color: inherit;
    text-decoration: none;
  }

  .contact-focus-list a:hover,
  .contact-focus-list a:focus-visible {
    color: var(--accent-plum);
  }

  .contact-focus-section,
  .follow-section {
    margin-top: 4rem;
  }

  .contact-social-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem 1.5rem;
    margin-top: 1.5rem;
  }

  .contact-social-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--secondary);
    font-weight: 400;
    text-decoration: none;
    font-size: 0.95rem !important;
    line-height: 1.7 !important;
  }

  .contact-social-links a span {
    font-size: 0.95rem !important;
    line-height: 1.7 !important;
    font-weight: 400;
  }

  .contact-social-links :global(svg) {
    color: currentColor;
  }

  .contact-social-links :global(svg path),
  .contact-social-links :global(svg circle),
  .contact-social-links :global(svg rect),
  .contact-social-links :global(svg polygon),
  .contact-social-links :global(svg line) {
    fill: currentColor;
    stroke: none;
  }

  .contact-social-links :global(svg) {
    width: 18px !important;
    height: 18px !important;
    min-width: 18px !important;
    min-height: 18px !important;
    flex: 0 0 18px;
    color: currentColor;
  }

  .contact-social-links :global(svg * ) {
    vector-effect: non-scaling-stroke;
  }

  @media (max-width: 700px) {
    .intro-section {
      margin-bottom: 3.5rem;
    }

    .contact-focus-section,
    .follow-section {
      margin-top: 3.25rem;
    }
    .contact-social-links {
      grid-template-columns: 1fr;
    }
  }
</style>
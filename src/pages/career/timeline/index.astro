---
import Layout from '../../../layouts/Layout.astro';
import SectionPage from '../../../components/SectionPage.astro';
import SectionMoreLink from '../../../components/SectionMoreLink.astro';

const title = 'Timeline | Career | Amid the Noise';
const description = 'A chronology of the experiences, decisions, and turning points that shaped the work behind Amid the Noise.';
const sectionIntro = 'A chronology of inflection points. Some happened to me. Others were choices. Together they explain the work more honestly than any résumé could.';

const timelineGroups = [
  {
    label: 'Formation',
    years: '1973–1992',
    items: [
      {
        date: '10/1973',
        title: 'Born in Altus, Oklahoma',
        text: 'The beginning of a life shaped by distance, weather, books, and a persistent curiosity about worlds beyond the one immediately visible.',
        kind: 'formation',
      },
      {
        date: '12/1978',
        title: 'Imagined Futures',
        text: 'Star Trek taught me that technology could be hopeful. December afternoons were spent on the floor flying an Enterprise through a universe of Christmas tree lights and imagination.',
        kind: 'formation',
      },
      {
        date: '06/1990',
        title: 'SWOSU Science & Math Camp',
        text: 'Summer meant college credits, new friendships, and a first taste of belonging among students who treated science and mathematics as shared possibility.',
        kind: 'formation',
      },
      {
        date: '06/1991',
        title: 'The SSC notices',
        text: 'I returned to SWOSU the following summer and was recruited by the Superconducting Super Collider, a recognition of my grasp of science, mathematics, and the future I imagined.',
        kind: 'formation',
      },
      {
        date: '05/1992',
        title: 'Graduated from Altus High School',
        text: 'Physics was the plan. The rest of life had other ideas.',
        kind: 'formation',
      },
      {
        date: '05/1994',
        title: 'Left Oklahoma State University',
        text: 'College did not go as planned. The learning continued anyway.',
        tone: 'life',
        kind: 'inflection',
      },
    ],
  },
  {
    label: 'The Public Internet',
    years: '1996–2008',
    items: [
      {
        date: '05/1996',
        title: 'Founded IXDesign',
        text: 'My first consultancy, created before I fully understood how much independent work would shape the rest of my professional life.',
        tone: 'choice',
        kind: 'inflection',
      },
      {
        date: '10/1996',
        title: 'Bought mattmcc.com & ixdsgn.com',
        text: 'Claimed my first domain, a small act of ownership that made the web feel personal, durable, and mine.',
        tone: 'choice',
        kind: 'inflection',
      },
      {
        date: '09/1997',
        title: 'Netscape',
        href: '/research/field-studies/content/netscape',
        text: 'Entered the commercial web while the public Internet was still being invented in real time.',
        kind: 'field-study',
      },
      {
        date: '09/2001',
        title: 'September 11',
        text: 'First near-death experience. A day that permanently changed my sense of history, vulnerability, and civic consequence.',
        tone: 'near-death',
        kind: 'inflection',
      },
      {
        date: '09/2004',
        title: 'Friendster',
        href: '/research/field-studies/content/friendster',
        text: 'Worked on social networking before social media hardened into infrastructure.',
        kind: 'field-study',
      },
      {
        date: '10/2005',
        title: 'Yahoo!',
        href: '/research/field-studies/content/stanford-improv',
        text: 'Helped shape one of the Internet’s primary front doors at shallow-billion-user scale.',
        kind: 'field-study',
      },
    ],
  },
  {
    label: 'Digital Transformation',
    years: '2009–2016',
    items: [
      {
        date: '05/2009',
        title: 'LEVEL Studios',
        href: '/research/field-studies/content/level-studios',
        text: 'The hinge from public web products toward enterprise clients, digital transformation, and organizational scale.',
        kind: 'field-study',
      },
      {
        date: '05/2009',
        title: 'Boston takes hold',
        text: 'While embedded with Fidelity Investments through LEVEL Studios, I fell in love with Boston and Massachusetts, adding place itself to the map of future possibility.',
        tone: 'choice',
        kind: 'inflection',
      },
      {
        date: '01/2011',
        title: 'Evernote',
        text: 'Explored memory, capture, and productivity through platform work, including Windows and ecosystem design.',
        kind: 'field-study',
      },
      {
        date: '07/2012',
        title: 'Autodesk',
        text: 'Moved deeper into cloud services, licensing, workflows, and the complexity of professional tools.',
        kind: 'field-study',
      },
      {
        date: '12/2014',
        title: 'Cadence Design Systems',
        text: 'Entered the world of semiconductor design, where software, engineering, and invisible infrastructure converged.',
        kind: 'field-study',
      },
    ],
  },
  {
    label: 'Enterprise Systems',
    years: '2017–2021',
    items: [
      {
        date: '05/2017',
        title: 'Founded Matt McClendon & Co., LLC',
        text: 'Created a formal home for independent consulting, advisory work, and the practice that would eventually feed Amid the Noise.',
        tone: 'choice',
        kind: 'inflection',
      },
      {
        date: '08/2017',
        title: 'CA Technologies',
        text: 'Worked at the scale of enterprise transformation, organizational systems, and executive-level design strategy.',
        kind: 'field-study',
      },
      {
        date: '07/2019',
        title: 'Wells Fargo',
        text: 'Designed within enterprise AI, governance, decision systems, and the friction of large institutions.',
        kind: 'field-study',
      },
      {
        date: '11/2019',
        title: 'Gino is born',
        text: 'A new life entered the world, and the shape of responsibility began to change.',
        tone: 'life',
        kind: 'inflection',
      },
      {
        date: '01/2020',
        title: 'Automation Anywhere',
        text: 'Worked inside intelligent automation as AI began changing how organizations imagined work.',
        kind: 'field-study',
      },
      {
        date: '03/2020',
        title: 'The world enters lockdown',
        text: 'COVID turned abstraction into atmosphere, revealing how fragile institutions, routines, work, proximity, and ordinary life could become all at once.',
        tone: 'life',
        kind: 'inflection',
      },
      {
        date: '06/2020',
        title: 'My father dies',
        text: 'His death from prostate cancer marked another before-and-after, reshaping memory, inheritance, grief, and the unfinished conversations parents leave behind.',
        tone: 'life',
        kind: 'inflection',
      },
      {
        date: '01/2021',
        title: 'Dremio',
        text: 'Moved into data infrastructure, where architecture, access, and decision-making became part of the same design problem.',
        kind: 'field-study',
      },
      {
        date: '08/2021',
        title: 'Chose to become Gino’s father',
        text: 'Not a formal milestone, but one of the most important decisions of my life.',
        tone: 'choice',
        kind: 'inflection',
      },
    ],
  },
  {
    label: 'Collapse & Reinvention',
    years: '2022–2026',
    items: [
      {
        date: '01/2022',
        title: 'Founded Amid the Noise',
        text: 'Created a place for writing, research, systems thinking, and the questions that would not fit neatly anywhere else.',
        tone: 'choice',
        kind: 'inflection',
      },
      {
        date: '04/2022',
        title: 'Sepsis',
        text: 'Second near-death experience. Survival became less abstract.',
        tone: 'near-death',
        kind: 'inflection',
      },
      {
        date: '02/2024',
        title: 'Automobile collision',
        text: 'Third near-death experience. Another reminder that a life can divide cleanly into before and after.',
        tone: 'near-death',
        kind: 'inflection',
      },
      {
        date: '04/2025',
        title: 'Chose a different future',
        text: 'The turning point was not what happened. It was the decision that followed.',
        tone: 'choice',
        kind: 'inflection',
      },
      {
        date: '07/2026',
        title: 'Punchcut',
        text: 'Returned to professional design with a different sense of time, responsibility, and what work can mean.',
        kind: 'field-study',
      },
      {
        date: '07/2026',
        title: 'Returned to university',
        text: 'Began the mathematics and statistics path I once thought required being eighteen again.',
        tone: 'choice',
        kind: 'inflection',
      },
    ],
  },
];
---

<Layout title={title} description={description}>
  <SectionPage
    section="career"
    title="Timeline"
    intro={sectionIntro}
    sectionNav={[
      { label: 'Overview', href: '/career' },
      { label: 'Case Studies', href: '/career/case-studies' },
      { label: 'Timeline', href: '/career/timeline' },
      { label: 'Learning', href: '/career/learning' },
    ]}
  >
    <section class="timeline-page" aria-labelledby="timeline-title">
      <div class="timeline-prologue">
        <p>
          This is not a complete chronology. It is a record of inflection points: the moments, institutions, losses, responsibilities, and decisions after which I was no longer quite the same person.
        </p>
      </div>

      <div class="timeline" aria-label="Career and life timeline">
        {timelineGroups.map((group) => (
          <section class="timeline-era" aria-labelledby={`timeline-${group.label.toLowerCase().replaceAll(' ', '-')}`}>
            <div class="timeline-era-marker">
              <p class="timeline-era-years">{group.years}</p>
              <h2 id={`timeline-${group.label.toLowerCase().replaceAll(' ', '-')}`}>{group.label}</h2>
            </div>

            <div class="timeline-era-items">
              {group.items.map((item) => (
                <article class:list={['timeline-item', item.kind && `timeline-item-${item.kind}`, item.tone && `timeline-item-${item.tone}`]}>
                  <div class="timeline-date">{item.date}</div>
                  <div class="timeline-card">
                    <h3>
                      {item.href ? (
                        <a href={item.href}>{item.title}</a>
                      ) : (
                        item.title
                      )}
                    </h3>
                    <p>{item.text}</p>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>

      <figure class="timeline-archive-image">
        <img src="/images/pages/atn-timeline-001.png" alt="Archival illustration for the Amid the Noise career timeline." loading="lazy" />
      </figure>

      <SectionMoreLink href="/career" label="Back to Career overview" />
    </section>
</SectionPage>
</Layout>

<style>
  .timeline-page {
    margin-top: 3rem;
    margin-bottom: 2rem;
  }

  .timeline-prologue {
    max-width: 46rem;
    margin-bottom: 3.5rem;
  }

  .timeline-prologue p {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.7;
    color: rgba(31, 31, 31, 0.82);
  }

  .timeline {
    position: relative;
    display: grid;
    gap: 4rem;
  }

  .timeline-era {
    display: grid;
    grid-template-columns: minmax(7.5rem, 0.24fr) minmax(0, 1fr);
    gap: clamp(0.9rem, 2.2vw, 2rem);
    position: relative;
  }

  .timeline-era-marker {
    position: sticky;
    top: 5.5rem;
    align-self: start;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.7rem;
    min-height: 16rem;
    overflow: visible;
  }

  .timeline-era-years {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-transform: uppercase;
    color: rgba(31, 31, 31, 0.62);
    white-space: nowrap;
  }

  .timeline-era h2 {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    line-height: 1;
    text-transform: uppercase;
    color: rgba(31, 31, 31, 0.92);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    white-space: nowrap;
  }

  .timeline-era-items {
    position: relative;
    display: grid;
    gap: 1.35rem;
    padding-left: 2rem;
  }

  .timeline-era-items::before {
    content: '';
    position: absolute;
    top: 0.35rem;
    bottom: 0.35rem;
    left: 0.38rem;
    width: 1px;
    background: linear-gradient(
      to bottom,
      rgba(31,31,31,0),
      rgba(31,31,31,0.34) 10%,
      rgba(31,31,31,0.34) 90%,
      rgba(31,31,31,0)
    );
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 5.75rem minmax(0, 1fr);
    gap: 1.25rem;
    position: relative;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: -2.08rem;
    top: 0.42rem;
    width: 0.82rem;
    height: 0.82rem;
    border: 2px solid rgba(31, 31, 31, 0.62);
    border-radius: 999px;
    background: var(--bg);
    box-shadow: 0 0 0 4px var(--bg);
  }
  
  .timeline-item-near-death::before {
    left: -2.10rem;
    width: 1.00rem;
    height: 1.00rem;
    border: 0;
    border-radius: 0;
    background: rgba(126, 68, 51, 0.9);

    clip-path: polygon(
      30% 0%,
      70% 0%,
      100% 30%,
      100% 70%,
      70% 100%,
      30% 100%,
      0% 70%,
      0% 30%
    );

    box-shadow: 0 0 0 4px var(--bg);
  }

  .timeline-item-life::before {
    width: 0.78rem;
    height: 0.78rem;
    border-color: rgba(126, 68, 51, 0.8);
    border-radius: 2px;
    transform: rotate(45deg);
  }

  .timeline-item-choice::before {
    left: -2.14rem;
    border-color: rgba(129, 96, 37, 0.86);
    box-shadow:
      0 0 0 4px var(--bg),
      inset 0 0 0 3px var(--bg),
      inset 0 0 0 4px rgba(129, 96, 37, 0.42);
  }

  .timeline-item-field-study::before {
    border-color: rgba(126, 68, 51, 0.72);
  }

  .timeline-item-formation::before {
    left: -2.14rem;
    border-color: rgba(31, 31, 31, 0.56);
  }

  .timeline-date {
    padding-top: 0.18rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.3;
    text-transform: uppercase;
    color: rgba(31, 31, 31, 0.74);
    font-variant-numeric: tabular-nums;
  }

  .timeline-card {
    position: relative;
    max-width: 42rem;
    padding-left: 1rem;
    padding-bottom: 1.35rem;
    border-bottom: 1px solid rgba(31, 31, 31, 0.11);
  }

  .timeline-card::before {
    content: '';
    position: absolute;
    top: 0.12rem;
    bottom: 1.35rem;
    left: 0;
    width: 3px;
    border-radius: 999px;
    background: rgba(31, 31, 31, 0.16);
  }

  .timeline-item-formation .timeline-card::before {
    background: rgba(31, 31, 31, 0.2);
  }

  .timeline-item-field-study .timeline-card::before {
    background: rgba(126, 68, 51, 0.62);
  }

  .timeline-item-inflection .timeline-card::before {
    background: rgba(129, 96, 37, 0.68);
  }

  .timeline-card h3 {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--text);
  }

  .timeline-card h3 a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 160ms ease, color 160ms ease;
  }

  .timeline-card h3 a:hover {
    color: var(--link);
    border-bottom-color: currentColor;
  }

  .timeline-archive-image {
    width: min(100%, 46rem);
    margin: 4rem 0 2.5rem;
  }

  .timeline-archive-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  .timeline-card p {
    margin: 0;
    font-size: 0.94rem;
    line-height: 1.62;
    color: rgba(31, 31, 31, 0.76);
  }

  @media (max-width: 900px) {
    .timeline-page {
      margin-top: 2.5rem;
    }

    .timeline-prologue {
      margin-bottom: 2.75rem;
    }
    .timeline-archive-image {
      width: 100%;
      margin-top: 3rem;
    }

    .timeline-era {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .timeline-era-marker {
      position: static;
      display: block;
      min-height: 0;
    }

    .timeline-era-items {
      padding-left: 1.45rem;
    }

    .timeline-era-items::before {
      left: 0.24rem;
    }

    .timeline-item {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .timeline-item::before {
      left: -1.56rem;
      top: 0.18rem;
    }

    .timeline-date {
      padding-top: 0;
    }

    .timeline-era h2 {
      writing-mode: horizontal-tb;
      transform: none;
      max-width: none;
      font-size: 1rem;
      letter-spacing: 0.06em;
      line-height: 1.2;
    }

    .timeline-era-years {
      margin: 0 0 0.35rem;
      padding-top: 0;
      white-space: normal;
    }
  }
</style>
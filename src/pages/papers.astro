---
import Layout from '../layouts/Layout.astro';

const title = "Papers";
const description = "Long-form research, white papers, and operational systems thinking from Amid the Noise.";

const papers = [
  {
    title: "From Passive Monitoring to Self-Stabilizing Infrastructure",
    subtitle:
      "Reaction latency, persistent operational presence, and the future of machine response.",
    href: "/papers/from-passive-monitoring-to-self-stabilizing-infrastructure.pdf",
    meta: "PDF • 26 pages • May 2026",
    description:
      "A white paper exploring the evolution of infrastructure from passive monitoring systems toward actively self-stabilizing systems capable of bounded autonomous intervention.",
  },
  {
    title: "Toward a Human-Centered Intelligence Infrastructure",
    subtitle:
      "Operational trust, escalation governance, and human judgment in AI-supported systems.",
    href: "/writing/toward-a-human-centered-intelligence-infrastructure",
    meta: "Essay • Foundational Paper",
    description:
      "A framework for designing intelligence systems that preserve human agency, accountability, and operational trust under pressure.",
  },
  {
    title: "The Reciprocity Principle of Emerging Intelligence",
    subtitle:
      "Behavioral ethics, digital civility, and the human consequences of machine interaction.",
    href: "/writing/the-reciprocity-principle-of-emerging-intelligence",
    meta: "Essay • Foundational Paper",
    description:
      "An exploration of how human interaction with AI systems may reinforce broader social norms, empathy structures, and institutional behavior.",
  },
];
---

<Layout title={title} description={description}>
  <section class="section papers-page">
    <div class="papers-intro">
      <h1>Papers</h1>
      <p>
        Long-form research, operational frameworks, and systems-level thinking
        exploring infrastructure, governance, artificial intelligence, and
        human-centered design.
      </p>
    </div>

    <div class="papers-list">
      {
        papers.map((paper) => (
          <article class="paper-card">
            <h2>
              <a href={paper.href}>{paper.title}</a>
            </h2>

            <p class="paper-meta">{paper.meta}</p>

            <p class="paper-subtitle">{paper.subtitle}</p>

            <p class="paper-description">{paper.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .papers-page {
    max-width: 100%;
  }

  .papers-intro {
    margin-bottom: 3.25rem;
  }

  .papers-intro h1 {
    margin-bottom: 1rem;
  }

  .papers-intro p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    max-width: 62ch;
  }

  .papers-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(49, 64, 86, 0.18);
  }

  .paper-card {
    padding: 1.75rem 0 2.6rem;
    border-bottom: 1px solid rgba(49, 64, 86, 0.18);
  }

  .paper-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .paper-meta {
    margin: 0 0 0.8rem;
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--color-text-muted);
  }

  .papers-page .paper-card h2 {
    margin: 0 0 0.25rem;
    font-size: clamp(1.08rem, 1.25vw, 1.22rem) !important;
    line-height: 1.3;
    letter-spacing: normal !important;
    text-transform: none !important;
    color: var(--color-text);
  }

  .papers-page .paper-card h2 a {
    color: inherit;
    text-decoration: none;
  }

  .papers-page .paper-card h2 a:hover {
    text-decoration: underline;
  }

  .paper-subtitle {
    margin: 0 0 0.7rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-text);
  }

  .paper-description {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 68ch;
  }
</style>
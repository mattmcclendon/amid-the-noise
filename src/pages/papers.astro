---
import Layout from '../layouts/Layout.astro';

const title = "Papers";
const description = "Long-form research, white papers, and operational systems thinking from Amid the Noise.";

const inProgressPapers = [
  {
    title: "Graceful Governance",
    workingTitle: true,
    subtitle:
      "Building institutions that remain legitimate under stress.",
    href: null,
    meta: "Web Paper • August 2026 (Forthcoming)",
    description:
      "Coming soon. A study of governance architectures that preserve adaptability, accountability, and public legitimacy during periods of disruption.",
  },
  {
    title: "Habitation",
    workingTitle: true,
    subtitle:
      "Why the measure of a system is whether people can continue living meaningfully within it.",
    href: null,
    meta: "Web Paper • July 2026 (Forthcoming)",
    description:
      "Coming soon. A systems framework arguing that the ultimate purpose of governance, infrastructure, and institutions is not optimization, but sustaining human habitation across changing conditions.",
  },
  {
    title: "Trust, Fairness, and the Space Between",
    workingTitle: true,
    subtitle:
      "Data, perception, and emotion as the foundations of institutional legitimacy.",
    href: null,
    meta: "Web Paper • July 2026 (Forthcoming)",
    description:
      "Coming soon. An examination of how measurable outcomes, public perception, and emotional experience combine to shape trust in civic and organizational systems.",
  },
];

const papers = [
  {
    title: "The Infrastructure of Belonging",
    subtitle:
      "Reducing the Gap Between Services and the People They Serve.",
    href: "/papers/the-infrastructure-of-belonging",
    pdfHref: "/papers/McClendon-The-Infrastructure-of-Belonging.pdf",
    meta: "Web Paper • June 2026",
    description:
      "A civic systems framework examining how institutions become reachable through connectors, continuity, and the reduction of distance. Drawing from elections, homelessness services, and public transit, the paper argues that belonging emerges when public systems are designed to bridge the gap between services and the people they serve.",
  },
  {
    title: "Existential Dread in Silicon Valley",
    subtitle:
      "Behavioral infrastructure, institutional drift, and the crisis of philosophical coherence.",
    href: "/papers/McClendon-Existential-Dread-in-Silicon-Valley.pdf",
    meta: "PDF • 26 pages • June 2026",
    description:
      "A systems-level examination of how technology companies evolved from products into behavioral infrastructure while remaining culturally optimized for startup-era experimentation, resulting in recurring cycles of institutional instability, strategic drift, and governance incoherence.",
  },
  {
    title: "Graceful Degradation",
    subtitle:
      "Space infrastructure and the future of resilient civilization.",
    href: "/papers/McClendon_Graceful-Degradation_2027.pdf",
    meta: "PDF • 13 pages • May 2026",
    description:
      "A white paper arguing that the infrastructural logic emerging from space habitation may offer a model for resilient terrestrial systems built around redundancy, compartmentalization, and recoverability under stress.",
  },
  {
    title: "From Passive Monitoring to Self-Stabilizing Infrastructure",
    subtitle:
      "Reaction latency, persistent operational presence, and the future of machine response.",
    href: "/papers/from-passive-monitoring-to-self-stabilizing-infrastructure.pdf",
    meta: "PDF • 26 pages • May 2026",
    description:
      "An exploration of reaction latency, machine-speed response, and the emergence of infrastructure capable of preserving operational continuity before coherent human intervention occurs.",
  },
  {
    title: "Toward a Human-Governed Intelligence Infrastructure",
    subtitle:
      "Operational trust, escalation governance, and human judgment in AI-supported systems.",
    href: "/papers/Toward-a-Human-Governed-Intelligence-Infrastructure.pdf",
    meta: "PDF • 15 pages • August 2025",
    description:
      "A systems-level argument for intelligence architectures that preserve accountability, escalation transparency, and human authority as AI becomes embedded inside operational decision environments.",
  },
  {
    title: "The Reciprocity Principle of Emerging Intelligence",
    subtitle:
      "Behavioral ethics, digital civility, and the human consequences of machine interaction.",
    href: "/papers/The-Reciprocity-Principle-of-Emerging-Intelligence.pdf",
    meta: "PDF • 19 pages • August 2025",
    description:
      "A philosophical and operational examination of how human behavior toward artificial intelligence may reinforce broader norms surrounding empathy, dignity, and social conduct.",
  },
  {
    title: "Operational Empathy as Intelligence Capability",
    subtitle:
      "Why emotionally legible systems may become essential to institutional trust.",
    href: "/papers/Operational-Empathy-as-Intelligence-Capability.pdf",
    meta: "PDF • 19 pages • August 2025",
    description:
      "An argument that emotionally legible systems may become essential to institutional trust, particularly in environments where intelligence systems increasingly mediate human outcomes.",
  },
  {
    title: "Designed to Fail, Excused by Scarcity",
    subtitle:
      "Why institutional systems increasingly optimize around constraint instead of human outcomes.",
    href: "/papers/Designed-to-Fail-Excused-by-Scarcity.pdf",
    meta: "PDF • 10 pages • August 2025",
    description:
      "A critique of modern institutions that normalize exhaustion, procedural friction, and systemic degradation by treating scarcity as an inevitability rather than a design decision.",
  },
  {
    title: "Designing Dignity",
    subtitle:
      "Why public systems fail when they optimize for compliance instead of human reality.",
    href: "/papers/Designing-Dignity.pdf",
    meta: "PDF • 11 pages • July 2025",
    description:
      "A civic systems paper examining how public infrastructure often fails the people closest to instability, and what becomes possible when dignity is treated as a design requirement.",
  },
];

---

<Layout title={title} description={description}>
  <section class="section papers-page">
    <div class="papers-intro">
      <h1>Papers</h1>
      <p>
        Long-form research, operational frameworks, and systems-level thinking
        exploring infrastructure, governance, artificial intelligence, and
        human-centered design.
      </p>

      <p class="papers-thesis">
        A system succeeds not when it performs optimally, but when people can
        continue living meaningfully inside it.
      </p>
    </div>

    <div class="papers-list">
      {
        papers.map((paper) => (
          <article class="paper-card">
            <h2>
              <a href={paper.href}>
                {paper.title}
                {
                  paper.workingTitle && (
                    <span class="working-title"> (working title)</span>
                  )
                }
              </a>
            </h2>

            <p class="paper-meta">
              {paper.meta}
              {
                paper.pdfHref && (
                  <>
                    <span class="paper-meta-separator">•</span>
                    <a class="paper-pdf-link" href={paper.pdfHref}>Download PDF (39 pages)</a>
                  </>
                )
              }
            </p>

            <p class="paper-subtitle">{paper.subtitle}</p>

            <p class="paper-description">{paper.description}</p>
          </article>
        ))
      }
    </div>

    <div class="papers-in-progress">
      <div class="section-heading">
        <h2>In Progress</h2>
      </div>

      <div class="papers-list in-progress-list">
        {
          inProgressPapers.map((paper) => (
            <article class="paper-card in-progress-card">
              <h2>
                {paper.title}
                {
                  paper.workingTitle && (
                    <span class="working-title"> (working title)</span>
                  )
                }
              </h2>

              <p class="paper-meta">{paper.meta}</p>

              <p class="paper-subtitle">{paper.subtitle}</p>

              <p class="paper-description">{paper.description}</p>
            </article>
          ))
        }
      </div>
    </div>

    <div class="papers-next-path">
      <div class="section-heading">
        <h2>Next Path</h2>
      </div>

      <p class="papers-next-copy">
        These papers focus on governance, infrastructure, intelligence, and
        systems-level theory. For applied examples of how those ideas translate
        into operational environments, product systems, and institutional
        decision-making, continue to the learning archive.
      </p>

      <p class="papers-next-link">
        <a href="/learning">Explore Field Studies →</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .papers-page {
    max-width: 100%;
  }

  .papers-intro {
    margin-bottom: 3.25rem;
  }

  .papers-intro h1 {
    margin-bottom: 1rem;
  }

  .papers-intro p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    max-width: 62ch;
  }

  .papers-thesis {
    margin-top: 1.15rem;
    padding-left: 0.85rem;
    border-left: 3px solid var(--accent-papers);
    font-size: clamp(1rem, 1.15vw, 1.12rem) !important;
    line-height: 1.7 !important;
    font-style: italic;
    color: var(--color-text) !important;
    max-width: 60ch !important;
  }

  .papers-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(49, 64, 86, 0.18);
  }

  .papers-in-progress {
    margin-top: 4rem;
  }

  .papers-in-progress .section-heading {
    margin-bottom: 1.2rem;
  }

  .papers-in-progress .section-heading h2 {
    font-size: 0.82rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .in-progress-list {
    border-top-color: rgba(49, 64, 86, 0.12);
  }

  .in-progress-card {
    opacity: 0.86;
  }

  .paper-card {
    position: relative;
    padding: 1.75rem 0 2.6rem 1rem;
    border-bottom: 1px solid rgba(49, 64, 86, 0.18);
  }

  .paper-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1.95rem;
    width: 3px;
    height: 3.35rem;
    background: var(--accent-papers);
  }

  .paper-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .paper-meta {
    margin: 0 0 1.15rem;
    font-size: 0.85rem;
    line-height: 1.45;
    padding-top: .2rem;
    color: var(--color-text-muted);
  }

  .paper-meta-separator {
    margin: 0 0.4rem;
    color: rgba(49, 64, 86, 0.42);
  }

  .paper-pdf-link {
    color: #3f5f8c;
    text-decoration: none;
  }

  .paper-pdf-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.16em;
  }

  .papers-page .paper-card h2 {
    margin: 0 0 0.32rem;
    font-size: clamp(1.08rem, 1.25vw, 1.22rem) !important;
    line-height: 1.28;
    letter-spacing: normal !important;
    text-transform: none !important;
    color: var(--color-text);
  }

  .papers-page .paper-card h2 a {
    color: inherit;
    text-decoration: none;
  }

  .papers-page .paper-card h2 a:hover {
    text-decoration: underline;
  }

  .working-title {
    font-size: 0.75em;
    font-style: italic;
    font-weight: 400;
    opacity: 0.75;
    white-space: nowrap;
  }

  .paper-subtitle {
    margin: 0 0 0.7rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-text);
  }

  .paper-description {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 68ch;
  }

  .papers-next-path {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(49, 64, 86, 0.18);
    max-width: 68ch;
  }


  .papers-next-copy {
    margin: 0 0 1rem;
    font-size: 0.98rem;
    line-height: 1.72;
    color: var(--color-text-muted);
    max-width: 66ch;
  }

  .papers-next-link {
    margin: 0;
  }

  .papers-next-link a {
    font-size: 0.98rem;
    font-weight: 400;
    color: #3f5f8c;
    text-decoration: none;
  }

  .papers-next-link a:hover {
    text-decoration: underline;
    text-underline-offset: 0.16em;
  }
</style>
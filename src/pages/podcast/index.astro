---
import Layout from '../../layouts/Layout.astro';
import SectionPage from '../../components/SectionPage.astro';
import ArchiveImageModule from '../../components/ArchiveImageModule.astro';
import PodcastEpisodeRow from '../../components/PodcastEpisodeRow.astro';
import StudioWishlist from '../../components/StudioWishlist.astro';

const title = 'Podcast';
const description = 'The Amid the Noise podcast is taking shape after a year spent finding its voice through writing.';
---

<Layout title={title} description={description}>
  <SectionPage
    section="podcast"
    title="Podcast"
    intro="The conversation starts here."
  >
    <section class="podcast-section" aria-labelledby="podcast-writing">
      <h2 id="podcast-writing">Writing came first</h2>
      <p><em>Amid the Noise</em> was always envisioned as a podcast. Then I started writing—and kept writing.</p>
      <p>Over the following year, the writing became a way of understanding what I actually believed: about systems, judgment, recovery, belonging, and the world I had spent decades learning to see.</p>
      <p>There is finally enough ground beneath those ideas to begin talking.</p>
    </section>

    <ArchiveImageModule
      src="/images/pages/atn-listen-001.png"
      alt="An archival illustration of a podcast table with microphones, headphones, a recorder, and an open notebook."
      width="wide"
    />

    <section class="podcast-section podcast-episodes" aria-labelledby="podcast-episodes">
      <h2 id="podcast-episodes">Episodes</h2>
      <PodcastEpisodeRow
        episodeNumber={1}
        title="Pilot"
        description={[
          'Join us for the first conversation as Amid the Noise moves from the page into the room.',
          'A beginning shaped by the ideas, systems, and questions that have been gathering here.',
        ]}
        dateLabel="In Production"
        duration="28 minutes"
        spotifyUrl="https://open.spotify.com/episode/3FuE37oNhMNFQztZam7ymg"
        spotifyPrefix="Coming Soon to"
      />
    </section>

    <section class="podcast-section" aria-labelledby="podcast-development">
      <h2 id="podcast-development">In development</h2>
      <p>A few episodes are already mapped out, but the podcast is still taking shape.</p>
      <p>If you have an idea, a story, a question worth exploring, or someone I should speak with, I would love to hear from you:</p>
      <p><a href="mailto:podcast@amidthenoise.com">podcast@amidthenoise.com</a></p>
    </section>

    <section class="podcast-section" aria-labelledby="podcast-studio">
      <h2 id="podcast-studio">Rebuilding the studio</h2>
      <p>The old studio—an Elgato-heavy room with three cameras, four lights, two microphones, acoustic treatment, and a Stream Deck—was lost in the fire. That is a footnote. The more interesting question is what comes next.</p>
      <p>I want to build deliberately this time: begin with an excellent one-person setup, then add only what moves it toward a genuinely capable two-person room.</p>
      <StudioWishlist
        phases={[
          {
            number: '01',
            name: 'Voice',
            purpose: 'A complete one-person recording setup with the audio foundation already sized for a second seat.',
            items: [
              { name: 'Shure MV7X', detail: 'Broadcast-style dynamic microphone' },
              { name: 'RØDECaster Duo', detail: 'Two-seat audio hub and remote-guest workflow' },
              { name: 'Gator Frameworks GFW-MIC-0822', detail: 'Compact desktop stand with telescoping boom' },
              { name: 'Audio-Technica ATH-M50x', detail: 'Reliable closed-back monitoring' },
              { name: 'Elgato Facecam 4K', detail: 'Primary camera' },
              { name: '2× SmallRig RC 120B', detail: 'Matched bi-color fixtures with standard Bowens mounts' },
              { name: 'SmallRig RA-D85 33-inch parabolic softbox', detail: 'A room-friendly, controlled key-light modifier' },
            ],
          },
          {
            number: '02',
            name: 'Image',
            purpose: 'More depth, separation, and control without turning the room into a television set.',
            items: [
              { name: 'Second Facecam 4K', detail: 'Alternate solo angle and future guest coverage' },
              { name: 'Elgato Stream Deck', detail: 'Recording, lighting, and scene control' },
              { name: 'Acoustic treatment', detail: 'Placed for the room rather than sold as decoration' },
              { name: 'A practical lamp', detail: 'Warmth and visible depth in the background' },
            ],
          },
          {
            number: '03',
            name: 'Conversation',
            purpose: 'The additions that turn a polished solo room into an equally considered two-person studio.',
            items: [
              { name: 'Second Shure MV7X', detail: 'A matched voice chain for the guest' },
              { name: 'Second Gator Frameworks GFW-MIC-0822', detail: 'Matched desktop stand for the guest microphone' },
              { name: 'Second Audio-Technica ATH-M50x', detail: 'Matched monitoring' },
              { name: 'Third Facecam 4K', detail: 'A dedicated two-shot' },
            ],
          },
        ]}
      />
    </section>
  </SectionPage>
</Layout>

<style>
  .podcast-section {
    padding: 2rem 0;
    border-top: 1px solid var(--line);
  }

  .podcast-section:first-child {
    padding-top: 1rem;
    border-top: 0;
  }

  .podcast-section h2 {
    margin: 0 0 1rem;
  }

  .podcast-section p {
    max-width: 42rem;
    margin: 0 0 0.8rem;
    font-size: 1rem;
    line-height: 1.65;
  }

  .podcast-episodes {
    padding-bottom: .25rem;
  }

</style>

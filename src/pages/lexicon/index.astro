---
import Layout from '../../layouts/Layout.astro';
import SectionPage from '../../components/SectionPage.astro';
import LexiconSection from '../../components/LexiconSection.astro';
import ArchiveImageModule from '../../components/ArchiveImageModule.astro';
import { conceptGroups } from '../../data/lexiconData';

const title = 'Lexicon | Amid the Noise';
const description = 'A working lexicon of recurring terms, concepts, and frameworks used across Amid the Noise.';
const sectionIntro = 'A working vocabulary for the ideas that recur across Amid the Noise: signal, trust, judgment, belonging, infrastructure, recovery, and the systems that shape them.';
---

<Layout title={title} description={description}>
  <SectionPage
    section="lexicon"
    title="Lexicon"
    intro={sectionIntro}
    showHeader={false}
  >
    {conceptGroups.map((group) => (
      <LexiconSection {...group} />
    ))}

    <div class="lexicon-image">
      <ArchiveImageModule
        src="/images/pages/atn-lexicon-001.png"
        alt="Archival illustration representing the evolving language and concepts of Amid the Noise."
      />
    </div>
  </SectionPage>
</Layout>

<style>
  .lexicon-image {
    margin-top: 1rem;
  }
</style>

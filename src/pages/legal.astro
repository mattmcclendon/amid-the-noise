---
import Layout from '../layouts/Layout.astro';

const title = "Legal";
const description = "Legal information, terms, and publication policies for Amid the Noise.";
---

<Layout title={title} description={description}>
  <section class="section">
    <h1>Terms of Use</h1>

    <p class="policy-meta">Effective Date: April 2026</p>

    <p>
      Welcome to Amid the Noise. By accessing this site, you agree to the
      following terms.
    </p>

    <h2>Content and Use</h2>
    <p>
      All content on this site, including writing, essays, and publications, is
      provided for informational and educational purposes.
    </p>

    <p>
      The views expressed are those of the author and do not constitute
      professional, legal, or policy advice.
    </p>

    <p>
      You may read, share, and link to the content freely. However, you may not
      reproduce, republish, or redistribute content in full without permission.
    </p>

    <p>
      Attribution is required when quoting or referencing any material from this
      site.
    </p>

    <h2>Intellectual Property</h2>
    <p>
      All original content is the intellectual property of Matthew McClendon
      unless otherwise noted.
    </p>

    <p>
      Unauthorized use, duplication, or distribution may violate copyright law.
    </p>

    <h2>External Links</h2>
    <p>
      This site may link to third-party platforms. These links are provided for
      convenience and do not imply endorsement.
    </p>

    <h2>No Liability</h2>
    <p>
      The content on this site is provided “as is” without warranties of any
      kind.
    </p>

    <p>
      The author is not responsible for any decisions, actions, or outcomes
      resulting from the use of this content.
    </p>

    <h2>Changes</h2>
    <p>
      These terms may be updated over time. Continued use of the site
      constitutes acceptance of any updates.
    </p>

    <h2>Contact</h2>
    <p>
      For questions regarding these terms, you may contact:
      <br />
      <a href="mailto:info@amidthenoise.com">info@amidthenoise.com</a>
    </p>
  </section>
</Layout>

<style>
  .policy-meta {
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--secondary);
    margin: 0 0 12px;
  }
</style>
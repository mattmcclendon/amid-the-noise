<style>
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 56px;
    align-items: start;
  }

  .about-text {
    min-width: 0;
  }

  .about-image-wrap {
    justify-self: end;
    width: 100%;
    max-width: 300px;
  }

  .about-image {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--line);
    background: var(--bg);
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .about-image-wrap {
      justify-self: start;
      max-width: 260px;
    }
  }
</style>
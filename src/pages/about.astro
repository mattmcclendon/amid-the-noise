---
import Layout from "../layouts/Layout.astro";

const title = "Contact Me";
const description = "Contact Matthew McClendon about product design, UX strategy, civic technology, writing, speaking, and consulting inquiries.";
---

<Layout title={title} description={description}>
  <section class="section" data-pagefind-ignore>
    <h1>Contact Me</h1>
    <p>
      I’m Matthew McClendon, a product design leader, writer, and civic technologist working at the intersection of systems, signal, and human decision-making.
    </p>
    <p>
      For product design, UX strategy, research, civic technology, writing, speaking, or consulting inquiries, send a note below or connect through one of the channels listed here.
    </p>
  </section>

  <section class="section" data-pagefind-ignore>
    <div class="section-heading">
      <h2>Follow</h2>
    </div>
    <p>
      Find Amid the Noise and related work across publication, design, and social channels.
    </p>
    <p class="contact-links">
      <a href="https://www.linkedin.com/in/matthewmcclendon/" target="_blank" rel="noopener noreferrer">LinkedIn</a> ·
      <a href="https://github.com/matthewmcclendon" target="_blank" rel="noopener noreferrer">GitHub</a> ·
      <a href="https://www.facebook.com/matt.mcclendon" target="_blank" rel="noopener noreferrer">Facebook</a> ·
      <a href="https://www.behance.net/matthewmcclendon" target="_blank" rel="noopener noreferrer">Behance</a> ·
      <a href="https://x.com/matt_mcclendon" target="_blank" rel="noopener noreferrer">X</a> ·
      <a href="/rss.xml">RSS</a>
    </p>
  </section>

  <section class="section" data-pagefind-ignore>
    <div class="section-heading">
      <h2>Send a note</h2>
    </div>
    <p>
      Use this for thoughtful inquiries, collaborations, speaking invitations, or project conversations.
    </p>

    <form class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden-field">
        <label>
          Don’t fill this out if you’re human: <input name="bot-field" />
        </label>
      </p>

      <label>
        Name
        <input type="text" name="name" autocomplete="name" required />
      </label>

      <label>
        Email
        <input type="email" name="email" autocomplete="email" required />
      </label>

      <label>
        Subject
        <input type="text" name="subject" required />
      </label>

      <label>
        Message
        <textarea name="message" rows="7" required></textarea>
      </label>

      <button type="submit">Send Message</button>
    </form>
  </section>
</Layout>

<style>
  .contact-links {
    line-height: 1.8;
  }

  .contact-form {
    display: grid;
    gap: 1.25rem;
    margin-top: 1.75rem;
  }

  .contact-form label {
    display: grid;
    gap: 0.45rem;
  }

  .contact-form input,
  .contact-form textarea {
    width: 100%;
    border: 1px solid var(--line);
    background: var(--bg);
    padding: 0.75rem;
    font: inherit;
    color: var(--text);
  }

  .contact-form textarea {
    resize: vertical;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: 2px solid var(--accent-plum);
    outline-offset: 2px;
  }

  .contact-form button {
    justify-self: start;
    border: 1px solid var(--text);
    background: var(--text);
    color: var(--bg);
    padding: 0.75rem 1rem;
    font: inherit;
    cursor: pointer;
  }

  .contact-form button:hover,
  .contact-form button:focus-visible {
    background: var(--accent-plum);
    border-color: var(--accent-plum);
  }

  .hidden-field {
    display: none;
  }
</style>
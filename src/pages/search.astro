---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Search | Amid the Noise"
  description="Search the writing, papers, and work archive."
>
  <section class="section" data-pagefind-ignore>
    <h1>Search</h1>
    <p>
      Search the archive of writing on systems, signal, and how decisions take shape.
    </p>

    <div id="search" class="search-shell">
      <label class="sr-only" for="search-input">Search the archive</label>
      <div class="search-form">
        <svg class="search-icon" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="1.8"></circle>
          <path d="M20 20l-4.35-4.35" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
        </svg>
        <input id="search-input" type="search" placeholder="Search Amid the Noise" autocomplete="off" />
        <button id="search-clear" type="button" hidden>Clear</button>
      </div>
      <div id="search-status" class="search-status" aria-live="polite"></div>
      <div id="search-results" class="search-results"></div>
      <div id="search-actions" class="search-actions" hidden>
        <button id="search-more" type="button" class="search-more">Load more</button>
      </div>
    </div>
  </section>

  <script is:inline type="module">
    import * as pagefind from "/pagefind/pagefind.js";

    const input = document.querySelector("#search-input");
    const clearButton = document.querySelector("#search-clear");
    const status = document.querySelector("#search-status");
    const resultsRoot = document.querySelector("#search-results");
    const actions = document.querySelector("#search-actions");
    const moreButton = document.querySelector("#search-more");

    const RESULTS_PER_PAGE = 10;
    let currentResults = [];
    let visibleCount = 0;
    let currentQuery = "";

    const stripHtml = (value) => value.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim();

    const normalizeExcerpt = (value) => {
      const cleaned = stripHtml(value || "")
        .replace(/([a-z])([A-Z])/g, "$1 $2")
        .replace(/\s+/g, " ")
        .trim();

      if (!cleaned) return "";
      return cleaned.length > 220 ? `${cleaned.slice(0, 217).trim()}...` : cleaned;
    };

    const buildResult = (data) => {
      const article = document.createElement("article");
      article.className = "search-result";

      const title = document.createElement("h3");
      title.className = "search-result-title";

      const link = document.createElement("a");
      link.href = data.url;
      link.textContent = data.meta.title || data.url;
      title.appendChild(link);

      const pubDate = data.meta.pubDate || data.meta.date || data.meta.published || data.meta.datePublished || "";
      const descriptionText = normalizeExcerpt(data.meta.description || data.excerpt || "");

      const metaLine = document.createElement("p");
      metaLine.className = "search-result-meta";
      metaLine.textContent = pubDate;

      const description = document.createElement("p");
      description.className = "search-result-description";
      description.textContent = descriptionText;

      article.appendChild(title);
      if (pubDate) {
        article.appendChild(metaLine);
      }
      if (descriptionText) {
        article.appendChild(description);
      }

      return article;
    };

    const renderVisibleResults = () => {
      resultsRoot.innerHTML = "";

      currentResults.slice(0, visibleCount).forEach((result) => {
        resultsRoot.appendChild(buildResult(result));
      });

      const hasMore = visibleCount < currentResults.length;
      actions.hidden = !hasMore;
    };

    const renderResults = async (query) => {
      const trimmed = query.trim();

      if (!trimmed) {
        currentQuery = "";
        currentResults = [];
        visibleCount = 0;
        status.textContent = "";
        resultsRoot.innerHTML = "";
        actions.hidden = true;
        clearButton.hidden = true;
        return;
      }

      clearButton.hidden = false;

      currentQuery = trimmed;
      const search = await pagefind.search(trimmed);
      currentResults = await Promise.all(search.results.map(async (result) => result.data()));
      visibleCount = Math.min(RESULTS_PER_PAGE, currentResults.length);

      status.textContent = `${currentResults.length} result${currentResults.length === 1 ? "" : "s"} for ${trimmed}`;
      renderVisibleResults();
    };

    let debounce;

    input.addEventListener("input", () => {
      window.clearTimeout(debounce);
      debounce = window.setTimeout(() => {
        renderResults(input.value);
      }, 120);
    });

    clearButton.addEventListener("click", () => {
      input.value = "";
      renderResults("");
      input.focus();
    });

    moreButton.addEventListener("click", () => {
      visibleCount = Math.min(visibleCount + RESULTS_PER_PAGE, currentResults.length);
      renderVisibleResults();
    });
  </script>
</Layout>

<style>
  #search {
    margin-top: 2rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .search-form {
    position: relative;
    width: min(680px, calc(100% - 200px));
    max-width: 680px;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: var(--secondary);
    pointer-events: none;
  }

  #search-input {
    width: 100%;
    height: 46px;
    padding: 0.5rem 4.5rem 0.5rem 3rem;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: transparent;
    color: var(--text);
    font: inherit;
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.2;
    box-sizing: border-box;
  }

  #search-input::placeholder {
    color: var(--secondary);
    opacity: 1;
  }

  #search-input:focus {
    outline: none;
    border-color: var(--secondary);
  }

  #search-clear {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    border: 0;
    background: transparent;
    color: var(--secondary);
    font: inherit;
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 0;
  }

  #search-clear:hover,
  #search-clear:focus-visible {
    color: var(--text);
    outline: none;
  }

  .search-status {
    margin-top: 2rem;
    color: var(--text);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.02rem;
    font-weight: 700;
  }

  .search-results {
    margin-top: 1rem;
  }

  .search-actions {
    margin-top: 1.25rem;
  }

  .search-more {
    border: 1px solid var(--line);
    background: transparent;
    color: var(--text);
    font: inherit;
    font-size: 0.88rem;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    cursor: pointer;
  }

  .search-more:hover,
  .search-more:focus-visible {
    border-color: var(--secondary);
    color: var(--accent);
    outline: none;
  }

  .search-result {
    padding: 1.9rem 0;
    border-top: 1px solid var(--line);
  }

  .search-result-title {
    margin: 0 0 0.55rem;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.18rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: 0;
    text-transform: none;
  }

  .search-result-title a {
    color: var(--text);
    text-decoration: none;
    text-transform: none;
    letter-spacing: 0;
    font: inherit;
  }

  .search-result-title a:hover,
  .search-result-title a:focus-visible {
    color: var(--accent);
    outline: none;
  }

  .search-result-meta {
    margin: 0 0 0.8rem;
    color: var(--secondary);
    font-size: 0.92rem;
    line-height: 1.35;
  }

  .search-result-description {
    margin: 0;
    color: var(--text);
    font-size: 0.98rem;
    line-height: 1.48;
    max-width: 46rem;
  }

  @media (max-width: 1200px) {
    .search-form {
      width: min(640px, calc(100% - 120px));
    }
  }

  @media (max-width: 900px) {
    .search-form {
      width: 100%;
      max-width: 100%;
    }
  }
</style>
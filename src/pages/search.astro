---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Search | Amid the Noise"
  description="Search the writing, papers, and work archive."
>
  <section class="section" data-pagefind-ignore>
    <h1>Search</h1>
    <p>
      Search the archive of writing on systems, signal, and how decisions take shape.
    </p>

    <div id="search"></div>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>

  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      new window.PagefindUI({
        element: "#search",
        showSubResults: false,
        resetStyles: false,
        showImages: false,
      });
    });
  </script>
</Layout>

<style>
  #search {
    margin-top: 2rem;
  }
  #search :global(.pagefind-ui__form) {
    width: min(680px, calc(100% - 200px));
    max-width: 680px;
  }

  #search :global(.pagefind-ui__search-input-container) {
    position: relative;
  }

  #search :global(.pagefind-ui__search-icon) {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    pointer-events: none;
    color: var(--secondary);
  }

  #search :global(.pagefind-ui__search-input) {
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 400;
    letter-spacing: 0;
    color: var(--text);
    box-shadow: none;
    height: 46px;
    padding: 0.5rem 4.5rem 0.5rem 3.1rem;
    line-height: 1.2;
  }

  #search :global(.pagefind-ui__search-input::placeholder) {
    color: var(--secondary);
    opacity: 1;
    font-weight: 400;
  }

  #search :global(.pagefind-ui__search-clear) {
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 400;
    color: var(--secondary);
    background: transparent;
    border: 0;
    box-shadow: none !important;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    right: 1rem;
  }

  #search :global(.pagefind-ui__search-clear:hover),
  #search :global(.pagefind-ui__search-clear:focus-visible) {
    color: var(--text);
    background: transparent;
    box-shadow: none !important;
    outline: none;
  }

  @media (max-width: 1200px) {
    #search :global(.pagefind-ui__form) {
      width: min(640px, calc(100% - 120px));
    }
  }

  @media (max-width: 900px) {
    #search :global(.pagefind-ui__form) {
      width: 100%;
      max-width: 100%;
    }
  }

  #search :global(.pagefind-ui__drawer) {
    margin-top: 2rem;
  }

  #search :global(.pagefind-ui__message) {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }

  #search :global(.pagefind-ui__result) {
    padding: 2rem 0;
    border-top: 1px solid var(--line);
  }

  #search :global(.pagefind-ui__result-link) {
    font-family: inherit;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
  }

  #search :global(.pagefind-ui__result-link:hover),
  #search :global(.pagefind-ui__result-link:focus-visible) {
    color: var(--accent);
    text-decoration: none;
  }

  #search :global(.pagefind-ui__result-excerpt) {
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--text);
  }

  #search :global(mark) {
    background: rgba(255, 230, 0, 0.55);
    color: inherit;
    padding: 0 0.08em;
  }
</style>
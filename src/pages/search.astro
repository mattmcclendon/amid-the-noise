---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Search | Amid the Noise"
  description="Search the writing, papers, and work archive."
>
  <section class="section" data-pagefind-ignore>
    <h1>Search</h1>
    <p>
      Search the archive of writing on systems, signal, and how decisions take shape.
    </p>

    <div id="search"></div>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>

  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      new window.PagefindUI({
        element: "#search",
        showSubResults: false,
        resetStyles: false,
        showImages: false,
      });

      const searchRoot = document.querySelector("#search");
      window.requestAnimationFrame(() => {
        window.requestAnimationFrame(() => {
          if (searchRoot?.querySelector(".pagefind-ui__form")) {
            searchRoot.classList.add("is-ready");
          }
        });
      });
    });
  </script>
</Layout>

<style>
  #search {
    margin-top: 2rem;
    min-height: 56px;
  }

  #search :global(.pagefind-ui) {
    opacity: 0;
  }

  #search.is-ready :global(.pagefind-ui) {
    opacity: 1;
    transition: opacity 0.14s ease;
  }

  #search :global(.pagefind-ui__form) {
    width: min(760px, calc(100% - 40px));
    max-width: 760px;
  }

  #search :global(.pagefind-ui__search-input) {
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 400;
    letter-spacing: 0;
    color: var(--text);
    box-shadow: none;
    height: 46px;
    padding: 0.5rem 4.5rem 0.5rem 3.1rem;
    line-height: 1.2;
  }

  #search :global(.pagefind-ui__search-input::placeholder) {
    color: var(--secondary);
    opacity: 1;
    font-weight: 400;
  }

  #search :global(.pagefind-ui__search-clear) {
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 400;
    color: var(--secondary);
    background: transparent;
    border: 0;
    box-shadow: none !important;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    right: 1rem;
  }

  #search :global(.pagefind-ui__search-clear:hover),
  #search :global(.pagefind-ui__search-clear:focus-visible) {
    color: var(--text);
    background: transparent;
    box-shadow: none !important;
    outline: none;
  }

  #search :global(.pagefind-ui__drawer) {
    margin-top: 2rem;
  }

  #search :global(.pagefind-ui__message) {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.02rem;
    font-weight: 700;
    color: var(--text);
  }

  #search :global(.pagefind-ui__results) {
    border-top: 1px solid var(--line);
    margin-top: 1.35rem;
  }

  #search :global(.pagefind-ui__result) {
    padding: 2.15rem 0;
  }

  #search :global(.pagefind-ui__result + .pagefind-ui__result) {
    border-top: 1px solid var(--line);
  }

  #search :global(.pagefind-ui__result-link),
  #search :global(.pagefind-ui__result-link:link),
  #search :global(.pagefind-ui__result-link:visited),
  #search :global(.pagefind-ui__result-link:hover),
  #search :global(.pagefind-ui__result-link:active),
  #search :global(.pagefind-ui__result-link:focus-visible) {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.22rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--text) !important;
    text-decoration: none !important;
    outline: none;
  }

  #search :global(.pagefind-ui__result-excerpt) {
    font-size: 0.98rem;
    line-height: 1.5;
    color: var(--text);
    max-width: 46rem;
  }

  #search :global(mark) {
    background: rgba(255, 230, 0, 0.55);
    color: inherit;
    padding: 0 0.08em;
  }

  @media (max-width: 1200px) {
    #search :global(.pagefind-ui__form) {
      width: min(700px, calc(100% - 60px));
    }
  }

  @media (max-width: 900px) {
    #search :global(.pagefind-ui__form) {
      width: 100%;
      max-width: 100%;
    }
  }
</style>
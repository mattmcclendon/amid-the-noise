---
import Layout from '../layouts/Layout.astro';

const title = 'Page Not Found';
const description = 'The page you were looking for could not be found.';
---

<Layout title={title} description={description}>
  <section class="section">
    <h1>404: Page Not Found</h1>

    <p class="intro-lead">
      Not every path leads where it was intended to.
    </p>

    <p>
      You can return to the <a href="/">home</a>, continue exploring the
      <a href="/writing/archives">archives</a>, or <a href="/search">search</a>
      for what you were trying to find.
    </p>

    <p>
      <a class="content-link" href="/">Amid the Noise home →</a>
    </p>
  </section>

  <style>
    .section p:not(:last-child) a {
      text-decoration: underline;
      text-underline-offset: 0.14em;
      text-decoration-thickness: 1px;
    }

    .section p:not(:last-child) a:hover {
      text-decoration-thickness: 2px;
    }

    .content-link {
      text-decoration: none;
    }

    .section h1 {
      margin-bottom: 1.5rem;
    }

    .intro-lead {
      margin-bottom: 1.75rem;
    }

    .intro-lead + p {
      margin-bottom: 1.75rem;
    }

    .content-link {
      display: inline-block;
      margin-top: 0.25rem;
    }
  </style>
</Layout>
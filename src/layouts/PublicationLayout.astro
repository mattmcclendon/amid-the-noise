---
import Layout from './Layout.astro';
const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | Amid the Noise`}>
  <article class="publication publication-doc">
    {frontmatter.heroImage && (
      <figure class="publication-hero">
        <img
          src={frontmatter.heroImage}
          alt={frontmatter.heroAlt || frontmatter.title}
        />
      </figure>
    )}

    <header class="publication-header section">
      <h1>{frontmatter.title}</h1>

      {frontmatter.pubDate && (
        <p class="publication-meta">
          {new Date(frontmatter.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </p>
      )}

      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="publication-tags">
          {frontmatter.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class={`publication-body section ${frontmatter.dropcap ? 'dropcap' : ''}`}>
      <slot />
    </div>
  </article>
</Layout>

<style is:global>
  .publication-doc {
    font-family: Inter, system-ui, sans-serif;
    color: var(--text);
  }

  .publication-hero {
    margin: 0 0 32px;
  }

  .publication-hero img {
    display: block;
    width: 100%;
    max-height: 420px;
    height: auto;
    object-fit: cover;
    object-position: center;
    padding: 5px;
    background: var(--bg);
    border: 1px solid var(--line);
    box-sizing: border-box;
  }

  .publication-header {
    padding-bottom: 22px;
  }

  .publication-doc h1 {
    margin: 0 0 10px;
    font-size: 1.7rem;
    line-height: 1.2;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--title);
  }

  .publication-description {
    margin: 0 0 12px;
    max-width: 46rem;
    font-size: 1rem;
    line-height: 1.45;
    font-weight: 600;
    color: var(--secondary);
  }

  .publication-meta {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.4;
    color: var(--secondary);
  }

  .publication-tags {
    margin-top: 12px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--secondary);
    border: 1px solid var(--line);
    padding: 5px 8px;
    background: transparent;
  }

  .publication-body {
    max-width: 46rem;
    font-size: 1.05rem;
    line-height: 1.72;
    color: var(--text);
  }

  .publication-body p {
    margin: 0 0 1.15em;
  }
  .publication-body.dropcap p:first-of-type::first-letter {
    float: left;
    font-size: 3.2rem;
    line-height: 0.85;
    margin-right: 8px;
    font-weight: 600;
    color: var(--title);
  }

  .publication-body h2 {
    margin: 2.8em 0 0.8em;
    font-size: 1.15rem;
    line-height: 1.35;
    font-weight: 600;
    color: var(--title);
  }

  .publication-body h3 {
    margin: 2em 0 0.6em;
    font-size: 1rem;
    line-height: 1.35;
    font-weight: 600;
    color: var(--title);
  }

  .publication-body ul,
  .publication-body ol {
    margin: 0 0 1.2em 1.4em;
    padding: 0;
  }

  .publication-body li {
    margin: 0 0 0.45em;
    line-height: 1.65;
  }

  .publication-body li + li {
    margin-top: 0.15em;
  }

  .publication-body blockquote {
    margin: 1.5em 0;
    padding-left: 1em;
    border-left: 2px solid var(--line);
    color: var(--secondary);
  }

  .publication-body strong {
    font-weight: 600;
  }

  .publication-body a {
    color: var(--accent);
  }

  .publication-body a:hover {
    text-decoration: underline;
  }

  @media (max-width: 720px) {
    .publication-hero {
      margin-bottom: 24px;
    }

    .publication-doc h1 {
      font-size: 1.45rem;
    }

    .publication-description {
      font-size: 0.95rem;
    }

    .publication-body {
      font-size: 1rem;
      line-height: 1.68;
    }
    .publication-body.dropcap p:first-of-type::first-letter {
      font-size: 2.6rem;
      margin-right: 6px;
    }

    .publication-body h2 {
      margin-top: 2.4em;
    }
  }
</style>
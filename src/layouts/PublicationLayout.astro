---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '');

const writingModules = Object.values(import.meta.glob('../pages/writing/*.md', { eager: true }));

const allArticles = writingModules
  .map((module) => ({
    title: module.frontmatter?.title,
    navTitle: module.frontmatter?.navTitle || module.frontmatter?.title,
    pubDate: module.frontmatter?.pubDate,
    url: module.url,
  }))
  .filter((article) => article.title && article.pubDate && article.url)
  .sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());

const currentIndex = allArticles.findIndex(
  (article) => article.url.replace(/\/$/, '') === currentPath
);

const nextArticle = currentIndex >= 0 && currentIndex < allArticles.length - 1 ? allArticles[currentIndex + 1] : null;
---

<Layout title={`${frontmatter.title} | Amid the Noise`}>
  <Fragment slot="head">
    <!-- Open Graph -->
    <meta property="og:title" content={frontmatter.title} />
    <meta property="og:description" content={frontmatter.description || frontmatter.subtitle || ''} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={new URL(frontmatter.heroImage || '/images/og-default.png', Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={frontmatter.title} />
    <meta name="twitter:description" content={frontmatter.description || frontmatter.subtitle || ''} />
    <meta name="twitter:image" content={new URL(frontmatter.heroImage || '/images/og-default.png', Astro.site)} />
  </Fragment>
  <article class="publication publication-doc">
    {frontmatter.heroImage && (
      <figure class="publication-hero">
        <img
          src={frontmatter.heroImage}
          alt={frontmatter.heroAlt || frontmatter.title}
        />
      </figure>
    )}

    <header class="publication-header section">
      <h1>{frontmatter.title}</h1>

      {frontmatter.subtitle && (
        <p class="publication-subtitle">{frontmatter.subtitle}</p>
      )}

      {frontmatter.pubDate && (
        <p class="publication-meta">
          {new Date(frontmatter.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </p>
      )}

      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="publication-tags">
          {frontmatter.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class={`publication-body section ${frontmatter.dropcap ? 'dropcap' : ''}`}>
      <slot />
    </div>

    <div class="publication-terminal" aria-hidden="true">■</div>

    {nextArticle && (
      <nav class="publication-pagination section" aria-label="Next article">
        <div class="publication-pagination-next">
          <span class="publication-pagination-label">Next article →</span>
          <a href={nextArticle.url} class="publication-pagination-title">
            {nextArticle.navTitle}
          </a>
        </div>
      </nav>
    )}
  </article>
</Layout>

<style is:global>
  .publication-doc {
    font-family: Inter, system-ui, sans-serif;
    color: var(--text);
  }

  .publication-hero {
    margin: 0 0 32px;
  }

  .publication-hero img {
    display: block;
    width: 100%;
    max-height: 420px;
    height: auto;
    object-fit: cover;
    object-position: center;
    padding: 5px;
    background: var(--bg);
    border: 1px solid var(--line);
    box-sizing: border-box;
  }

  .publication-header {
    padding-bottom: 22px;
  }

  .publication-doc h1 {
    margin: 0 0 12px;
    font-size: 1.8rem;
    line-height: 1.25;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--title);
  }

  .publication-subtitle {
    margin: 0 0 12px;
    max-width: 46rem;
    font-size: 1.08rem;
    line-height: 1.45;
    font-weight: 500;
    color: var(--title);
  }

  .publication-description {
    margin: 0 0 12px;
    max-width: 46rem;
    font-size: 1rem;
    line-height: 1.45;
    color: var(--secondary);
  }

  .publication-header .publication-meta {
    margin: 0;
    font-size: 0.76rem !important;
    line-height: 1.25;
    letter-spacing: 0.01em;
    font-weight: 400;
    color: var(--secondary);
    opacity: 0.88;
  }

  .publication-header p.publication-meta {
    font-size: 0.76rem !important;
    line-height: 1.25;
    font-weight: 400;
  }

  .publication-tags {
    margin-top: 12px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--secondary);
    border: 1px solid var(--line);
    padding: 5px 8px;
    background: transparent;
  }

  .publication-body {
    max-width: 46rem;
    font-size: 1.05rem;
    line-height: 1.72;
    color: var(--text);
  }

  .publication-body p {
    margin: 0 0 1.15em;
  }
  .publication-body.dropcap p:first-of-type::first-letter {
    float: left;
    font-size: 3.2rem;
    line-height: 0.85;
    margin-right: 8px;
    font-weight: 600;
    color: var(--title);
  }

  .publication-body h2 {
    margin: 2.8em 0 0.8em;
    font-size: 1.15rem;
    line-height: 1.35;
    font-weight: 600;
    color: var(--title);
  }

  .publication-body h3 {
    margin: 2em 0 0.6em;
    font-size: 1rem;
    line-height: 1.35;
    font-weight: 600;
    color: var(--title);
  }

  .publication-body ul,
  .publication-body ol {
    margin: 0 0 1.2em 1.4em;
    padding: 0;
  }

  .publication-body li {
    margin: 0 0 0.45em;
    line-height: 1.65;
  }

  .publication-body li + li {
    margin-top: 0.15em;
  }

  .publication-body blockquote {
    margin: 1.5em 0;
    padding-left: 1em;
    border-left: 2px solid var(--line);
    color: var(--secondary);
  }

  .publication-body strong {
    font-weight: 600;
  }

  .publication-body a {
    color: var(--accent);
  }

  .publication-body a:hover {
    text-decoration: underline;
  }

  .publication-pagination {
    max-width: 46rem;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: flex-end;
  }

  .publication-pagination-next {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    max-width: 28rem;
    text-decoration: none;
    text-align: right;
  }

  .publication-pagination-label {
    font-size: 0.7rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--title);
    opacity: 0.8;
  }

  .publication-pagination-title {
    display: block;
    max-width: 28rem;
    font-size: 0.88rem;
    line-height: 1.4;
    color: var(--secondary);
    white-space: normal;
    overflow: visible;
    text-overflow: clip;
    text-decoration: none;
  }

  .publication-pagination-title:hover {
    color: var(--title);
    text-decoration: underline;
  }

  .publication-terminal {
    max-width: 46rem;
    margin-top: 1.25rem;
    font-size: 1rem;
    line-height: 1;
    color: #3e5a82;
  }

  @media (max-width: 720px) {
    .publication-hero {
      margin-bottom: 24px;
    }

    .publication-doc h1 {
      font-size: 1.5rem;
    }

    .publication-subtitle {
      font-size: 1rem;
    }

    .publication-description {
      font-size: 0.95rem;
    }

    .publication-body {
      font-size: 1rem;
      line-height: 1.68;
    }
    .publication-body.dropcap p:first-of-type::first-letter {
      font-size: 2.6rem;
      margin-right: 6px;
    }

    .publication-body h2 {
      margin-top: 2.4em;
    }

    .publication-pagination {
      justify-content: flex-start;
    }

    .publication-pagination-next {
      align-items: flex-start;
      max-width: 100%;
      text-align: left;
    }
  }
</style>
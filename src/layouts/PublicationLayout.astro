---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '');

const writingModules = Object.values(import.meta.glob('../pages/writing/*.md', { eager: true }));

const allArticles = writingModules
  .map((module) => ({
    title: module.frontmatter?.title,
    navTitle: module.frontmatter?.navTitle || module.frontmatter?.title,
    pubDate: module.frontmatter?.pubDate,
    url: module.url,
  }))
  .filter((article) => article.title && article.pubDate && article.url)
  .sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());

const currentIndex = allArticles.findIndex(
  (article) => article.url.replace(/\/$/, '') === currentPath
);

const nextArticle = currentIndex >= 0 && currentIndex < allArticles.length - 1 ? allArticles[currentIndex + 1] : null;

const BASE_URL = 'https://www.amidthenoise.com';
const canonicalUrl = `${BASE_URL}${Astro.url.pathname}`;
const socialImage = `${BASE_URL}${frontmatter.heroImage || '/images/og-default.png'}`;
const socialDescription = frontmatter.description || frontmatter.subtitle || '';
const publishedTime = frontmatter.pubDate ? new Date(frontmatter.pubDate).toISOString() : null;
---

<Layout title={`${frontmatter.title} | Amid the Noise`}>
  <Fragment slot="head">
    <meta data-pagefind-meta="title[content]" content={frontmatter.title} />
    <meta
      data-pagefind-meta="description[content]"
      content={frontmatter.description || frontmatter.subtitle || ''}
    />
    {frontmatter.pubDate && (
      <meta data-pagefind-meta="date[content]" content={frontmatter.pubDate} />
    )}
    <!-- Open Graph -->
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content="Amid the Noise" />
    <meta property="og:title" content={frontmatter.title} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:width" content="1920" />
    <meta property="og:image:height" content="1080" />
    <meta property="og:image:alt" content={frontmatter.heroAlt || frontmatter.title} />
    {publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={frontmatter.title} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={frontmatter.heroAlt || frontmatter.title} />
  </Fragment>

  <article class="publication publication-doc" data-pagefind-body>
    {frontmatter.heroImage && (
      <figure class="publication-hero">
        <img
          src={frontmatter.heroImage}
          alt={frontmatter.heroAlt || frontmatter.title}
        />
      </figure>
    )}

    <header class="publication-header section">
      <h1 data-pagefind-meta="title">{frontmatter.title}</h1>

      {frontmatter.subtitle && (
        <p class="publication-subtitle">{frontmatter.subtitle}</p>
      )}

      {frontmatter.pubDate && (
        <p class="publication-meta">
          {new Date(frontmatter.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </p>
      )}

      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="publication-tags">
          {frontmatter.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="publication-body section">
      <slot />
    </div>

    {nextArticle && (
      <nav class="publication-pagination section" aria-label="Next article">
        <img class="publication-pagination-threshold" src="/threshold-mark.svg" alt="" loading="lazy" aria-hidden="true" />
        <div class="publication-pagination-next">
          <span class="publication-pagination-label">Next article →</span>
          <a href={nextArticle.url} class="publication-pagination-title">
            {nextArticle.navTitle}
          </a>
        </div>
      </nav>
    )}
  </article>
</Layout>

<style is:global>
  .publication-doc {
    font-family: Inter, system-ui, sans-serif;
    color: var(--text);
  }

  .publication-hero {
    margin: 0 0 32px;
  }

  .publication-hero img {
    display: block;
    width: 100%;
    max-height: 420px;
    height: auto;
    object-fit: cover;
    object-position: center;
    padding: 5px;
    background: var(--bg);
    border: 1px solid var(--line);
    box-sizing: border-box;
  }

  .publication-header {
    padding-bottom: 22px;
  }

  .publication-doc h1 {
    margin: 0 0 12px;
    max-width: 34ch;
    font-size: clamp(1.72rem, 2.2vw, 1.95rem);
    line-height: 1.18;
    font-weight: 600;
    letter-spacing: -0.018em;
    color: var(--title);
    text-wrap: balance;
    overflow-wrap: normal;
    hyphens: none;
  }

  .publication-subtitle {
    margin: 0 0 12px;
    max-width: 46rem;
    font-size: 1.08rem;
    line-height: 1.45;
    font-weight: 500;
    color: var(--title);
  }

  .publication-description {
    margin: 0 0 12px;
    max-width: 46rem;
    font-size: 1rem;
    line-height: 1.45;
    color: var(--secondary);
  }

  .publication-header .publication-meta {
    margin: 0;
    font-size: 0.76rem !important;
    line-height: 1.25;
    letter-spacing: 0.01em;
    font-weight: 400;
    color: var(--secondary);
    opacity: 0.88;
  }

  .publication-header p.publication-meta {
    font-size: 0.76rem !important;
    line-height: 1.25;
    font-weight: 400;
  }

  .publication-tags {
    margin-top: 12px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--secondary);
    border: 1px solid var(--line);
    padding: 5px 8px;
    background: transparent;
  }

  .publication-body {
    max-width: 46rem;
    font-size: 1.05rem;
    line-height: 1.72;
    color: var(--text);
  }

  .publication-body p {
    margin: 0 0 1.15em;
  }

  .publication-body hr {
    margin: 2em 0;
    border: none;
    border-top: 1px solid var(--line);
    opacity: 0.6;
  }


  .publication-body h2 {
    margin: 2.8em 0 0.8em;
    font-size: 1.15rem;
    line-height: 1.35;
    font-weight: 600;
    color: var(--title);
  }

  .publication-body h3 {
    margin: 2em 0 0.6em;
    font-size: 1rem;
    line-height: 1.35;
    font-weight: 600;
    color: var(--title);
  }

  .publication-body ul,
  .publication-body ol {
    margin: 0 0 1.35em;
    padding-left: 1.15rem;
    list-style-position: outside;
  }

  .publication-body li {
    margin: 0 0 0.5em;
    padding-left: 0.35rem;
    line-height: 1.65;
    font-size: 0.96em;
  }

  .publication-body li + li {
    margin-top: 0.2em;
  }

  .publication-body li::marker {
    color: var(--secondary);
    font-size: 0.85em;
  }

  .publication-body blockquote {
    margin: 1.5em 0;
    padding-left: 1em;
    border-left: 2px solid var(--line);
    color: var(--secondary);
  }

  .publication-body strong {
    font-weight: 600;
  }

  .publication-body a {
    color: var(--accent);
  }

  .publication-body a:hover {
    text-decoration: underline;
  }

  .publication-pagination {
    max-width: 46rem;
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .publication-pagination-threshold {
    width: 36px;
    height: 36px;
    display: block;
    opacity: 0.72;
    flex: 0 0 auto;
  }

  .publication-pagination-next {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    max-width: 42rem;
    text-align: right;
  }

  .publication-pagination-label {
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--secondary);
    opacity: 0.9; /* was 0.72 */
  }

  .publication-pagination-title {
    display: block;
    max-width: 42rem;
    font-size: 0.91rem;
    line-height: 1.4;
    color: var(--title); /* stronger contrast than --secondary */
    white-space: nowrap;
    overflow: visible;
    text-overflow: clip;
    text-decoration: none;
  }

  .publication-pagination-title:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  @media (max-width: 720px) {
    .publication-hero {
      margin-bottom: 24px;
    }

    .publication-doc h1 {
      max-width: 100%;
      font-size: clamp(1.45rem, 6vw, 1.65rem);
      line-height: 1.22;
      text-wrap: balance;
    }

    .publication-subtitle {
      font-size: 1rem;
    }

    .publication-description {
      font-size: 0.95rem;
    }

    .publication-body {
      font-size: 1rem;
      line-height: 1.68;
    }

    .publication-body ul,
    .publication-body ol {
      padding-left: 1rem;
    }

    .publication-body li {
      padding-left: 0.25rem;
    }

    .publication-body h2 {
      margin-top: 2.4em;
    }

    .publication-pagination {
      justify-content: space-between;
      gap: 1rem;
    }

    .publication-pagination-next {
      align-items: flex-start;
      max-width: 100%;
      text-align: left;
    }

    .publication-pagination-title {
      max-width: 100%;
      white-space: normal;
    }

    .publication-pagination-threshold {
      width: 32px;
      height: 32px;
    }
  }
</style>
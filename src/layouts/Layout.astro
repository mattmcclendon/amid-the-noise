---
const { title = 'Amid the Noise' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,200..900&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    {import.meta.env.PROD && (
      <>
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-52DXMG6X0J"></script>
        <script is:inline>
          {`
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-52DXMG6X0J');
          `}
        </script>
      </>
    )}
    <title>{title}</title>
    <slot name="head" />
  </head>

  <body id="top">
    <header class="site-header">
      <div class="site-frame">
        <div class="site-header-inner">
          <div class="site-brand">
            <a href="/" class="site-wordmark" aria-label="Amid the Noise home">
              <span class="site-mark" aria-hidden="true"></span>
              <span class="site-name">amid the noise</span>
            </a>
          </div>

          <nav class="site-nav" aria-label="Primary">
            <a href="/work">Work</a>
            <a href="/writing">Writing</a>
            <a href="/learning">Learning</a>
            <a href="/search">Search</a>
            <a href="/about">About</a>
          </nav>
        </div>
      </div>
    </header>

    <main class="site-main">
      <div class="site-frame">
        <div class="content-grid">
          <div class="main-content">
            <slot />
          </div>

          <aside class="sidebar">
            <div class="sidebar-inner">
              <section class="sidebar-section">
                <h3>About</h3>
                <p>Matthew McClendon writes about how decisions actually get made inside modern systems.</p>
                <p>His work focuses on AI, signal, and the structures that determine what happens when the model is wrong.</p>
                <p><em>Amid the Noise</em> is a running exploration of that boundary: where systems act, people interpret, and accountability either holds or fails.</p>
                <p><a href="/about">Read more →</a></p>
              </section>

              <section class="sidebar-section sidebar-contact-section">
                <h3>Contact</h3>
                <p>For collaborations, speaking inquiries, or related work, <a href="mailto:hello@amidthenoise.com">contact me</a>.</p>
              </section>

              <section class="sidebar-section">
                <h3>Follow</h3>
                <div class="social-icons">
                  <a href="https://linkedin.com/in/mattmcclendon" aria-label="LinkedIn"><img src="/linkedin.svg" alt="LinkedIn" /></a>
                  <a href="https://github.com/mattmcclendon" aria-label="GitHub"><img class="social-icon-round" src="/github.svg" alt="GitHub" /></a>
                  <a href="https://substack.com/@matthewmcclendon" aria-label="Substack"><img src="/substack.svg" alt="Substack" /></a>
                  <a href="https://medium.com/@mattmcclendon" aria-label="Medium"><img src="/medium.svg" alt="Medium" /></a>
                  <a href="https://facebook.com/mattmcclendonco" aria-label="Facebook"><img src="/facebook.svg" alt="Facebook" /></a>
                  <a href="https://open.spotify.com/show/4lShSEhp8vnng0TmO1AQET?si=eea92d50416849be" aria-label="Spotify"><img class="social-icon-round" src="/spotify.svg" alt="Spotify" /></a>
                  <!--<a href="https://www.behance.net/mattmcclendon" aria-label="Behance"><img src="/behance.svg" alt="Behance" /></a>-->
                </div>
              </section>
            </div>
          </aside>
        </div>
      </div>
    </main>

    <footer class="site-footer">
      <div class="site-frame">
        <div class="footer-inner">
          <div class="footer-left">
            <p>© {new Date().getFullYear()} Matthew McClendon</p>
          </div>

          <div class="footer-right">
            <a href="mailto:hello@amidthenoise.com">Contact</a>
            <a href="/privacy">Privacy Policy</a>
            <a href="/legal">Terms of Use</a>
            <a href="#top" class="back-to-top">Back to Top ↑</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f8f7f4;
    --title: #0f172a;
    --text: #111827;
    --secondary: #334155;
    --accent: #3e5a82;
    --line: #ddd8cf;

    --frame-width: 1080px;
    --content-width: 740px;
    --sidebar-width: 280px;
  }

  html {
    background: var(--bg);
    color: var(--text);
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 19px;
    line-height: 1.76;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  .site-frame {
    width: min(var(--frame-width), calc(100% - 56px));
    margin: 0 auto;
  }

  .site-header {
    border-bottom: 1px solid var(--line);
  }

  .site-header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 20px 0;
  }

  .site-brand a {
    color: var(--title);
  }

  .site-wordmark {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    color: var(--title);
    text-decoration: none;
  }

  .site-mark {
    width: 28px;
    height: 28px;
    flex: 0 0 28px;
    background: var(--accent);
    display: inline-block;
  }

  .site-name {
    font-family: "Source Serif 4", Georgia, "Times New Roman", serif;
    font-size: 2.2rem;
    line-height: 1;
    font-weight: 500;
    font-optical-sizing: auto;
    letter-spacing: -0.01em;
    color: var(--title);
  }

  .site-wordmark:hover {
    text-decoration: none;
  }

  .site-nav {
    display: flex;
    gap: 30px;
    flex-wrap: wrap;
  }

  .site-nav a {
    color: var(--secondary);
    font-family: "Source Serif 4", Georgia, "Times New Roman", serif;
    font-size: 1.1rem;
    line-height: 1.2;
    font-weight: 500;
    font-optical-sizing: auto;
    letter-spacing: -0.01em;
  }

  .site-nav a:hover {
    color: var(--title);
  }

  .site-main {
    padding: 64px 0 96px;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) var(--sidebar-width);
    gap: 48px;
  }

  .main-content {
    width: min(var(--content-width), 100%);
    padding-right: 28px;
    border-right: 1px solid var(--line);
    min-width: 0;
  }

  .sidebar {
    padding-left: 6px;
    font-size: 0.96rem;
    color: var(--secondary);
  }

  .sidebar-inner {
    position: sticky;
    top: 72px;
  }

  .sidebar-section {
    padding-top: 22px;
    margin-top: 22px;
    border-top: 1px solid var(--line);
  }

  .sidebar-section:first-child {
    padding-top: 0;
    margin-top: 0;
    border-top: none;
  }

  .sidebar h3 {
    margin: 0 0 14px;
    font-size: 0.78rem;
    line-height: 1.3;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--secondary);
  }

  .sidebar p {
    margin: 0 0 0.9em;
    color: #2f3a4a;
    line-height: 1.5;
  }

  .sidebar-section a {
    color: var(--accent);
    font-size: 0.95rem;
  }

  .sidebar-section a:hover {
    text-decoration: underline;
  }


  h1 {
    margin: 0 0 18px;
    font-family: "Source Serif 4", Georgia, "Times New Roman", serif;
    font-size: clamp(1.9rem, 3vw, 2.4rem);
    line-height: 1.08;
    font-weight: 550;
    font-optical-sizing: auto;
    letter-spacing: -0.015em;
    color: var(--title);
  }

  h2 {
    margin: 36px 0 12px;
    font-size: 0.92rem;
    line-height: 1.3;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  h3 {
    margin: 20px 0 6px;
    font-size: 1.12rem;
    line-height: 1.35;
    font-weight: 600;
    color: var(--title);
  }

  p {
    margin: 0 0 1.25em;
    color: var(--text);
  }

  .section {
    max-width: 48rem;
    padding: 36px 0;
    border-top: 1px solid var(--line);
  }

  .section:first-of-type {
    padding-top: 0;
    border-top: none;
  }

  .section h1 {
    margin: 0 0 18px;
    font-family: "Source Serif 4", Georgia, "Times New Roman", serif;
    font-size: clamp(1.9rem, 3vw, 2.4rem);
    line-height: 1.08;
    font-weight: 550;
    font-optical-sizing: auto;
    letter-spacing: -0.015em;
  }

  .section h2 {
    margin: 36px 0 12px;
    font-size: 0.92rem;
    line-height: 1.3;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  .section h3 {
    margin: 20px 0 6px;
    font-size: 1.12rem;
    line-height: 1.35;
    font-weight: 600;
    color: var(--title);
  }

  .section p {
    margin: 0 0 12px;
    max-width: 48rem;
    font-size: 1rem;
    line-height: 1.7;
  }

  .section p:last-child {
    margin-bottom: 0;
  }

  .books-page {
    max-width: 48rem;
    padding: 36px 0;
    border-top: 1px solid var(--line);
  }

  .books-page:first-of-type {
    padding-top: 0;
    border-top: none;
  }

  .books-page p {
    margin: 0 0 12px;
    max-width: 48rem;
    font-size: 1rem;
    line-height: 1.7;
  }

  .books-page p:last-child {
    margin-bottom: 0;
  }

  .books-page .poem {
    margin: 18px 0 8px;
    padding-left: 1.25rem;
    border-left: 2px solid #d6d9df;
    font-style: normal;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text);
  }

  .books-page .citation {
    margin-top: 0;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--secondary);
  }

  .entry {
    padding: 22px 0 38px;
    border-top: 1px solid var(--line);
  }

  .entry:first-of-type {
    border-top: 0;
    padding-top: 0;
  }

  .entry h3 {
    margin: 0 0 8px;
    font-size: 1.28rem;
    line-height: 1.28;
    font-weight: 600;
  }

  .entry h3 a {
    color: var(--title);
  }

  .entry-meta {
    margin: 0 0 12px;
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--secondary);
  }

  .entry p {
    margin: 0 0 10px;
    font-size: 0.96rem;
    color: var(--secondary);
    line-height: 1.55;
  }

  .social-icons {
    display: flex;
    align-items: center;
    gap: 20px;
    margin: 12px 0 0;
  }

  .social-icons a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--secondary);
    text-decoration: none;
  }

  .social-icons img {
    display: block;
    width: 28px;
    height: 28px;
    opacity: 0.72;
    transition: opacity 0.2s ease;
  }
  .social-icons img.social-icon-round {
    width: 27px;
    height: 27px;
  }

  .social-icons a:hover img {
    opacity: 1;
  }

  .site-footer {
    margin-top: 88px;
    padding: 24px 0 28px;
    border-top: 1px solid var(--line);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .footer-left p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--secondary);
  }

  .footer-right {
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
  }

  .footer-right a {
    font-size: 0.9rem;
    color: var(--secondary);
    text-decoration: none;
  }

  .footer-right a:hover {
    color: var(--accent);
  }

  .back-to-top {
    opacity: 0.85;
  }

  @media (max-width: 900px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .main-content {
      width: 100%;
      padding-right: 0;
      border-right: none;
    }

    .sidebar {
      padding-left: 0;
      margin-top: 8px;
    }

    .sidebar-inner {
      position: static;
    }
  }

  @media (max-width: 720px) {
    body {
      font-size: 18px;
      line-height: 1.68;
    }

    .site-frame {
      width: min(var(--frame-width), calc(100% - 32px));
    }

    .site-header-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }

    .site-wordmark {
      gap: 14px;
    }

    .site-mark {
      width: 22px;
      height: 22px;
      flex-basis: 22px;
    }

    .site-name {
      font-size: 1.2rem;
    }

    .site-nav {
      gap: 20px;
    }

    .site-main {
      padding: 44px 0 68px;
    }

    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .footer-right {
      gap: 16px;
    }

    h1 {
      font-size: 2rem;
    }
  }
</style>
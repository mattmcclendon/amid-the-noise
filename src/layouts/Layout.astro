---
import LinkedInIcon from '../components/icons/linkedin.astro';
import GitHubIcon from '../components/icons/github.astro';
import FacebookIcon from '../components/icons/facebook.astro';
import BehanceIcon from '../components/icons/behance.astro';
import XIcon from '../components/icons/x.astro';
import RSSIcon from '../components/icons/rss.astro';

const {
  title = 'Amid the Noise',
  description = 'Amid the Noise is Matthew McClendon’s living archive of essays, systems work, design thinking, field studies, recovery reflections, and ongoing projects.',
  ogImage = '/images/og-default.png',
} = Astro.props;

const siteTitle = 'Amid the Noise';
const siteUrl = 'https://www.amidthenoise.com';
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KE5ZDGD6KP"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-KE5ZDGD6KP');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,200..900&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Amid the Noise RSS Feed"
      href="/rss.xml"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <slot name="head" />
  </head>

  <body id="top">
    <header class="site-header">
      <div class="site-frame">
        <div class="site-header-inner">
          <div class="site-brand">
            <a href="/" class="site-wordmark" aria-label="Amid the Noise home">
              <span class="site-mark" aria-hidden="true"></span>
              <span class="site-name">amid the noise</span>
            </a>
          </div>

          <nav class="site-nav" aria-label="Primary">
            <a href="/work" class="nav-work">Work</a>
            <a href="/writing" class="nav-writing">Writing</a>
            <a href="/learning" class="nav-learning">Learning</a>
            <a href="/papers" class="nav-papers">Papers</a>
            <a href="/thinking" class="nav-thinking">Thinking</a>
            <!--<a href="/about" class="nav-about">About</a>-->
            <a href="/search" class="site-search-link nav-search" aria-label="Search">
              <img src="/search.svg" alt="" aria-hidden="true" class="site-search-icon" />
            </a>
          </nav>
        </div>
      </div>
    </header>

    <main class="site-main">
      <div class="site-frame">
        <div class="content-grid">
          <div class="main-content">
            <slot />
          </div>

          <aside class="sidebar">
            <div class="sidebar-inner">
              <section class="sidebar-section">
                <!--<h3>Who is Matthew McClendon?</h3>-->
                <p><em>Matthew McClendon</em> is a product designer with 30 years of experience designing interfaces, workflows, and decision systems, increasingly in contexts where AI behavior must be legible, contestable, and accountable.</p>
                <p>His work spans financial, enterprise, civic, and AI-enabled organizations, designing the interfaces, workflows, and governance systems that shape how people make decisions under pressure.</p>
                <p>The recurring problem: <em>how do you make invisible system behavior legible enough for sound judgment?</em></p>
                <p class="sidebar-evidence"><strong><em>Amid the Noise</em></strong> <span>is the</span> <strong>evidence.</strong></p>
                <p class="sidebar-about-link"><a href="/about">read more →</a></p>
              </section>

              <!--
              <section class="sidebar-section sidebar-contact-section">
                <h3>Contact</h3>
                <p>For collaborations, speaking inquiries, or related work, <a href="mailto:hello@amidthenoise.com">contact me</a>.</p>
              </section>
              -->

              <section class="sidebar-section">
                <h3>Follow</h3>
                <div class="social-icons">
                  <a href="https://linkedin.com/in/mattmcclendon" aria-label="LinkedIn"><LinkedInIcon /></a>
                  <a href="https://github.com/mattmcclendon" aria-label="GitHub"><GitHubIcon /></a>
                  <a href="https://facebook.com/mattmcclendonco" aria-label="Facebook"><FacebookIcon /></a>
                  <a href="https://www.behance.net/mattmcclendon" aria-label="Behance"><BehanceIcon /></a>
                  <a href="https://x.com/AmidtheNoise" aria-label="X/Twitter"><XIcon /></a>
                  <a href="/rss.xml" aria-label="RSS Feed"><RSSIcon /></a>
                </div>
              </section>
            </div>
          </aside>
        </div>
      </div>
    </main>

    <div class="footer-treeline" aria-hidden="true"></div>

    <footer class="site-footer">
      <div class="site-frame">
        <div class="footer-inner">
          <div class="footer-left">
            <p>© {new Date().getFullYear()} Matthew McClendon (Amid the Noise, LLC)</p>
          </div>

          <div class="footer-right">
            <a href="mailto:hello@amidthenoise.com">Contact Me</a>
            <a href="/privacy" label="Privacy Policy">Privacy Policy</a>
            <a href="/legal" label="Terms of Use">Terms of Use</a>
            <a href="#top" class="back-to-top" label="Back to Top">Back to Top ↑</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f8f7f4;
    --title: #0f172a;
    --text: #111827;
    --secondary: #334155;
    --accent: #3e5a82;
    /* Palette colors */
    --accent-rust: #a4633f; /* rust */
    --accent-plum: #7a3f68; /* stronger plum */
    --accent-blue-gray: #4f7893; /* clearer blue-gray */
    --accent-graphite: #252b33; /* near-charcoal graphite */
    --accent-brass: #b48a4a; /* brass */
    --accent-slate: #334155; /* slate */

    /* Section colors */
    --accent-work: var(--accent-rust); /* rust */
    --accent-writing: var(--accent-plum); /* plum */
    --accent-learning: var(--accent-blue-gray); /* blue-gray */
    --accent-papers: var(--accent-graphite); /* graphite */
    --accent-thinking: var(--accent-brass); /* brass */
    --accent-neutral: var(--accent-slate); /* slate */
    --line: #ddd8cf;

    --frame-width: 1080px;
    --content-width: 740px;
    --sidebar-width: 280px;

    --font-serif: "Source Serif 4", Georgia, "Times New Roman", serif;
    --font-body: Georgia, "Times New Roman", serif;

    --space-section: 36px;
    --space-entry-y: 22px;
    --radius-card: 0;
  }

  html {
    background: var(--bg);
    color: var(--text);
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 19px;
    line-height: 1.76;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  .site-frame {
    width: min(var(--frame-width), calc(100% - 56px));
    margin: 0 auto;
  }

  .site-header {
    border-bottom: 1px solid var(--line);
  }

  .site-header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 20px 0;
  }

  .site-brand a {
    color: var(--title);
  }

  .site-wordmark {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    color: var(--title);
    text-decoration: none;
  }

  .site-mark {
    width: 28px;
    height: 28px;
    flex: 0 0 28px;
    background: var(--accent);
    display: inline-block;
  }

  .site-name {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    line-height: 1;
    font-weight: 500;
    font-optical-sizing: auto;
    letter-spacing: -0.01em;
    color: var(--title);
  }

  .site-wordmark:hover {
    text-decoration: none;
  }

  .site-nav {
    display: flex;
    gap: 30px;
    flex-wrap: wrap;
  }

  .site-nav a {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    color: var(--secondary);
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.2;
    font-weight: 500;
    font-optical-sizing: auto;
    letter-spacing: -0.01em;
    text-decoration: none;
  }

  .site-nav a::after {
    content: "";
    display: block;
    width: 100%;
    height: 2px;
    background: var(--nav-accent, var(--accent-neutral));
    opacity: 0;
    transform: scaleX(0.72);
    transform-origin: left center;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .site-nav a:hover {
    text-decoration: none;
  }

  .site-nav a:hover::after,
  .site-nav a[aria-current="page"]::after,
  .site-nav a.is-active::after {
    opacity: 1.0;
    transform: scaleX(1);
  }

  .site-nav .nav-work {
    --nav-accent: var(--accent-work);
  }

  .site-nav .nav-writing {
    --nav-accent: var(--accent-writing);
  }

  .site-nav .nav-learning {
    --nav-accent: var(--accent-learning);
  }

  .site-nav .nav-papers {
    --nav-accent: var(--accent-papers);
  }

  .site-nav .nav-thinking {
    --nav-accent: var(--accent-thinking);
  }

  .site-nav .nav-about,
  .site-nav .nav-search {
    --nav-accent: var(--accent-neutral);
  }

  .site-search-link {
    align-items: center;
    justify-content: center;
    width: 1.1rem;
    height: calc(1.1rem + 8px);
    transform: translateY(1px);
  }

  .site-search-icon {
    display: block;
    width: 1.15rem;
    height: 1.15rem;
    opacity: 0.88;
    transition: opacity 0.2s ease;
  }

  .site-search-link:hover {
    text-decoration: none;
  }

  .site-search-link:hover .site-search-icon {
    opacity: 1;
  }

  .site-main {
    padding: 64px 0 56px;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) var(--sidebar-width);
    gap: 48px;
  }

  .main-content {
    width: min(var(--content-width), 100%);
    padding-right: 28px;
    border-right: 1px solid var(--line);
    min-width: 0;
  }

  .sidebar {
    padding-left: 6px;
    font-size: 0.9rem;
    color: var(--secondary);
  }

  .sidebar-inner {
    position: sticky;
    top: 72px;
    max-height: calc(100vh - 96px);
    overflow-y: auto;
    padding-right: 4px;
    scrollbar-width: thin;
  }

  .sidebar-section {
    padding-top: 22px;
    margin-top: 22px;
    border-top: 1px solid var(--line);
  }

  .sidebar-section:first-child {
    padding-top: 0;
    margin-top: 0;
    border-top: none;
  }

  .sidebar h3 {
    margin: 0 0 14px;
    font-size: 0.78rem;
    line-height: 1.3;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--secondary);
  }

  .sidebar p {
    margin: 0 0 0.9em;
    color: #2f3a4a;
    line-height: 1.5;
  }
  .sidebar-evidence {
    font-weight: 400;
  }

  .sidebar-evidence strong {
    font-weight: 600;
  }

  .sidebar-evidence span {
    font-weight: 400;
  }

  .sidebar-about-link {
    text-align: right;
    padding-top: 20px;
  }

  .sidebar-about-link a {
   font-size: 0.95rem;  
  }

  .sidebar-section a {
    color: var(--accent);
    font-size: 0.9rem;
  }

  .sidebar-section a:hover {
    text-decoration: underline;
  }


  .framework-name {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 1em;
    letter-spacing: 0.01em;
  }


  h1 {
    margin: 0 0 18px;
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 3vw, 2.4rem);
    line-height: 1.08;
    font-weight: 550;
    font-optical-sizing: auto;
    letter-spacing: -0.015em;
    color: var(--title);
  }

  h2 {
    margin: 36px 0 12px;
    font-size: 0.92rem;
    line-height: 1.3;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  h3 {
    margin: 20px 0 6px;
    font-size: 1.12rem;
    line-height: 1.35;
    font-weight: 600;
    color: var(--title);
  }

  p {
    margin: 0 0 1.25em;
    color: var(--text);
  }

  .section {
    max-width: 48rem;
    padding: var(--space-section) 0;
    border-top: 1px solid var(--line);
  }

  .section:first-of-type {
    padding-top: 0;
    border-top: none;
  }

  .section h1 {
    margin: 0 0 18px;
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 3vw, 2.4rem);
    line-height: 1.08;
    font-weight: 550;
    font-optical-sizing: auto;
    letter-spacing: -0.015em;
  }

  .section h2 {
    margin: 36px 0 12px;
    font-size: 0.92rem;
    line-height: 1.3;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  .section h3 {
    margin: 20px 0 6px;
    font-size: 1.12rem;
    line-height: 1.35;
    font-weight: 600;
    color: var(--title);
  }

  .section p {
    margin: 0 0 12px;
    max-width: 48rem;
    font-size: 1rem;
    line-height: 1.7;
  }

  .section p:last-child {
    margin-bottom: 0;
  }

  .section-heading {
    margin: 0 0 44px;
  }

  .section-heading h2 {
    margin: 0 0 8px;
    font-size: 0.92rem;
    line-height: 1.3;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  .section-heading p {
    margin: 0;
    max-width: 44rem;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--secondary);
  }

  .intro-lead {
    margin: 0 0 1.25em;
    max-width: 46rem;
    font-size: 1.08rem;
    line-height: 1.68;
    color: var(--text);
  }

  .content-card {
    padding: 18px 0;
    border-top: 1px solid var(--line);
  }

  .content-card:first-child {
    padding-top: 0;
    border-top: none;
  }

  .content-card h3,
  .content-card-title {
    margin: 0 0 8px;
    font-size: 1.18rem;
    line-height: 1.3;
    font-weight: 600;
    color: var(--title);
  }

  .content-card p {
    margin: 0 0 10px;
    font-size: 0.96rem;
    line-height: 1.55;
    color: var(--secondary);
  }

  .content-card-meta {
    margin: 0 0 8px;
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--secondary);
  }

  .content-link,
  .entry-link,
  .next-path {
    color: var(--accent);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .books-page {
    max-width: 48rem;
    padding: 36px 0;
    border-top: 1px solid var(--line);
  }

  .books-page:first-of-type {
    padding-top: 0;
    border-top: none;
  }

  .books-page p {
    margin: 0 0 12px;
    max-width: 48rem;
    font-size: 1rem;
    line-height: 1.7;
  }

  .books-page p:last-child {
    margin-bottom: 0;
  }

  .books-page .poem {
    margin: 18px 0 8px;
    padding-left: 1.25rem;
    border-left: 2px solid #d6d9df;
    font-style: normal;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text);
  }

  .books-page .citation {
    margin-top: 0;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--secondary);
  }

  .entry {
    padding: var(--space-entry-y) 0 38px;
    border-top: 1px solid var(--line);
  }

  .entry:first-of-type {
    border-top: 0;
    padding-top: 0;
  }

  .entry h3 {
    margin: 0 0 8px;
    font-size: 1.28rem;
    line-height: 1.28;
    font-weight: 600;
  }

  .entry h3 a {
    color: var(--title);
  }

  .entry-meta {
    margin: 0 0 12px;
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--secondary);
  }

  .entry p {
    margin: 0 0 10px;
    font-size: 0.96rem;
    color: var(--secondary);
    line-height: 1.55;
  }

  .social-icons {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .social-icons svg {
    width: 22px;
    height: 22px;
    fill: currentColor;
    opacity: 0.58;
    transition: opacity 0.2s ease;
  }

  .social-icons a:hover svg {
    opacity: 1;
  }

  .social-icons a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--secondary);
    text-decoration: none;
  }

  .social-icons img {
    display: block;
    width: 25px;
    height: 25px;
    opacity: 0.76;
    transition: opacity 0.2s ease;
  }
  .social-icons img.social-icon-round {
    width: 24px;
    height: 24px;
  }

  .social-icons a:hover img {
    opacity: 1;
  }


  .footer-treeline {
    height: clamp(72px, 6vw, 96px);
    background-color: var(--bg);
    background-image: url('/images/atn-footer-treeline.png');
    background-repeat: repeat-x;
    background-position: center bottom;
    background-size: auto clamp(72px, 6vw, 96px);
    pointer-events: none;
  }

  .site-footer {
    margin-top: 0;
    padding: 24px 0 28px;
    background: #d1ccc1;
    border-top: 1px solid #d1ccc1;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
  }

  .footer-left p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--secondary);
  }

  .footer-right {
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
  }

  .footer-right a {
    font-size: 0.9rem;
    color: var(--secondary);
    text-decoration: none;
  }

  .footer-right a:hover {
    color: var(--accent);
  }

  .back-to-top {
    opacity: 0.85;
  }

  @media (max-width: 900px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .main-content {
      width: 100%;
      padding-right: 0;
      border-right: none;
    }

    .sidebar {
      padding-left: 0;
      margin-top: 8px;
      font-size: 0.96rem;
    }

    .sidebar-inner {
      position: static;
      max-height: none;
      overflow: visible;
      padding-right: 0;
    }


  }

  @media (max-width: 720px) {
    body {
      font-size: 18px;
      line-height: 1.68;
    }

    .site-frame {
      width: min(var(--frame-width), calc(100% - 32px));
    }

    .site-header-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }

    .site-wordmark {
      gap: 14px;
    }

    .site-mark {
      width: 22px;
      height: 22px;
      flex-basis: 22px;
    }

    .site-name {
      font-size: 1.2rem;
    }

    .site-nav {
      gap: 20px;
    }

    .site-main {
      padding: 44px 0 44px;
    }


    .footer-treeline {
      height: 58px;
      background-size: auto 58px;
      background-position: center bottom;
    }

    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .footer-right {
      gap: 16px;
    }

    h1 {
      font-size: 2rem;
    }
  }
</style>
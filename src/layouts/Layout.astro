---
import SiteHeader from '../components/SiteHeader.astro';
import RightRail from '../components/RightRail.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/global.css';

const {
  title = 'Amid the Noise',
  description = 'Essays and field studies on systems, signal, trust, recovery, and the structures that shape how people think and act.',
  ogImage = '/images/og-default.png',
} = Astro.props;

const siteTitle = 'Amid the Noise';
const siteUrl = (Astro.site ?? new URL('https://amidthenoise.com')).toString();
const pageTitle = title === siteTitle || title.endsWith(`| ${siteTitle}`)
  ? title
  : `${title} | ${siteTitle}`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KE5ZDGD6KP"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-KE5ZDGD6KP');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,200..900&display=optional" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Amid the Noise RSS Feed"
      href="/rss.xml"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <slot name="head" />
  </head>

  <body id="top">
    <SiteHeader currentPath={currentPath} />

    <main class="site-main">
      <div class="site-frame">
        <div class="content-grid">
          <div class="main-content">
            <slot />
          </div>

          <RightRail />
        </div>
      </div>
    </main>

    <SiteFooter />
  </body>
</html>

---
import FoundationMark from '../components/FoundationMark.astro';
import Layout from '../layouts/Layout.astro';

const groundTruths = [
  'People cannot meaningfully govern what they cannot understand.',
  'Every consequential decision has a responsible human institution behind it.',
  'Complexity does not eliminate power; it makes power harder to see.',
  'Trust emerges from consistent, observable system behavior.',
  'Access without comprehension, agency, and dignity is incomplete.',
  'Technology inherits the assumptions and incentives of the systems around it.',
  'Systems designed without the people most affected will predictably misunderstand them.',
];

const commitments = [
  {
    label: 'Defend',
    title: 'The human conditions trustworthy systems must preserve.',
    items: [
      'Human agency and dignity',
      'Visible responsibility',
      'Meaningful participation',
      'The right to question consequential decisions',
      'Human judgment where consequences cannot be responsibly automated',
    ],
  },
  {
    label: 'Investigate',
    title: 'The places where power and responsibility become obscured.',
    items: [
      'Automated and AI-assisted decisions',
      'Civic and institutional infrastructure',
      'Barriers disguised as administrative necessity',
      'The distance between policy and lived experience',
      'How complexity alters trust, participation, and belonging',
    ],
  },
  {
    label: 'Build',
    title: 'Practical ways to make systems more legible and humane.',
    items: [
      'Public-interest research',
      'Frameworks for evaluating consequential systems',
      'Open educational resources',
      'Models for meaningful human oversight',
      'Partnerships that translate insight into practice',
    ],
  },
  {
    label: 'Refuse',
    title: 'Boundaries that protect the integrity of the work.',
    items: [
      'Technology that obscures responsibility',
      'Efficiency purchased through diminished dignity',
      'Participation used to legitimize predetermined outcomes',
      'Complexity used to prevent scrutiny',
      'Funding or partnerships that require silence about harm',
    ],
  },
];

const focusAreas = [
  {
    number: '01',
    title: 'Civic legibility',
    description: 'Helping people see how public systems work, where responsibility lives, and how decisions move into everyday life.',
  },
  {
    number: '02',
    title: 'Human-governed intelligence',
    description: 'Keeping judgment, accountability, and the consequences of automated decisions visible to human beings.',
  },
  {
    number: '03',
    title: 'Public-interest design',
    description: 'Improving the clarity, access, dignity, and trustworthiness of consequential services and the systems behind them.',
  },
];
---

<Layout>
  <header class="site-header">
    <div class="frame header-inner">
      <a href="#top" class="wordmark" aria-label="Amid the Noise Foundation home">
        <FoundationMark />
        <span class="wordmark-copy">
          <span class="wordmark-name">Amid the Noise</span>
          <span class="wordmark-label">Foundation</span>
        </span>
      </a>

      <nav aria-label="Primary navigation">
        <a href="#mission">Mission</a>
        <a href="#work">Work</a>
        <a href="#ground-truths">Ground truths</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero frame" aria-labelledby="hero-heading">
      <p class="status"><span></span>An initiative in formation</p>
      <div class="hero-grid">
        <div>
          <h1 id="hero-heading">Making complex systems more understandable, accountable, and humane.</h1>
          <p class="hero-deck">Amid the Noise Foundation supports public-interest research, design, and practical work where technology, institutions, and civic life meet.</p>
          <a class="arrow-link" href="#mission">Explore the mission <span aria-hidden="true">↓</span></a>
        </div>

        <div class="signal-field" aria-hidden="true">
          <span class="signal-mark"><FoundationMark /></span>
          <span class="signal-block signal-block--one"></span>
          <span class="signal-block signal-block--two"></span>
          <span class="signal-line signal-line--one"></span>
          <span class="signal-line signal-line--two"></span>
        </div>
      </div>
    </section>

    <section id="mission" class="section-rule">
      <div class="frame split">
        <p class="eyebrow">Our mission</p>
        <div class="mission-copy">
          <h2 class="display-heading">Too many consequential systems are visible only through their outcomes.</h2>
          <p>People increasingly live inside technical, institutional, and civic structures they cannot see, understand, or meaningfully challenge. Decisions arrive without context. Responsibility becomes difficult to locate. Complexity creates distance between people and the systems meant to serve them.</p>
          <p>We work to close that distance—making complex systems more legible, strengthening human agency, and helping institutions build trust through what they do, not simply what they promise.</p>
          <blockquote>No system should become too complex, automated, or institutionally protected for the people affected by it to understand where power lives, how decisions are made, and who remains responsible.</blockquote>
        </div>
      </div>
    </section>

    <section id="work" class="work section-rule">
      <div class="frame">
        <div class="section-intro split">
          <p class="eyebrow">The work</p>
          <div>
            <h2 class="display-heading">What we are prepared to defend, investigate, build, and refuse.</h2>
            <p class="section-deck">This framework is both a public commitment and a practical test for deciding what belongs inside the foundation.</p>
          </div>
        </div>

        <div class="commitment-grid">
          {commitments.map((commitment, index) => (
            <article class="commitment-card">
              <div class="commitment-heading">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <p class="eyebrow">{commitment.label}</p>
              </div>
              <h3>{commitment.title}</h3>
              <ul>
                {commitment.items.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))}
        </div>

        <div class="focus-heading split">
          <p class="eyebrow">Where we begin</p>
          <p>Three connected areas define the foundation’s first field of work.</p>
        </div>

        <div class="focus-grid">
          {focusAreas.map((area) => (
            <article>
              <p class="focus-number">{area.number}</p>
              <h3>{area.title}</h3>
              <p>{area.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="ground-truths" class="section-rule">
      <div class="frame split">
        <p class="eyebrow">Ground truths</p>
        <div>
          <h2 class="display-heading">What experience, research, and observation have taught us about people and systems.</h2>
          <ol class="truth-list">
            {groundTruths.map((truth, index) => (
              <li>
                <span>{String(index + 1).padStart(2, '0')}</span>
                <p>{truth}</p>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <section id="contact" class="contact">
      <div class="frame contact-grid">
        <p class="eyebrow">Begin a conversation</p>
        <div>
          <h2>Better systems begin when their hidden assumptions become visible.</h2>
          <p>We are beginning with research, open resources, and conversations with people working inside consequential systems.</p>
          <a href="mailto:info@amidthenoise.com">info@amidthenoise.com <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="frame footer-grid">
      <div class="footer-brand">
        <FoundationMark small={true} />
        <span>Amid the Noise Foundation</span>
      </div>
      <p>Public-interest research and design for more legible systems.</p>
      <a href="https://amidthenoise.com">Writing and research archive <span aria-hidden="true">↗</span></a>
    </div>
  </footer>
</Layout>

<style>
  .site-header {
    position: sticky;
    z-index: 10;
    top: 0;
    border-bottom: 1px solid color-mix(in srgb, var(--line) 86%, transparent);
    background: color-mix(in srgb, var(--paper) 93%, transparent);
    backdrop-filter: blur(14px);
  }

  .header-inner {
    min-height: 104px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 38px;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    text-decoration: none;
  }

  .wordmark-copy {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .wordmark-name {
    font-family: var(--serif);
    font-size: 1.78rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 0.9;
  }

  .wordmark-label {
    color: var(--muted);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    line-height: 1;
    text-transform: uppercase;
  }

  nav {
    display: flex;
    gap: 30px;
  }

  nav a {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
  }

  nav a:hover {
    color: var(--green-dark);
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  .hero {
    padding-top: clamp(84px, 10vw, 150px);
    padding-bottom: clamp(96px, 12vw, 172px);
  }

  .status {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 58px;
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .status > span {
    width: 7px;
    height: 7px;
    background: var(--green);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 800px) minmax(210px, 1fr);
    gap: 68px;
  }

  h1 {
    max-width: 800px;
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(3.25rem, 6.2vw, 5.95rem);
    font-weight: 500;
    letter-spacing: -0.05em;
    line-height: 0.97;
  }

  .hero-deck {
    max-width: 650px;
    margin: 40px 0 32px;
    color: var(--muted);
    font-family: var(--serif);
    font-size: clamp(1.16rem, 1.8vw, 1.42rem);
    line-height: 1.55;
  }

  .arrow-link,
  .contact a {
    display: inline-flex;
    gap: 12px;
    align-items: center;
    color: var(--green-dark);
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  .signal-field {
    position: relative;
    min-height: 440px;
    border-left: 1px solid var(--line);
  }

  .signal-mark,
  .signal-block,
  .signal-line {
    position: absolute;
  }

  .signal-mark {
    top: 0;
    right: 10%;
    transform: scale(1.9);
    transform-origin: top right;
  }

  .signal-block {
    display: block;
    background: var(--green);
  }

  .signal-block--one {
    top: 48%;
    left: 18%;
    width: 30px;
    height: 30px;
    opacity: 0.56;
  }

  .signal-block--two {
    right: 0;
    bottom: 3%;
    width: 14px;
    height: 14px;
    opacity: 0.28;
  }

  .signal-line {
    display: block;
    height: 1px;
    background: var(--line);
    transform-origin: left center;
  }

  .signal-line--one {
    top: 56%;
    left: 20%;
    width: 72%;
    transform: rotate(-30deg);
  }

  .signal-line--two {
    top: 39%;
    left: 38%;
    width: 64%;
    transform: rotate(67deg);
  }

  .mission-copy > p,
  .section-deck {
    max-width: 710px;
    margin: 30px 0 0;
    color: var(--muted);
    font-family: var(--serif);
    font-size: 1.08rem;
    line-height: 1.7;
  }

  blockquote {
    max-width: 710px;
    margin: 54px 0 0;
    padding: 4px 0 4px 28px;
    border-left: 4px solid var(--green);
    color: var(--ink);
    font-family: var(--serif);
    font-size: clamp(1.3rem, 2.4vw, 1.8rem);
    font-weight: 500;
    line-height: 1.45;
  }

  .section-intro {
    margin-bottom: 76px;
  }

  .section-deck {
    max-width: 650px;
    margin-top: 24px;
  }

  .commitment-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }

  .commitment-card {
    min-height: 470px;
    padding: 36px 40px 44px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .commitment-heading {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 64px;
  }

  .commitment-heading > span,
  .focus-number,
  .truth-list > li > span {
    color: var(--green);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .commitment-card h3 {
    max-width: 470px;
    margin: 0 0 28px;
    font-family: var(--serif);
    font-size: clamp(1.48rem, 2.5vw, 2rem);
    font-weight: 550;
    letter-spacing: -0.02em;
    line-height: 1.22;
  }

  .commitment-card ul {
    margin: 0;
    padding: 0;
    color: var(--muted);
    font-size: 0.84rem;
    line-height: 1.55;
    list-style: none;
  }

  .commitment-card li {
    position: relative;
    margin-top: 10px;
    padding-left: 17px;
  }

  .commitment-card li::before {
    position: absolute;
    top: 0.76em;
    left: 0;
    width: 5px;
    height: 5px;
    background: var(--green);
    content: "";
  }

  .focus-heading {
    margin: 118px 0 54px;
  }

  .focus-heading > p:last-child {
    max-width: 550px;
    margin: 0;
    color: var(--muted);
    font-family: var(--serif);
    font-size: 1.16rem;
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .focus-grid article {
    min-height: 330px;
    padding: 34px 34px 40px;
    border-left: 1px solid var(--line);
  }

  .focus-grid article:first-child {
    border-left: 0;
  }

  .focus-number {
    margin: 0 0 76px;
  }

  .focus-grid h3 {
    margin: 0 0 14px;
    font-family: var(--serif);
    font-size: 1.48rem;
    font-weight: 550;
    line-height: 1.2;
  }

  .focus-grid article > p:last-child {
    margin: 0;
    color: var(--muted);
    font-size: 0.84rem;
    line-height: 1.62;
  }

  .truth-list {
    margin: 58px 0 0;
    padding: 0;
    border-top: 1px solid var(--line);
    list-style: none;
  }

  .truth-list li {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 22px;
    align-items: baseline;
    padding: 25px 0;
    border-bottom: 1px solid var(--line);
  }

  .truth-list p {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    line-height: 1.35;
  }

  .contact {
    padding: clamp(96px, 12vw, 180px) 0;
    background: var(--green-dark);
    color: #f6f4ee;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 220px minmax(0, 800px);
    gap: clamp(48px, 8vw, 120px);
  }

  .contact .eyebrow,
  .contact a {
    color: #cfe0d9;
  }

  .contact h2 {
    max-width: 800px;
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(2.65rem, 5vw, 5rem);
    font-weight: 500;
    letter-spacing: -0.05em;
    line-height: 1.01;
  }

  .contact div > p {
    max-width: 650px;
    margin: 34px 0 26px;
    color: #cfe0d9;
    font-family: var(--serif);
    font-size: 1.08rem;
    line-height: 1.65;
  }

  footer {
    padding: 42px 0;
    background: #102e29;
    color: #cfe0d9;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 36px;
    align-items: center;
    font-size: 0.72rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-grid p {
    margin: 0;
    color: #9fb9b0;
  }

  .footer-grid > a {
    justify-self: end;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  @media (max-width: 920px) {
    nav {
      gap: 18px;
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }

    .signal-field {
      display: none;
    }

    .commitment-card {
      padding-inline: 30px;
    }

    .contact-grid {
      grid-template-columns: 150px minmax(0, 1fr);
      gap: 40px;
    }
  }

  @media (max-width: 760px) {
    nav {
      display: none;
    }

    .commitment-grid,
    .focus-grid {
      grid-template-columns: 1fr;
    }

    .commitment-card {
      min-height: auto;
    }

    .focus-grid article {
      min-height: 0;
      border-top: 1px solid var(--line);
      border-left: 0;
    }

    .focus-grid article:first-child {
      border-top: 0;
    }

    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-grid p {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .header-inner {
      min-height: 88px;
    }

    .wordmark :global(.foundation-mark) {
      width: 30px;
      height: 30px;
      flex-basis: 30px;
      gap: 3px;
    }

    .wordmark-name {
      font-size: 1.42rem;
    }

    .hero {
      padding-top: 70px;
      padding-bottom: 94px;
    }

    .status {
      margin-bottom: 42px;
    }

    h1 {
      font-size: clamp(2.8rem, 14vw, 4.4rem);
    }

    .section-intro {
      margin-bottom: 48px;
    }

    .commitment-grid {
      border-left: 0;
    }

    .commitment-card {
      padding: 30px 0 38px;
      border-right: 0;
    }

    .commitment-heading {
      margin-bottom: 42px;
    }

    .focus-heading {
      margin-top: 84px;
    }

    .focus-grid article {
      padding-inline: 0;
    }

    .focus-number {
      margin-bottom: 42px;
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: 34px;
    }

    .contact h2 {
      font-size: clamp(2.55rem, 13vw, 4rem);
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 22px;
    }

    .footer-grid > a {
      justify-self: start;
    }
  }
</style>
